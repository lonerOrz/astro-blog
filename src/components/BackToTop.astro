---
import ArrowIcon from "@components/ArrowIcon.astro";
---

<script>
  if (typeof window !== "undefined") {
    window.addEventListener("DOMContentLoaded", () => {
      const btn = document.getElementById("back-to-top");
      if (btn) {
        btn.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }
    });
  }
</script>

<button
  id="back-to-top"
  class="group btn-interactive relative flex w-fit flex-nowrap rounded-sm border border-zinc-200 py-1.5 pr-3 pl-8 hover:bg-zinc-100 hover:text-zinc-900 focus-visible:bg-zinc-100 focus-visible:text-zinc-900 dark:border-zinc-700 dark:hover:bg-zinc-800/60 dark:hover:text-zinc-50 dark:focus-visible:bg-zinc-800/60 dark:focus-visible:text-zinc-50"
>
  <ArrowIcon
    direction="up"
    size={4}
    class="absolute top-1/2 left-2 -translate-y-1/2"
  />
  <div class="text-sm">Back to top</div>
</button>
