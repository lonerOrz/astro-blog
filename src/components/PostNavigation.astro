---
const { prevPost, nextPost } = Astro.props;
---

<div class="grid grid-cols-2 gap-1.5 sm:gap-3">
  {
    prevPost?.id ? (
      <a
        href={`/blog/${prevPost?.id}`}
        class="group relative flex flex-nowrap rounded-lg border border-zinc-200 px-4 py-3 pl-10 no-underline card-interactive hover:bg-zinc-100 hover:text-zinc-900 focus-visible:bg-zinc-100 focus-visible:text-zinc-900 dark:border-zinc-700 dark:hover:bg-zinc-800/60 dark:hover:text-zinc-50 dark:focus-visible:bg-zinc-800/60 dark:focus-visible:text-zinc-50"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          class="absolute top-1/2 left-2 size-5 -translate-y-1/2 fill-none stroke-current stroke-2"
        >
          <line
            x1="5"
            y1="12"
            x2="19"
            y2="12"
            class="translate-x-3 scale-x-0 transition-transform duration-200 ease-emphasis group-hover:translate-x-0 group-hover:scale-x-100 group-focus-visible:translate-x-0 group-focus-visible:scale-x-100"
          />
          <polyline
            points="12 5 5 12 12 19"
            class="translate-x-1 transition-transform duration-200 ease-emphasis group-hover:translate-x-0 group-focus-visible:translate-x-0"
          />
        </svg>
        <div class="flex items-center text-sm">{prevPost?.data.title}</div>
      </a>
    ) : (
      <div class="invisible" />
    )
  }

  {
    nextPost?.id ? (
      <a
        href={`/blog/${nextPost?.id}`}
        class="group relative flex grow flex-row-reverse flex-nowrap rounded-lg border border-zinc-200 px-4 py-4 pr-10 no-underline card-interactive hover:bg-zinc-100 hover:text-zinc-900 focus-visible:bg-zinc-100 focus-visible:text-zinc-900 dark:border-zinc-700 dark:hover:bg-zinc-800/60 dark:hover:text-zinc-50 dark:focus-visible:bg-zinc-800/60 dark:focus-visible:text-zinc-50"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          class="absolute top-1/2 right-2 size-5 -translate-y-1/2 fill-none stroke-current stroke-2"
        >
          <line
            x1="5"
            y1="12"
            x2="19"
            y2="12"
            class="translate-x-3 scale-x-0 transition-transform duration-200 ease-emphasis group-hover:translate-x-0 group-hover:scale-x-100 group-focus-visible:translate-x-0 group-focus-visible:scale-x-100"
          />
          <polyline
            points="12 5 19 12 12 19"
            class="-translate-x-1 transition-transform duration-200 ease-emphasis group-hover:translate-x-0 group-focus-visible:translate-x-0"
          />
        </svg>
        <div class="flex items-center text-sm">{nextPost?.data.title}</div>
      </a>
    ) : (
      <div class="invisible" />
    )
  }
</div>
