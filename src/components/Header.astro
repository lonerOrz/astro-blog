---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { SITE } from "@consts";
---

<header transition:persist class="py-3">
  <Container>
    <div class="flex items-center justify-between">
      <Link href="/" underline={false}>
        <div class="flex items-center font-semibold text-sm">
          <img src="/site/hero.png" alt="logo" class="h-5 w-5 mr-1" />
          {SITE.TITLE}
        </div>
      </Link>
      <nav class="flex items-center gap-0.5 text-sm">
        <Link href="/" class="px-2 py-1 rounded hover:bg-black/5 dark:hover:bg-white/5 transition-colors">home</Link>
        <span class="text-black/20 dark:text-white/20">/</span>
        <Link href="/blog" class="px-2 py-1 rounded hover:bg-black/5 dark:hover:bg-white/5 transition-colors">blog</Link>
        <span class="text-black/20 dark:text-white/20">/</span>
        <Link href="/projects" class="px-2 py-1 rounded hover:bg-black/5 dark:hover:bg-white/5 transition-colors">projects</Link>
        <span class="text-black/20 dark:text-white/20">/</span>
        <Link href="/music" class="px-2 py-1 rounded hover:bg-black/5 dark:hover:bg-white/5 transition-colors">music</Link>
        <span class="text-black/20 dark:text-white/20">/</span>
        <Link href="/friends" class="px-2 py-1 rounded hover:bg-black/5 dark:hover:bg-white/5 transition-colors">friends</Link>
        <span class="text-black/20 dark:text-white/20">/</span>
        <Link href="/about" class="px-2 py-1 rounded hover:bg-black/5 dark:hover:bg-white/5 transition-colors">about</Link>
        <span class="text-black/20 dark:text-white/20 mx-1">/</span>
        <button
          id="magnifying-glass"
          aria-label="Search"
          class="flex items-center rounded-sm border border-black/15 bg-neutral-100 px-9 py-1 text-xs transition-colors duration-300 ease-in-out hover:bg-black/5 hover:text-black focus-visible:bg-black/5 focus-visible:text-black dark:border-white/20 dark:bg-slate-900 dark:hover:bg-white/5 dark:hover:text-white dark:focus-visible:bg-white/5 dark:focus-visible:text-white"
        >
          <svg
            height="16"
            stroke-linejoin="round"
            viewBox="0 0 16 16"
            width="16"
            style="color: currentcolor;"
            ><path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M3.5 7C3.5 5.067 5.067 3.5 7 3.5C8.933 3.5 10.5 5.067 10.5 7C10.5 7.88461 10.1718 8.69256 9.63058 9.30876L9.30876 9.63058C8.69256 10.1718 7.88461 10.5 7 10.5C5.067 10.5 3.5 8.933 3.5 7ZM9.96544 11.0261C9.13578 11.6382 8.11014 12 7 12C4.23858 12 2 9.76142 2 7C2 4.23858 4.23858 2 7 2C9.76142 2 12 4.23858 12 7C12 8.11014 11.6382 9.13578 11.0261 9.96544L14.0303 12.9697L14.5607 13.5L13.5 14.5607L12.9697 14.0303L9.96544 11.0261Z"
              fill="currentColor"></path></svg
          >
          &nbsp;Search
        </button>
      </nav>
    </div>
  </Container>
</header>
