---
const { item, index } = Astro.props;
---

<div class="bangumi-card-wrapper" style={`animation-delay: ${index * 0.05}s`}>
  <a
    href={item.url}
    target="_blank"
    class="group relative flex h-full flex-col space-y-4 rounded-[2rem] border border-zinc-200 bg-white/50 p-3 shadow-sm transition-all duration-500 hover:-translate-y-2 hover:border-zinc-300 hover:shadow-2xl dark:border-zinc-800 dark:bg-zinc-900/60 dark:hover:border-zinc-700"
  >
    <div
      class="relative aspect-[3/4] overflow-hidden rounded-[1.5rem] bg-zinc-100 dark:bg-zinc-950"
    >
      <img
        src={item.cover}
        alt={item.title}
        referrerpolicy="no-referrer"
        class="h-full w-full object-cover saturate-[0.4] transition-all duration-900 group-hover:scale-110 group-hover:saturate-100"
        loading="lazy"
      />
      {
        item.score && (
          <div class="absolute top-3 right-3 rounded-lg border border-white/20 bg-zinc-900/70 px-2 py-0.5 font-mono text-[10px] font-black text-white backdrop-blur-md dark:bg-zinc-100 dark:text-zinc-900">
            {item.score}
          </div>
        )
      }
    </div>

    <div class="flex flex-1 flex-col justify-between px-1 pb-1">
      <div class="space-y-1.5">
        <h3
          class="line-clamp-1 text-sm font-bold tracking-tight text-zinc-900 uppercase dark:text-zinc-100"
        >
          {item.title}
        </h3>

        <div
          class="flex items-center justify-between font-mono text-[9px] font-extrabold tracking-widest text-zinc-400 uppercase dark:text-zinc-500"
        >
          <span class="text-sky-600 dark:text-sky-400/90">{item.progress}</span>
          <span>{item.total}</span>
        </div>
      </div>

      <p
        class="mt-3 line-clamp-2 translate-y-2 text-[10px] leading-relaxed text-zinc-500 italic opacity-0 transition-all duration-500 group-hover:translate-y-0 group-hover:opacity-100 dark:text-zinc-400"
      >
        "{item.desc}"
      </p>
    </div>
  </a>
</div>

<style>
  .bangumi-card-wrapper {
    animation: slideUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    opacity: 0;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
