---
// src/components/Giscus.astro
---

<div class="giscus-wrapper pt-10" data-pagefind-ignore>
  <div
    class="giscus-placeholder flex flex-col items-center justify-center border-t border-zinc-200 py-12 dark:border-zinc-800"
  >
    <span
      class="animate-pulse font-mono text-[10px] tracking-[0.2em] text-zinc-400 uppercase dark:text-zinc-600"
    >
      Loading Comments...
    </span>
  </div>
</div>

<script is:inline data-astro-rerun>
  (function () {
    const wrapper = document.querySelector(".giscus-wrapper");
    if (!wrapper) return;

    function getTheme() {
      return document.documentElement.classList.contains("dark")
        ? "dark_dimmed"
        : "light";
    }

    function updateGiscusTheme() {
      const iframe = document.querySelector("iframe.giscus-frame");
      if (!iframe) return;

      iframe.contentWindow.postMessage(
        { giscus: { setConfig: { theme: getTheme() } } },
        "https://giscus.app",
      );
    }

    function loadGiscus() {
      if (wrapper.dataset.loaded === "true") return;

      const script = document.createElement("script");
      const attrs = {
        src: "https://giscus.app/client.js",
        "data-repo": "lonerOrz/astro-blog",
        "data-repo-id": "R_kgDOPXNc_A",
        "data-category": "Announcements",
        "data-category-id": "DIC_kwDOPXNc_M4CttkN",
        "data-mapping": "pathname",
        "data-strict": "0",
        "data-reactions-enabled": "1",
        "data-emit-metadata": "0",
        "data-input-position": "top",
        "data-theme": getTheme(),
        "data-lang": "en",
        crossorigin: "anonymous",
        async: "true",
      };

      Object.entries(attrs).forEach(([k, v]) => script.setAttribute(k, v));

      script.onload = () => {
        wrapper.dataset.loaded = "true";
        const placeholder = wrapper.querySelector(".giscus-placeholder");
        if (placeholder) {
          placeholder.style.transition = "opacity 0.5s ease";
          placeholder.style.opacity = "0";
          setTimeout(() => placeholder.remove(), 500);
        }
      };

      wrapper.appendChild(script);
    }

    // 初始化加载
    loadGiscus();

    // 监听主题切换：当 html class 变化时同步更新 Giscus
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.attributeName === "class") {
          updateGiscusTheme();
        }
      });
    });

    observer.observe(document.documentElement, { attributes: true });
  })();
</script>
