---
import type { CollectionEntry } from "astro:content";
import ArrowIcon from "@components/ArrowIcon.astro";
import FormattedDate from "@components/FormattedDate.astro";

type Props = {
  entry: CollectionEntry<"blog"> | CollectionEntry<"series">;
};

const { entry } = Astro.props;
---

<a
  href={`/${entry.collection}/${entry.id.replace(/\.(md|mdx)$/, "")}`}
  class="not-prose group translate-gpu relative flex flex-col gap-3 rounded-[1.5rem] border border-zinc-200 bg-white p-5 pr-12 transition-all duration-400 hover:-translate-y-1 hover:border-zinc-300 hover:shadow-2xl hover:shadow-zinc-200/50 dark:border-zinc-800 dark:bg-zinc-900/40 dark:hover:border-zinc-700 dark:hover:shadow-none"
>
  <!-- 顶部元数据 -->
  <div class="flex items-center gap-3">
    <div
      class="rounded-full bg-zinc-100 px-2 py-0.5 font-mono text-[9px] font-bold tracking-widest text-zinc-500 uppercase dark:bg-zinc-800 dark:text-zinc-400"
    >
      {entry.collection}
    </div>
    <div class="h-px w-6 bg-zinc-100 dark:bg-zinc-800"></div>
    <div class="font-mono text-[10px] font-medium text-zinc-400">
      <FormattedDate date={entry.data.date} />
    </div>
  </div>

  <!-- 内容区 -->
  <div class="flex min-w-0 flex-1 flex-col gap-1.5">
    <div
      class="text-[17px] leading-tight font-bold tracking-tight text-zinc-900 transition-colors group-hover:text-blue-600 dark:text-zinc-100 dark:group-hover:text-blue-400"
    >
      {entry.data.title}
    </div>
    <div
      class="line-clamp-2 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400"
    >
      {entry.data.description}
    </div>
  </div>

  <!-- 动态箭头容器 -->
  <div class="absolute top-1/2 right-5 -translate-y-1/2">
    <div
      class="flex size-8 items-center justify-center rounded-full border border-zinc-100 bg-zinc-50/50 text-zinc-300 shadow-sm transition-all duration-500 group-hover:scale-110 group-hover:border-zinc-900 group-hover:bg-zinc-900 group-hover:text-white dark:border-zinc-800 dark:bg-zinc-950 dark:group-hover:border-white dark:group-hover:bg-white dark:group-hover:text-black"
    >
      <ArrowIcon
        direction="right"
        class="size-3.5 transition-transform duration-500 group-hover:translate-x-0.5"
      />
    </div>
  </div>
</a>

<style>
  /* 解决移动端和低端浏览器渲染抖动 */
  .translate-gpu {
    backface-visibility: hidden;
    will-change: transform, border-color, box-shadow;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }
</style>
