---
type Playlist = {
  id: string;
  label: string;
};

type Variant = 'default' | 'v2';

interface Props {
  playlists: Playlist[];
  defaultPlaylist?: string;
  id?: string;
  variant?: Variant;
}

const {
  playlists = [],
  id = 'playlist-selector',
  variant = 'default',
} = Astro.props;

const defaultPlaylist =
  Astro.props.defaultPlaylist ??
  playlists[0]?.id ??
  '';

const useDropdown = playlists.length > 6;

const rootClass = [
  'playlist-selector-container',
  'animate',
  `variant-${variant}`,
];
---

<div
  id={id}
  class:list={rootClass}
  data-playlists={JSON.stringify(playlists)}
  data-default={defaultPlaylist}
>
  <div class="selector-header">
    <span class="label-tag">Switch Playlist</span>
    <span class="status-dot"></span>
  </div>

  <div class="selector-body" role="tablist" aria-label="Music playlists">
    {
      useDropdown ? (
        <div class="select-wrapper">
          <select class="playlist-select" aria-label="Select playlist">
            {playlists.map(({ id, label }) => (
              <option value={id} selected={id === defaultPlaylist}>
                {label}
              </option>
            ))}
          </select>
          <svg class="select-arrow" viewBox="0 0 20 20" fill="currentColor">
            <path d="M7 7l3-3 3 3m0 6l-3 3-3-3" />
          </svg>
        </div>
      ) : (
        <div class="playlist-buttons">
          {playlists.map(({ id, label }, index) => {
            const active = id === defaultPlaylist;
            return (
              <button
                role="tab"
                data-playlist={id}
                data-index={index}
                aria-selected={active}
                tabindex={active ? 0 : -1}
                class:list={['playlist-btn', { active }]}
              >
                {label}
              </button>
            );
          })}
        </div>
      )
    }
  </div>
</div>

<script>
  function initSelector() {
    const container = document.querySelector('.playlist-selector-container') as HTMLElement;
    if (!container) return;

    const buttons = container.querySelectorAll('.playlist-btn');
    const select = container.querySelector('.playlist-select') as HTMLSelectElement;

    const syncUI = (targetId: string) => {
      buttons.forEach(btn => {
        const isActive = btn.getAttribute('data-playlist') === targetId;
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-selected', String(isActive));
        (btn as HTMLElement).tabIndex = isActive ? 0 : -1;
      });
      if (select) select.value = targetId;
    };

    const updatePlaylist = (newId: string) => {
      syncUI(newId);

      localStorage.setItem("an_music_last_playlist", newId);

      window.dispatchEvent(new CustomEvent('playlist-change', {
        detail: { id: newId }
      }));
    };

    const savedId = localStorage.getItem("an_music_last_playlist");
    const defaultId = container.dataset.default;

    if (savedId && savedId !== defaultId) {
      const availablePlaylists = JSON.parse(container.dataset.playlists || '[]');
      if (availablePlaylists.some((p: any) => p.id === savedId)) {
        syncUI(savedId);
      }
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-playlist');
        if (id) updatePlaylist(id);
      });
    });

    select?.addEventListener('change', (e) => {
      const id = (e.target as HTMLSelectElement).value;
      updatePlaylist(id);
    });
  }

  initSelector();
  document.addEventListener("astro:after-swap", initSelector);
</script>

<style>
.playlist-selector-container {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
}

.selector-header {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  padding-left: 0.25rem;
}

.label-tag {
  font-family: var(--font-mono), monospace;
  font-size: 0.65rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: #94a3b8;
}

.status-dot {
  width: 5px;
  height: 5px;
  background-color: #10b981;
  border-radius: 9999px;
  box-shadow: 0 0 10px rgba(16, 185, 129, 0.5);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.2); }
  100% { opacity: 1; transform: scale(1); }
}

.playlist-buttons {
  display: inline-flex;
  padding: 0.3rem;
  background-color: rgba(0, 0, 0, 0.04);
  border: 1px solid rgba(0, 0, 0, 0.05);
  border-radius: 1.1rem;
  gap: 0.3rem;
  max-width: 100%;
  overflow-x: auto;
  scrollbar-width: none;
}

.playlist-buttons::-webkit-scrollbar { display: none; }

.playlist-btn {
  white-space: nowrap;
  padding: 0.45rem 1.1rem;
  font-size: 0.85rem;
  font-weight: 700;
  color: #64748b;
  border: none;
  border-radius: 0.85rem;
  background: transparent;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  backface-visibility: hidden;
}

.playlist-btn:hover {
  color: #1e293b;
  background-color: rgba(255, 255, 255, 0.5);
}

.playlist-btn.active {
  color: #ffffff;
  background-color: #0f172a;
  box-shadow: 0 10px 15px -3px rgba(15, 23, 42, 0.15);
}

@media (prefers-color-scheme: dark) {
  .playlist-buttons {
    background-color: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.08);
  }
  .playlist-btn { color: #94a3b8; }
  .playlist-btn:hover {
    color: #f1f5f9;
    background-color: rgba(255, 255, 255, 0.06);
  }
  .playlist-btn.active {
    color: #0f172a;
    background-color: #f8fafc;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.4);
  }
  .playlist-select {
    background-color: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.1);
    color: #f1f5f9;
  }
}

.playlist-btn:active { transform: scale(0.94); }
.select-wrapper { position: relative; max-width: 260px; }

.playlist-select {
  appearance: none;
  width: 100%;
  padding: 0.65rem 2.5rem 0.65rem 1.1rem;
  font-size: 0.875rem;
  font-weight: 700;
  color: #1e293b;
  background-color: rgba(0, 0, 0, 0.04);
  border: 1px solid rgba(0, 0, 0, 0.05);
  border-radius: 1rem;
  cursor: pointer;
  outline: none;
}

.select-arrow {
  position: absolute;
  right: 0.8rem;
  top: 50%;
  transform: translateY(-50%);
  width: 1.1rem;
  height: 1.1rem;
  pointer-events: none;
  color: #94a3b8;
}
</style>
