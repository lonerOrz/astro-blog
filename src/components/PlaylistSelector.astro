---
type Playlist = {
  id: string;
  label: string;
};

type Variant = "default" | "v2";

interface Props {
  playlists: Playlist[];
  defaultPlaylist?: string;
  id?: string;
  variant?: Variant;
}

const {
  playlists = [],
  id = "playlist-selector",
  variant = "default",
} = Astro.props;

const defaultPlaylist = Astro.props.defaultPlaylist ?? playlists[0]?.id ?? "";
const initialActiveLabel =
  playlists.find((p) => p.id === defaultPlaylist)?.label || "Playlist";
---

<div
  id={id}
  class:list={["playlist-selector-container", `variant-${variant}`]}
  data-playlists={JSON.stringify(playlists)}
  data-default={defaultPlaylist}
  data-open="false"
>
  <button
    type="button"
    class="micro-trigger"
    aria-haspopup="listbox"
    aria-expanded="false"
  >
    <span class="status-dot"></span>
    <span class="trigger-label">{initialActiveLabel}</span>
    <svg class="select-arrow" viewBox="0 0 20 20" fill="currentColor">
      <path
        fill-rule="evenodd"
        d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
        clip-rule="evenodd"></path>
    </svg>
  </button>

  <div class="horizontal-tray" role="listbox">
    {
      playlists.map(({ id: itemId, label }) => {
        const active = itemId === defaultPlaylist;
        return (
          <button
            type="button"
            class:list={["tray-item", { active }]}
            role="option"
            aria-selected={active}
            data-value={itemId}
          >
            {label}
          </button>
        );
      })
    }
  </div>

  <select
    class="playlist-select"
    aria-label="Select playlist"
    style="display: none;"
  >
    {
      playlists.map(({ id: itemId, label }) => (
        <option value={itemId} selected={itemId === defaultPlaylist}>
          {label}
        </option>
      ))
    }
  </select>
</div>

<script>
  function initSelector() {
    const containers = document.querySelectorAll(
      ".playlist-selector-container",
    );

    containers.forEach((container) => {
      const trigger = container.querySelector(
        ".micro-trigger",
      ) as HTMLButtonElement;
      const triggerLabel = container.querySelector(
        ".trigger-label",
      ) as HTMLElement;
      const items = container.querySelectorAll(".tray-item");
      const nativeSelect = container.querySelector(
        ".playlist-select",
      ) as HTMLSelectElement;

      const toggleDropdown = (forceClose = false) => {
        if (!container || !trigger) return;
        const isOpen = container.getAttribute("data-open") === "true";
        if (isOpen || forceClose) {
          container.setAttribute("data-open", "false");
          trigger.setAttribute("aria-expanded", "false");
        } else {
          container.setAttribute("data-open", "true");
          trigger.setAttribute("aria-expanded", "true");
        }
      };

      const syncUI = (targetId: string) => {
        if (nativeSelect) {
          nativeSelect.value = targetId;
          nativeSelect.dispatchEvent(new Event("change", { bubbles: true }));
        }

        items.forEach((item) => {
          const isSelected = item.getAttribute("data-value") === targetId;
          item.classList.toggle("active", isSelected);
          item.setAttribute("aria-selected", String(isSelected));

          if (isSelected && triggerLabel) {
            triggerLabel.textContent = item.textContent || "";
          }
        });
      };

      const updatePlaylist = (newId: string) => {
        syncUI(newId);
        localStorage.setItem("an_music_last_playlist", newId);

        window.dispatchEvent(
          new CustomEvent("playlist-change", {
            detail: { id: newId },
          }),
        );
        toggleDropdown(true);
      };

      trigger?.addEventListener("click", (e) => {
        e.stopPropagation();
        toggleDropdown();
      });

      items.forEach((item) => {
        item.addEventListener("click", (e) => {
          e.stopPropagation();
          const id = item.getAttribute("data-value");
          if (id) updatePlaylist(id);
        });
      });

      const handleOutsideClick = (e: MouseEvent) => {
        if (container && !container.contains(e.target as Node)) {
          toggleDropdown(true);
        }
      };

      document.addEventListener("click", handleOutsideClick);

      const savedId = localStorage.getItem("an_music_last_playlist");
      const defaultId = (container as HTMLElement).dataset.default;
      const initialId = savedId || defaultId;

      if (initialId) {
        const availablePlaylists = JSON.parse(
          (container as HTMLElement).dataset.playlists || "[]",
        );
        if (availablePlaylists.some((p: any) => p.id === initialId)) {
          syncUI(initialId);
        }
      }
    });
  }

  initSelector();
  document.addEventListener("astro:after-swap", initSelector);
</script>

<style>
  .playlist-selector-container {
    display: inline-flex;
    align-items: center;
    flex-direction: row;
    width: fit-content;
    margin-bottom: 1rem;
  }

  .micro-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: #1e293b;
    background-color: rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 9999px;
    cursor: pointer;
    outline: none;
    transition:
      background-color 0.25s,
      color 0.25s,
      transform 0.25s;
    z-index: 2;
  }

  .micro-trigger:hover {
    background-color: rgba(0, 0, 0, 0.08);
    color: #0f172a;
  }

  .micro-trigger:active {
    transform: scale(0.93);
  }

  .trigger-label {
    max-width: 90px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .status-dot {
    width: 4px;
    height: 4px;
    background-color: #10b981;
    border-radius: 9999px;
  }

  .select-arrow {
    width: 0.85rem;
    height: 0.85rem;
    color: #475569;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .playlist-selector-container[data-open="true"] .select-arrow {
    transform: rotate(180deg);
  }

  .horizontal-tray {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    overflow: hidden;
    max-width: 0;
    opacity: 0;
    white-space: nowrap;
    pointer-events: none;
    transition:
      max-width 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.2s ease,
      margin-left 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .playlist-selector-container[data-open="true"] .horizontal-tray {
    max-width: 600px;
    opacity: 1;
    margin-left: 0.5rem;
    pointer-events: auto;
  }

  .tray-item {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: #334155;
    border: 1px solid rgba(0, 0, 0, 0.04);
    border-radius: 9999px;
    background-color: rgba(0, 0, 0, 0.02);
    cursor: pointer;
    transform: translateX(-12px);
    transition:
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.25s ease,
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .tray-item:hover {
    color: #0f172a;
    background-color: rgba(0, 0, 0, 0.06);
    border-color: rgba(0, 0, 0, 0.08);
  }

  .tray-item:active {
    transform: scale(0.92);
  }

  .tray-item.active {
    color: #ffffff;
    background-color: #0f172a;
    border-color: #0f172a;
  }

  .playlist-selector-container[data-open="true"] .tray-item {
    transform: translateX(0);
    opacity: 1;
  }

  .playlist-selector-container[data-open="true"] .tray-item:nth-child(1) {
    transition-delay: 0.02s;
  }
  .playlist-selector-container[data-open="true"] .tray-item:nth-child(2) {
    transition-delay: 0.06s;
  }
  .playlist-selector-container[data-open="true"] .tray-item:nth-child(3) {
    transition-delay: 0.1s;
  }
  .playlist-selector-container[data-open="true"] .tray-item:nth-child(4) {
    transition-delay: 0.14s;
  }
  .playlist-selector-container[data-open="true"] .tray-item:nth-child(5) {
    transition-delay: 0.18s;
  }
  .playlist-selector-container[data-open="true"] .tray-item:nth-child(6) {
    transition-delay: 0.22s;
  }

  @media (prefers-color-scheme: dark) {
    .micro-trigger {
      background-color: rgba(255, 255, 255, 0.05);
      border-color: rgba(255, 255, 255, 0.08);
      color: #cbd5e1;
    }
    .micro-trigger:hover {
      background-color: rgba(255, 255, 255, 0.08);
      color: #f1f5f9;
    }
    .select-arrow {
      color: #94a3b8;
    }
    .tray-item {
      color: #cbd5e1;
      background-color: rgba(255, 255, 255, 0.02);
      border-color: rgba(255, 255, 255, 0.04);
    }
    .tray-item:hover {
      color: #f1f5f9;
      background-color: rgba(255, 255, 255, 0.06);
      border-color: rgba(255, 255, 255, 0.1);
    }
    .tray-item.active {
      color: #0f172a;
      background-color: #f8fafc;
      border-color: #f8fafc;
    }
  }
</style>
