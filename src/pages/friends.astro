---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import PageHeader from "@components/PageHeader.astro";
import ArrowIcon from "@components/ArrowIcon.astro";
import Link from "@components/Link.astro";
import { FRIENDS_PAGE, FRIENDS, SITE } from "@consts";

const friends = FRIENDS.map((friend) => {
  const githubUsername = friend.GITHUB?.split("/").pop();

  return {
    ...friend,
    hostname: new URL(friend.HREF).hostname.replace(/^www\./, ""),
    githubUsername,
    initial: friend.NAME.slice(0, 1).toUpperCase(),
    avatar: githubUsername
      ? `https://github.com/${githubUsername}.png?size=128`
      : `https://ui-avatars.com/api/?name=${friend.NAME}&background=random&size=128`,
  };
});

const MY_GITHUB = "https://github.com/lonerOrz";
---

<Layout title={FRIENDS_PAGE.TITLE} description={FRIENDS_PAGE.DESCRIPTION}>
  <Container>
    <div class="mx-auto max-w-6xl space-y-16">
      <PageHeader
        title="Friends."
        subtitle="A small blogroll for people and websites I want to keep close."
      />

      <section
        class="animate grid gap-12 lg:grid-cols-[340px_1fr] lg:items-start"
      >
        <!-- Sidebar: Info & Stats -->
        <aside class="space-y-8 lg:sticky lg:top-28">
          <div class="space-y-4">
            <h2
              class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50"
            >
              Exchange Links
            </h2>
            <p
              class="text-[15px] leading-relaxed text-zinc-500 dark:text-zinc-400"
            >
              Welcome to my quiet corner. If you'd like to exchange links,
              please ensure your site is active and HTTPS-enabled.
            </p>
          </div>

          <!-- Stats Bento -->
          <div class="grid grid-cols-2 gap-3">
            <div
              class="rounded-2xl border border-zinc-200/60 bg-zinc-50/50 p-4 dark:border-zinc-800/60 dark:bg-zinc-900/40"
            >
              <span
                class="block font-mono text-[10px] tracking-[0.2em] text-zinc-400 uppercase"
                >Directory</span
              >
              <span
                class="mt-1 text-2xl font-bold text-zinc-900 dark:text-zinc-50"
                >{friends.length}</span
              >
            </div>
            <div
              class="rounded-2xl border border-zinc-200/60 bg-zinc-50/50 p-4 dark:border-zinc-800/60 dark:bg-zinc-900/40"
            >
              <span
                class="block font-mono text-[10px] tracking-[0.2em] text-zinc-400 uppercase"
                >Status</span
              >
              <div class="mt-2 flex items-center gap-1.5">
                <span class="relative flex h-2 w-2">
                  <span
                    class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"
                  ></span>
                  <span
                    class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"
                  ></span>
                </span>
                <span
                  class="text-[11px] font-bold text-emerald-600 uppercase dark:text-emerald-400"
                  >Open</span
                >
              </div>
            </div>
          </div>

          <!-- My Metadata Card -->
          <div
            class="group relative overflow-hidden rounded-[2rem] border border-zinc-200 bg-white p-6 shadow-sm transition-all hover:shadow-md dark:border-zinc-800 dark:bg-zinc-950"
          >
            <div
              class="flex items-center justify-between border-b border-zinc-100 pb-4 dark:border-zinc-900"
            >
              <h3
                class="text-xs font-bold tracking-widest text-zinc-900 uppercase dark:text-zinc-100"
              >
                My Info
              </h3>
              <button
                id="copy-info"
                class="inline-flex items-center gap-1 rounded-md bg-zinc-100 px-2 py-1 text-[10px] font-bold text-zinc-600 transition-all hover:bg-zinc-900 hover:text-white dark:bg-zinc-800 dark:text-zinc-400 dark:hover:bg-zinc-100 dark:hover:text-zinc-900"
              >
                COPY
              </button>
            </div>

            <div class="mt-5 space-y-4 font-mono">
              <div class="group/item flex flex-col gap-1">
                <span
                  class="text-[9px] font-bold tracking-tighter text-zinc-400 uppercase"
                  >Title</span
                >
                <span
                  class="text-xs font-medium text-zinc-800 dark:text-zinc-200"
                  >{SITE.TITLE}</span
                >
              </div>
              <div class="group/item flex flex-col gap-1">
                <span
                  class="text-[9px] font-bold tracking-tighter text-zinc-400 uppercase"
                  >URL</span
                >
                <span
                  class="text-xs font-medium break-all text-zinc-800 dark:text-zinc-200"
                  >{SITE.URL}</span
                >
              </div>
              <div class="group/item flex flex-col gap-1">
                <span
                  class="text-[9px] font-bold tracking-tighter text-zinc-400 uppercase"
                  >GitHub</span
                >
                <span
                  class="text-xs font-medium break-all text-zinc-800 dark:text-zinc-200"
                  >{MY_GITHUB}</span
                >
              </div>
              <div class="group/item flex flex-col gap-1">
                <span
                  class="text-[9px] font-bold tracking-tighter text-zinc-400 uppercase"
                  >Description</span
                >
                <span
                  class="text-xs leading-relaxed font-medium text-zinc-800 dark:text-zinc-200"
                  >{SITE.DESCRIPTION}</span
                >
              </div>
            </div>

            <Link
              href={`mailto:${SITE.EMAIL}`}
              underline={false}
              class="mt-6 flex w-full items-center justify-center gap-2 rounded-xl bg-zinc-900 py-3 text-xs font-bold text-white transition-all hover:opacity-90 active:scale-[0.98] dark:bg-zinc-100 dark:text-zinc-900"
            >
              <br />
              Contact Me
            </Link>
          </div>
        </aside>

        <!-- Main Content: Friends Grid -->
        <section>
          <ul class="grid gap-6 sm:grid-cols-2">
            {
              friends.map((friend, i) => (
                <li
                  class="stagger-item group"
                  style={{ "--delay": `${i * 60}ms` }}
                >
                  <div class="relative flex h-full flex-col overflow-hidden rounded-[2rem] border border-zinc-200 bg-white p-7 transition-all duration-500 hover:-translate-y-1 hover:border-zinc-300 hover:shadow-xl dark:border-zinc-800 dark:bg-zinc-900/40 dark:hover:border-zinc-700">
                    <div class="relative z-10 flex flex-1 flex-col">
                      {/* Top Info */}
                      <div class="flex items-start justify-between">
                        <div class="relative shrink-0">
                          <div class="absolute inset-0 scale-110 rounded-2xl bg-zinc-100 blur-md dark:bg-zinc-800" />
                          <img
                            src={friend.avatar}
                            alt={friend.NAME}
                            class="relative size-16 rounded-2xl object-cover shadow-sm transition-transform duration-500 group-hover:scale-105"
                          />
                        </div>

                        {friend.githubUsername && (
                          <a
                            href={`https://github.com/${friend.githubUsername}`}
                            target="_blank"
                            class="rounded-full bg-zinc-50 p-2.5 text-zinc-400 transition-all hover:bg-zinc-900 hover:text-white dark:bg-zinc-800 dark:hover:bg-zinc-100 dark:hover:text-zinc-900"
                            aria-label="GitHub Profile"
                          >
                            <svg
                              class="size-5"
                              fill="currentColor"
                              viewBox="0 0 24 24"
                            >
                              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                            </svg>
                          </a>
                        )}
                      </div>

                      {/* Content Info */}
                      <div class="mt-6 flex-1 space-y-2">
                        <h3 class="text-xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50">
                          {friend.NAME}
                        </h3>
                        <div class="inline-flex rounded-lg bg-blue-50 px-2 py-0.5 dark:bg-blue-900/30">
                          <span class="font-mono text-[10px] font-bold tracking-wider text-blue-600 uppercase dark:text-blue-400">
                            {friend.hostname}
                          </span>
                        </div>
                        <p class="mt-4 line-clamp-2 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
                          {friend.DESCRIPTION}
                        </p>
                      </div>

                      {/* Card Footer */}
                      <div class="mt-8 flex items-center justify-between border-t border-zinc-100 pt-5 dark:border-zinc-800">
                        <div class="flex items-center gap-1.5">
                          <span class="size-1.5 rounded-full bg-emerald-500/80 shadow-[0_0_8px_rgba(16,185,129,0.4)]" />
                          <span class="font-mono text-[10px] font-bold tracking-widest text-zinc-400 uppercase">
                            Online
                          </span>
                        </div>

                        <a
                          href={friend.HREF}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="group/link flex items-center gap-1 text-sm font-bold text-zinc-900 transition-colors hover:text-blue-500 dark:text-white dark:hover:text-blue-400"
                        >
                          Explore
                          <ArrowIcon
                            direction="right"
                            class="size-3.5 transition-transform group-hover/link:translate-x-1"
                          />
                        </a>
                      </div>
                    </div>
                  </div>
                </li>
              ))
            }
          </ul>
        </section>
      </section>
    </div>
  </Container>
</Layout>

<script is:inline define:vars={{ SITE, MY_GITHUB }}>
  document.getElementById("copy-info")?.addEventListener("click", function () {
    const text = `Title: ${SITE.TITLE}\nURL: ${SITE.URL}\nGitHub: ${MY_GITHUB}\nDescription: ${SITE.DESCRIPTION}`;

    navigator.clipboard.writeText(text).then(() => {
      const btn = this;
      const original = btn.innerHTML;
      btn.innerHTML = "DONE!";
      btn.classList.add("!bg-emerald-500", "!text-white");

      setTimeout(() => {
        btn.innerHTML = original;
        btn.classList.remove("!bg-emerald-500", "!text-white");
      }, 2000);
    });
  });
</script>

<style>
  .stagger-item {
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInSlide 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    animation-delay: var(--delay);
  }

  @keyframes fadeInSlide {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
