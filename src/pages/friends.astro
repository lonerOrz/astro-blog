---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import PageHeader from "@components/PageHeader.astro";
import ArrowIcon from "@components/ArrowIcon.astro";
import Link from "@components/Link.astro";
import { FRIENDS_PAGE, FRIENDS, SITE } from "@consts";

const friends = FRIENDS.map((friend) => ({
  ...friend,
  hostname: new URL(friend.HREF).hostname.replace(/^www\./, ""),
  initial: friend.NAME.slice(0, 1).toUpperCase(),
  favicon: `https://www.google.com/s2/favicons?domain=${encodeURIComponent(friend.HREF)}&sz=64`,
}));
---

<Layout title={FRIENDS_PAGE.TITLE} description={FRIENDS_PAGE.DESCRIPTION}>
  <Container>
    <div class="mx-auto max-w-6xl space-y-14">
      <PageHeader
        title="Friends."
        subtitle="A small blogroll for people and websites I want to keep close."
      />

      <section class="animate grid gap-10 lg:grid-cols-[300px_1fr] lg:items-start">
        <aside class="space-y-6 lg:sticky lg:top-28">
          <div class="space-y-4">
            <p class="text-3xl font-semibold leading-tight tracking-tight text-zinc-900 dark:text-zinc-50">
              A quiet corner for friends' sites.
            </p>
            <p class="text-base leading-relaxed text-zinc-500 dark:text-zinc-400">
              This page is for exchanging links with friends. The current
              entries are placeholders until more personal sites are added here.
            </p>
          </div>

          <div class="grid grid-cols-2 gap-2">
            <div class="rounded-xl border border-zinc-200 bg-white/70 p-3 dark:border-zinc-800 dark:bg-zinc-900/40">
              <p class="font-mono text-[10px] uppercase tracking-widest text-zinc-400 dark:text-zinc-500">
                sites
              </p>
              <p class="mt-1 text-xl font-semibold text-zinc-900 dark:text-zinc-50">
                {String(friends.length).padStart(2, "0")}
              </p>
            </div>
            <div class="rounded-xl border border-zinc-200 bg-white/70 p-3 dark:border-zinc-800 dark:bg-zinc-900/40">
              <p class="font-mono text-[10px] uppercase tracking-widest text-zinc-400 dark:text-zinc-500">
                status
              </p>
              <p class="mt-1 text-xl font-semibold text-zinc-900 dark:text-zinc-50">
                open
              </p>
            </div>
          </div>

          <div class="rounded-2xl border border-zinc-200 bg-zinc-50/70 p-4 dark:border-zinc-800 dark:bg-zinc-900/40">
            <p class="font-mono text-[11px] uppercase tracking-widest text-zinc-400 dark:text-zinc-500">
              Exchange Links?
            </p>
            <div class="mt-3 space-y-1.5 font-mono text-xs text-zinc-500 dark:text-zinc-400">
              <div>
                <span class="text-zinc-400 dark:text-zinc-500">title: </span>{SITE.TITLE}
              </div>
              <div>
                <span class="text-zinc-400 dark:text-zinc-500">description: </span>{SITE.DESCRIPTION}
              </div>
              <div>
                <span class="text-zinc-400 dark:text-zinc-500">url: </span>{SITE.URL}
              </div>
            </div>
            <p class="mt-4 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
              Send me your site title, description, and URL.
            </p>
            <Link
              href={`mailto:${SITE.EMAIL}`}
              underline={false}
              class="btn-interactive mt-4 inline-flex w-fit items-center rounded-md border border-zinc-200 bg-white px-3 py-2 text-sm text-zinc-600 transition-colors duration-150 hover:border-zinc-300 hover:bg-zinc-50 hover:text-zinc-900 dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-400 dark:hover:border-zinc-600 dark:hover:bg-zinc-800 dark:hover:text-zinc-50"
            >
              Send your site →
            </Link>
          </div>
        </aside>

        <section>
          <ul class="grid gap-2 sm:grid-cols-2 xl:grid-cols-3">
            {
              friends.map((friend, i) => (
                <li
                  class="stagger-item"
                  style={`--delay: ${80 + i * 35}ms`}
                >
                  <a
                    href={friend.HREF}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="not-prose group card-interactive flex min-h-32 flex-col justify-between rounded-2xl border border-zinc-200 bg-white/70 p-4 shadow-sm shadow-zinc-950/[0.03] dark:border-zinc-800 dark:bg-zinc-900/40 dark:shadow-black/10"
                  >
                    <div class="flex items-start justify-between gap-3">
                      <div class="flex min-w-0 items-center gap-3">
                        <div class="relative grid size-9 shrink-0 place-items-center rounded-xl border border-zinc-200 bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-950/40">
                          <img
                            src={friend.favicon}
                            alt=""
                            class="size-5 rounded-sm"
                            loading="lazy"
                            decoding="async"
                            onerror="this.style.display='none';this.nextElementSibling.style.display='grid';"
                          />
                          <span class="absolute inset-0 hidden place-items-center font-mono text-xs font-semibold text-zinc-500 dark:text-zinc-400">
                            {friend.initial}
                          </span>
                        </div>
                        <div class="min-w-0">
                          <p class="truncate text-sm font-semibold text-zinc-900 decoration-zinc-300 underline-offset-[3px] group-hover:underline dark:text-zinc-50 dark:decoration-zinc-600">
                            {friend.NAME}
                          </p>
                          <p class="truncate font-mono text-[10px] text-zinc-400 dark:text-zinc-500">
                            {friend.hostname}
                          </p>
                        </div>
                      </div>
                      <ArrowIcon
                        direction="right"
                        size={4}
                        class="mt-0.5 shrink-0 text-zinc-400 transition-colors duration-150 group-hover:text-zinc-900 dark:text-zinc-600 dark:group-hover:text-zinc-50"
                      />
                    </div>

                    <p class="mt-4 line-clamp-2 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
                      {friend.DESCRIPTION}
                    </p>

                    <div class="mt-4 flex items-center justify-between border-t border-zinc-100 pt-3 dark:border-zinc-800">
                      <span class="font-mono text-[10px] tabular-nums text-zinc-400 dark:text-zinc-600">
                        {String(i + 1).padStart(3, "0")}
                      </span>
                      <span class="font-mono text-[10px] text-zinc-300 transition-colors duration-150 group-hover:text-zinc-500 dark:text-zinc-700 dark:group-hover:text-zinc-500">
                        visit
                      </span>
                    </div>
                  </a>
                </li>
              ))
            }
          </ul>
        </section>
      </section>
    </div>
  </Container>
</Layout>
