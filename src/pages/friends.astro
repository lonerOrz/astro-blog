---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import PageHeader from "@components/PageHeader.astro";
import ArrowIcon from "@components/ArrowIcon.astro";
import Link from "@components/Link.astro";
import { FRIENDS_PAGE, FRIENDS, SITE } from "@consts";

const friends = FRIENDS.map((friend) => {
  const githubUsername = friend.GITHUB?.split("/").pop();

  return {
    ...friend,
    hostname: new URL(friend.HREF).hostname.replace(/^www\./, ""),
    githubUsername,
    initial: friend.NAME.slice(0, 1).toUpperCase(),
    avatar: githubUsername
      ? `https://github.com/${githubUsername}.png?size=120`
      : `https://ui-avatars.com/api/?name=${friend.NAME}&background=random&size=120`,
  };
});
---

<Layout title={FRIENDS_PAGE.TITLE} description={FRIENDS_PAGE.DESCRIPTION}>
  <Container>
    <div class="mx-auto max-w-6xl space-y-16">
      <PageHeader
        title="Friends."
        subtitle="A small blogroll for people and websites I want to keep close."
      />

      <section class="animate grid gap-12 lg:grid-cols-[340px_1fr] lg:items-start">
        <!-- Sidebar -->
        <aside class="space-y-10 lg:sticky lg:top-28">
          <!-- Intro -->
          <div class="space-y-4">
            <h2 class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50">
              Exchange Links
            </h2>
            <p class="text-[15px] leading-relaxed text-zinc-500 dark:text-zinc-400">
              If you have a personal blog or a creative space, I'd love to connect. Please make sure your site is active and HTTPS-enabled.
            </p>
          </div>

          <!-- Stats Block -->
          <div class="flex gap-4">
            <div class="flex-1 rounded-2xl border border-zinc-200/60 bg-zinc-50/50 p-4 dark:border-zinc-800/60 dark:bg-zinc-900/40">
              <span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-zinc-400">Directory</span>
              <span class="mt-1 text-2xl font-bold text-zinc-900 dark:text-zinc-50">{friends.length} <span class="text-xs font-normal text-zinc-400 uppercase">Sites</span></span>
            </div>
            <div class="flex-1 rounded-2xl border border-zinc-200/60 bg-zinc-50/50 p-4 dark:border-zinc-800/60 dark:bg-zinc-900/40">
              <span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-zinc-400">Status</span>
              <div class="mt-2 flex items-center gap-1.5">
                <span class="size-2 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]"></span>
                <span class="text-xs font-bold text-emerald-600 dark:text-emerald-400 uppercase">Accepting</span>
              </div>
            </div>
          </div>

          <!-- Enhanced Metadata Card -->
          <div class="group relative space-y-4 rounded-3xl border border-zinc-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md dark:border-zinc-800 dark:bg-zinc-950">
            <div class="flex items-center justify-between border-b border-zinc-100 pb-4 dark:border-zinc-900">
              <h3 class="text-sm font-bold text-zinc-900 dark:text-zinc-100">My Site Info</h3>
              <button
                id="copy-info"
                class="flex items-center gap-1.5 rounded-lg bg-zinc-100 px-3 py-1.5 text-[11px] font-bold text-zinc-600 transition-all hover:bg-zinc-900 hover:text-white dark:bg-zinc-800 dark:text-zinc-400 dark:hover:bg-zinc-100 dark:hover:text-zinc-900"
              >
                <svg class="size-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
                COPY
              </button>
            </div>

            <div id="site-metadata" class="space-y-5 py-2">
              <div class="group/item">
                <p class="font-mono text-[10px] font-bold uppercase tracking-widest text-zinc-400 transition-colors group-hover/item:text-blue-500">Title</p>
                <p class="mt-1 text-sm font-medium text-zinc-700 dark:text-zinc-300">{SITE.TITLE}</p>
              </div>

              <div class="group/item">
                <p class="font-mono text-[10px] font-bold uppercase tracking-widest text-zinc-400 transition-colors group-hover/item:text-blue-500">URL</p>
                <p class="mt-1 break-all text-sm font-medium text-zinc-700 dark:text-zinc-300">{SITE.URL}</p>
              </div>

              <div class="group/item">
                <p class="font-mono text-[10px] font-bold uppercase tracking-widest text-zinc-400 transition-colors group-hover/item:text-blue-500">Description</p>
                <p class="mt-1 text-sm leading-relaxed text-zinc-700 dark:text-zinc-300">{SITE.DESCRIPTION}</p>
              </div>
            </div>

            <Link
              href={`mailto:${SITE.EMAIL}`}
              underline={false}
              class="mt-4 flex w-full items-center justify-center gap-2 rounded-2xl bg-zinc-900 py-3 text-sm font-bold text-white transition-transform hover:scale-[1.02] active:scale-[0.98] dark:bg-zinc-100 dark:text-zinc-900"
            >
              Contact Me
            </Link>
          </div>
        </aside>

        <!-- Main Content: Friends Grid -->
        <section>
          <ul class="grid gap-6 sm:grid-cols-2">
            {
              friends.map((friend, i) => (
                <li class="stagger-item group" style={{ '--delay': `${i * 60}ms` }}>
                  <div class="relative flex h-full flex-col overflow-hidden rounded-[2rem] border border-zinc-200 bg-white p-7 transition-all duration-500 hover:-translate-y-1 hover:border-zinc-300 hover:shadow-xl dark:border-zinc-800 dark:bg-zinc-900/40 dark:hover:border-zinc-700">

                    <div class="relative z-10 flex flex-1 flex-col">
                      <div class="flex items-center justify-between">
                        <div class="relative shrink-0">
                          <div class="absolute inset-0 scale-110 rounded-2xl bg-zinc-100 blur-sm dark:bg-zinc-800" />
                          <img
                            src={friend.avatar}
                            alt={friend.NAME}
                            class="relative size-16 rounded-2xl object-cover shadow-sm transition-transform duration-500 group-hover:scale-105"
                          />
                        </div>

                        {friend.githubUsername && (
                          <a
                            href={`https://github.com/${friend.githubUsername}`}
                            target="_blank"
                            class="rounded-2xl bg-zinc-50 p-2.5 text-zinc-400 transition-colors hover:bg-zinc-900 hover:text-white dark:bg-zinc-800 dark:hover:bg-zinc-100 dark:hover:text-zinc-900"
                          >
                            <svg class="size-5" fill="currentColor" viewBox="0 0 24 24">
                              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                            </svg>
                          </a>
                        )}
                      </div>

                      <!-- Card Body -->
                      <div class="mt-5 flex-1">
                        <div class="flex items-baseline gap-2">
                          <h3 class="text-xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50">
                            {friend.NAME}
                          </h3>
                        </div>
                        <p class="mt-1 font-mono text-[11px] font-semibold uppercase tracking-widest text-blue-600/80 dark:text-blue-400/80">
                          {friend.hostname}
                        </p>
                        <p class="mt-4 line-clamp-2 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
                          {friend.DESCRIPTION}
                        </p>
                      </div>

                      <!-- Card Footer -->
                      <div class="mt-7 flex items-center justify-between border-t border-zinc-100 pt-5 dark:border-zinc-800">
                        <div class="flex items-center gap-1.5 font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-400">
                          <span class="size-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                          Active
                        </div>

                        <a
                          href={friend.HREF}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="group/link flex items-center gap-1 text-sm font-bold text-zinc-900 dark:text-white"
                        >
                          Explore
                          <ArrowIcon direction="right" class="size-3.5 transition-transform group-hover/link:translate-x-1" />
                        </a>
                      </div>
                    </div>
                  </div>
                </li>
              )
            )
          }
          </ul>
        </section>
      </section>
    </div>
  </Container>
</Layout>

<script is:inline>
  document.getElementById('copy-info')?.addEventListener('click', function() {
    const title = "{SITE.TITLE}";
    const url = "{SITE.URL}";
    const desc = "{SITE.DESCRIPTION}";
    const text = `Title: ${title}\nURL: ${url}\nDescription: ${desc}`;

    navigator.clipboard.writeText(text).then(() => {
      const btn = this;
      const original = btn.innerHTML;
      btn.innerHTML = 'DONE!';
      btn.classList.add('!bg-emerald-500', '!text-white');
      setTimeout(() => {
        btn.innerHTML = original;
        btn.classList.remove('!bg-emerald-500', '!text-white');
      }, 2000);
    });
  });
</script>

<style>
  .stagger-item {
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInSlide 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    animation-delay: var(--delay);
  }

  @keyframes fadeInSlide {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
