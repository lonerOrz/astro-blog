---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { FRIENDS, SITE } from "@consts";

const friends = [
  {
    NAME: "Astro",
    HREF: "https://astro.build",
    DESCRIPTION: "The web framework for content-driven websites.",
    ICON: "🚀",
  },
  {
    NAME: "Tailwind CSS",
    HREF: "https://tailwindcss.com",
    DESCRIPTION: "A utility-first CSS framework.",
    ICON: "🎨",
  },
  {
    NAME: "LonerOrz",
    HREF: "https://github.com/lonerOrz",
    DESCRIPTION: "The creator of this space.",
    ICON: "👾",
  },
];
---

<Layout title={FRIENDS.TITLE} description={FRIENDS.DESCRIPTION}>
  <Container>
    <div class="space-y-16">
      <!-- Header Section -->
      <section class="animate">
        <h1 class="text-3xl font-bold text-black dark:text-white">
          🤝 Friends
        </h1>
        <p class="mt-4 text-neutral-600 dark:text-neutral-400">
          Awesome people and projects that inspire me.
        </p>
      </section>

      <!-- Friends Grid -->
      <section class="animate">
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          {
            friends.map((friend) => (
              <a
                href={friend.HREF}
                target="_blank"
                class="group flex items-start gap-4 rounded-xl border border-black/10 p-4 transition-all duration-300 hover:bg-black/5 hover:shadow-md dark:border-white/10 dark:hover:bg-white/5"
              >
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-neutral-100 text-2xl dark:bg-neutral-800">
                  {friend.ICON}
                </div>
                <div class="flex-1 overflow-hidden">
                  <div class="truncate font-semibold text-black transition-colors group-hover:text-blue-500 dark:text-white">
                    {friend.NAME}
                  </div>
                  <div class="mt-1 line-clamp-2 text-sm text-neutral-500">
                    {friend.DESCRIPTION}
                  </div>
                </div>
              </a>
            ))
          }
        </div>
      </section>

      <!-- Exchange Section -->
      <section
        class="animate rounded-xl border border-blue-500/10 bg-blue-500/5 p-6"
      >
        <h2 class="mb-4 text-xl font-semibold text-black dark:text-white">
          Exchange Links?
        </h2>
        <p class="mb-6 text-sm text-neutral-600 dark:text-neutral-400">
          If you'd like to be added here, feel free to reach out with your site
          details!
        </p>
        <div
          class="space-y-2 rounded-lg border border-black/5 bg-white/50 p-4 font-mono text-xs text-black dark:border-white/5 dark:bg-black/50 dark:text-white"
        >
          <p><span class="text-blue-500">Title:</span> {SITE.TITLE}</p>
          <p>
            <span class="text-blue-500">Description:</span>
            {SITE.DESCRIPTION}
          </p>
          <p>
            <span class="text-blue-500">URL:</span> https://astro-blog-rosy.vercel.app
          </p>
        </div>
      </section>
    </div>
  </Container>
</Layout>
