---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { FRIENDS, SITE } from "@consts";

const friends = [
  {
    NAME: "Astro",
    HREF: "https://astro.build",
    DESCRIPTION: "The web framework for content-driven websites.",
  },
  {
    NAME: "Tailwind CSS",
    HREF: "https://tailwindcss.com",
    DESCRIPTION: "A utility-first CSS framework.",
  },
  {
    NAME: "LonerOrz",
    HREF: "https://github.com/lonerOrz",
    DESCRIPTION: "The creator of this space.",
  },
];
---

<Layout title={FRIENDS.TITLE} description={FRIENDS.DESCRIPTION}>
  <Container>
    <div class="space-y-10">

      <!-- Page header -->
      <section class="animate space-y-1.5">
        <h1 class="text-3xl font-semibold text-black dark:text-white">
          Friends.
        </h1>
        <p class="font-mono text-xs text-black/40 dark:text-white/40">
          Awesome people and projects that inspire me.
        </p>
      </section>

      <!-- Friends list – editorial numbered style -->
      <section class="animate border-t border-black/10 dark:border-white/10">
        {
          friends.map((friend, i) => (
            <a
              href={friend.HREF}
              target="_blank"
              rel="noopener noreferrer"
              class="not-prose group card-interactive block py-5 border-b border-black/10 dark:border-white/10"
            >
              <div class="flex items-center gap-2 mb-2.5">
                <span class="font-mono text-[11px] tabular-nums text-black/25 dark:text-white/25 select-none">
                  {String(i + 1).padStart(3, "0")}
                </span>
              </div>
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <div class="font-medium text-black dark:text-white text-[15px] leading-snug mb-1.5 group-hover:underline decoration-black/30 dark:decoration-white/30 underline-offset-[3px]">
                    {friend.NAME}
                  </div>
                  <div class="text-sm text-black/55 dark:text-white/55 leading-relaxed">
                    {friend.DESCRIPTION}
                  </div>
                </div>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  class="mt-0.5 shrink-0 size-4 fill-none stroke-current stroke-2 text-black/25 dark:text-white/25 transition-colors duration-150 group-hover:text-black dark:group-hover:text-white"
                >
                  <line
                    x1="5"
                    y1="12"
                    x2="19"
                    y2="12"
                    class="translate-x-3 scale-x-0 transition-transform duration-200 ease-emphasis group-hover:translate-x-0 group-hover:scale-x-100"
                  />
                  <polyline
                    points="12 5 19 12 12 19"
                    class="-translate-x-1 transition-transform duration-200 ease-emphasis group-hover:translate-x-0"
                  />
                </svg>
              </div>
            </a>
          ))
        }
      </section>

      <!-- Exchange info – minimal monospace block -->
      <section class="animate space-y-3">
        <p class="font-mono text-[11px] text-black/35 dark:text-white/35 uppercase tracking-widest">
          Exchange Links?
        </p>
        <div
          class="font-mono text-xs text-black/50 dark:text-white/50 space-y-1.5 border-l-2 border-black/10 dark:border-white/10 pl-4"
        >
          <div>
            <span class="text-black/30 dark:text-white/30">title: </span>{
              SITE.TITLE
            }
          </div>
          <div>
            <span class="text-black/30 dark:text-white/30">description: </span>{
              SITE.DESCRIPTION
            }
          </div>
          <div>
            <span class="text-black/30 dark:text-white/30">url: </span>https://astro-blog-rosy.vercel.app
          </div>
          <div class="pt-1 text-black/35 dark:text-white/35">
            Reach out if you'd like to be added here.
          </div>
        </div>
      </section>

    </div>
  </Container>
</Layout>
