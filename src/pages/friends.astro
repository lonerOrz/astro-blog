---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import PageHeader from "@components/PageHeader.astro";
import ArrowIcon from "@components/ArrowIcon.astro";
import { FRIENDS_PAGE, FRIENDS, SITE } from "@consts";
---

<Layout title={FRIENDS_PAGE.TITLE} description={FRIENDS_PAGE.DESCRIPTION}>
  <Container>
    <div class="space-y-10">

      <PageHeader
        title="Friends."
        subtitle="Awesome people and projects that inspire me."
      />

      <section class="animate border-t border-zinc-200 dark:border-zinc-800">
        {
          FRIENDS.map((friend, i) => (
            <a
              href={friend.HREF}
              target="_blank"
              rel="noopener noreferrer"
              class="not-prose group card-interactive block py-5 border-b border-zinc-200 dark:border-zinc-800"
            >
              <div class="flex items-center gap-2 mb-2.5">
                <span class="font-mono text-[11px] tabular-nums text-zinc-400 dark:text-zinc-600 select-none">
                  {String(i + 1).padStart(3, "0")}
                </span>
              </div>
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1 min-w-0">
                  <div class="font-medium text-zinc-900 dark:text-zinc-50 text-[15px] leading-snug mb-1.5 group-hover:underline decoration-zinc-300 dark:decoration-zinc-600 underline-offset-[3px]">
                    {friend.NAME}
                  </div>
                  <div class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">
                    {friend.DESCRIPTION}
                  </div>
                </div>
                <ArrowIcon
                  direction="right"
                  size={4}
                  class="mt-0.5 shrink-0 text-zinc-400 dark:text-zinc-600 transition-colors duration-150 group-hover:text-zinc-900 dark:group-hover:text-zinc-50"
                />
              </div>
            </a>
          ))
        }
      </section>

      <section class="animate space-y-3">
        <p class="font-mono text-[11px] text-zinc-400 dark:text-zinc-500 uppercase tracking-widest">
          Exchange Links?
        </p>
        <div
          class="font-mono text-xs text-zinc-500 dark:text-zinc-400 space-y-1.5 border-l-2 border-zinc-200 dark:border-zinc-800 pl-4"
        >
          <div>
            <span class="text-zinc-400 dark:text-zinc-500">title: </span>{SITE.TITLE}
          </div>
          <div>
            <span class="text-zinc-400 dark:text-zinc-500">description: </span>{SITE.DESCRIPTION}
          </div>
          <div>
            <span class="text-zinc-400 dark:text-zinc-500">url: </span>{SITE.URL}
          </div>
          <div class="pt-1 text-zinc-400 dark:text-zinc-500">
            Reach out if you'd like to be added here.
          </div>
        </div>
      </section>

    </div>
  </Container>
</Layout>
