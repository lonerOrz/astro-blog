---
import { getCollection, render } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import PageHeader from "@components/PageHeader.astro";
import FormattedDate from "@components/FormattedDate.astro";
import BackToPrevious from "@components/BackToPrevious.astro";

export async function getStaticPaths() {
  const allEntries = await getCollection("series");

  const allPosts = allEntries.filter(
    (post) => post.id.includes("/"),
  );
  const seriesSet = new Set(allPosts.map((p) => p.id.split("/")[0]));
  return Array.from(seriesSet).map((series) => ({
    params: { series },
    props: { series },
  }));
}

type Props = {
  series: string;
};

const { series } = Astro.props;

const allEntries = await getCollection("series");

// Series metadata from index file
const seriesMeta = allEntries.find((p) => {
  const name = p.id.split("/")[0].replace(/\.(md|mdx)$/, "");
  const isIndex = !p.id.includes("/") || p.id.endsWith("/index.md") || p.id.endsWith("/index.mdx");
  return name === series && isIndex;
});
const { Content: SeriesIntro } = seriesMeta
  ? await render(seriesMeta)
  : { Content: undefined };

// Articles (exclude index files)
const allPosts = allEntries
  .filter(
    (post) =>
      !post.data.draft &&
      post.id.startsWith(series + "/") &&
      !post.id.endsWith("/index.md") &&
      !post.id.endsWith("/index.mdx"),
  )
  .sort((a, b) => {
    const aOrder = a.data.seriesOrder ?? Infinity;
    const bOrder = b.data.seriesOrder ?? Infinity;
    if (aOrder !== bOrder) return aOrder - bOrder;
    return b.data.date.valueOf() - a.data.date.valueOf();
  });

const pageTitle = seriesMeta?.data.title ?? series;
const pageDescription =
  seriesMeta?.data.description ??
  `${allPosts.length} articles in ${series} series`;
const pageSubtitle = `${allPosts.length} ${allPosts.length === 1 ? "article" : "articles"}`;
---

<Layout title={pageTitle} description={pageDescription}>
  <Container>
    <div class="animate">
      <BackToPrevious href="/series">Back to series</BackToPrevious>
    </div>

    <div class="animate my-10">
      <PageHeader title={pageTitle} subtitle={pageSubtitle} />
    </div>

    {
      SeriesIntro && (
        <div class="animate prose prose-zinc dark:prose-invert mb-12 max-w-none text-sm text-zinc-600 dark:text-zinc-400 [&>:first-child]:mt-0">
          <SeriesIntro />
        </div>
      )
    }

    <ul class="animate not-prose flex flex-col gap-2">
      {
        allPosts.map((post, i) => (
          <li
            class="stagger-item"
            style={`--delay: ${150 + i * 60}ms`}
          >
            <a
              href={`/series/${series}/${post.id.split("/").slice(1).join("/").replace(/\.(md|mdx)$/, "")}`}
              class="group flex items-center gap-4 rounded-xl px-3 py-3.5 transition-all duration-200 active:scale-[0.99] hover:bg-zinc-50 dark:hover:bg-zinc-900/40"
            >
              <span class="relative flex h-4 w-4 items-center justify-center font-mono text-xs text-zinc-300 dark:text-zinc-700">
                <span class="transition-all duration-300 group-hover:scale-0 group-hover:opacity-0">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="absolute h-3.5 w-3.5 scale-0 opacity-0 text-emerald-500 transition-all duration-300 group-hover:scale-100 group-hover:opacity-100 dark:text-emerald-400">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </span>

              <span class="flex-1 truncate text-sm font-medium text-zinc-800 transition-colors group-hover:text-zinc-900 dark:text-zinc-300 dark:group-hover:text-zinc-50">
                {post.data.title}
              </span>

              <div class="hidden shrink-0 items-center gap-2 sm:flex">
                {post.data.description && (
                  <span class="max-w-[200px] truncate text-right text-[11px] text-zinc-400 dark:text-zinc-500">
                    {post.data.description}
                  </span>
                )}
                <time class="shrink-0 font-mono text-[11px] text-zinc-400 transition-transform duration-300 group-hover:-translate-x-1 dark:text-zinc-500">
                  <FormattedDate date={post.data.date} />
                </time>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </Container>
</Layout>
