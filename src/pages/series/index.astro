---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import PageHeader from "@components/PageHeader.astro";
import { SERIES } from "@consts";

type SeriesGroup = {
  series: string;
  posts: typeof allSeries;
  latestDate: Date;
  meta: (typeof allSeries)[0] | undefined;
};

const allSeries = (await getCollection("series")).filter(
  (post) => !post.data.draft,
);

// Load index entries for series metadata
const indexEntries = new Map(
  allSeries
    .filter((p) => !p.id.includes("/") || p.id.endsWith("/index.md") || p.id.endsWith("/index.mdx"))
    .map((p) => {
      const name = p.id.split("/")[0].replace(/\.(md|mdx)$/, "");
      return [name, p];
    }),
);

// Articles only (exclude index files)
const seriesPosts = allSeries.filter(
  (p) => p.id.includes("/") && !p.id.endsWith("/index.md") && !p.id.endsWith("/index.mdx"),
);

// Group by series folder name (first segment of id)
const seriesMap = new Map<string, typeof seriesPosts>();
for (const post of seriesPosts) {
  const seriesName = post.id.split("/")[0];
  const existing = seriesMap.get(seriesName) || [];
  existing.push(post);
  seriesMap.set(seriesName, existing);
}

const seriesList: SeriesGroup[] = Array.from(seriesMap.entries())
  .map(([series, posts]) => ({
    series,
    posts,
    latestDate: posts.reduce(
      (latest, p) => (p.data.date > latest ? p.data.date : latest),
      posts[0].data.date,
    ),
    meta: indexEntries.get(series),
  }))
  .sort((a, b) => b.latestDate.valueOf() - a.latestDate.valueOf());
---

<Layout title={SERIES.TITLE} description={SERIES.DESCRIPTION}>
  <Container>
    <aside data-pagefind-ignore>
      <div class="space-y-10">
        <PageHeader
          title="Series."
          subtitle={`${seriesList.length} series`}
        />

        <ul class="animate not-prose flex flex-col gap-4">
          {
            seriesList.map((group, i) => (
              <li
                class="stagger-item"
                style={`--delay: ${150 + i * 60}ms`}
              >
                <a
                  href={`/series/${group.series}`}
                  class="not-prose group relative flex flex-nowrap rounded-lg border border-zinc-200 px-4 py-3 pr-10 card-interactive hover:bg-zinc-50 hover:text-zinc-900 focus-visible:bg-zinc-50 focus-visible:text-zinc-900 dark:border-zinc-700 dark:hover:bg-zinc-800/50 dark:hover:text-zinc-50 dark:focus-visible:bg-zinc-800/50 dark:focus-visible:text-zinc-50"
                >
                  <div class="flex flex-1 flex-col truncate">
                    <div class="font-semibold">
                      {group.meta?.data.title ?? group.series}
                    </div>
                    <div class="text-sm text-zinc-500 dark:text-zinc-400">
                      {group.meta?.data.description
                        ? group.meta.data.description
                        : `${group.posts.length} ${group.posts.length === 1 ? "article" : "articles"}`}
                    </div>
                  </div>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="absolute top-1/2 right-2 -translate-y-1/2 text-zinc-400 dark:text-zinc-500"
                  >
                    <path d="M9 18l6-6-6-6" />
                  </svg>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </aside>
  </Container>
</Layout>
