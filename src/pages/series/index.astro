---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content"; // 导入类型
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import PageHeader from "@components/PageHeader.astro";
import { SERIES } from "@consts";

type SeriesPost = CollectionEntry<"series">;

const allSeries = (await getCollection("series")).filter((p) => !p.data.draft);

const indexEntries = new Map<string, SeriesPost>(
  allSeries
    .filter(
      (p) =>
        !p.id.includes("/") ||
        p.id.endsWith("/index.md") ||
        p.id.endsWith("/index.mdx"),
    )
    .map((p) => [p.id.split("/")[0].replace(/\.(md|mdx)$/, ""), p]),
);

const seriesPosts = allSeries.filter(
  (p) =>
    p.id.includes("/") &&
    !p.id.endsWith("/index.md") &&
    !p.id.endsWith("/index.mdx"),
);

const seriesMap = new Map<string, SeriesPost[]>();
seriesPosts.forEach((post) => {
  const name = post.id.split("/")[0];
  const existing = seriesMap.get(name) || [];
  existing.push(post);
  seriesMap.set(name, existing);
});

const seriesList = Array.from(seriesMap.entries())
  .map(([series, posts]) => ({
    series,
    posts,
    latestDate: posts.reduce(
      (latest: Date, p: SeriesPost) =>
        p.data.date > latest ? p.data.date : latest,
      posts[0].data.date,
    ),
    meta: indexEntries.get(series),
  }))
  .sort((a, b) => b.latestDate.valueOf() - a.latestDate.valueOf());
---

<Layout
  title={SERIES.TITLE}
  description={SERIES.DESCRIPTION || "Browse curated article series."}
>
  <!-- 背景网格 -->
  <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] bg-[size:40px_40px]"
    >
    </div>
    <div
      class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-[0.02] contrast-125 dark:opacity-[0.03]"
    >
    </div>
  </div>

  <Container>
    <div class="space-y-12 pb-24">
      <PageHeader
        title="Series."
        subtitle="Curated collections of technical deep-dives."
      />

      <section class="animate grid gap-6 sm:grid-cols-2">
        {
          seriesList.map((group, i) => (
            <div class="stagger-item group" style={`--delay: ${i * 0.1}s`}>
              <a
                href={`/series/${group.series}`}
                class="relative flex h-full flex-col justify-between overflow-hidden rounded-[2.5rem] border border-zinc-200 bg-white p-8 transition-all duration-500 hover:-translate-y-1 hover:border-zinc-300 hover:shadow-xl dark:border-zinc-800 dark:bg-zinc-900/40 dark:hover:border-zinc-700"
              >
                <div class="space-y-5">
                  <div class="flex items-start justify-between">
                    {/* 文件夹图标 */}
                    <div class="flex size-12 items-center justify-center rounded-2xl bg-zinc-50 shadow-inner transition-colors group-hover:bg-zinc-900 group-hover:text-white dark:bg-zinc-950 dark:group-hover:bg-white dark:group-hover:text-zinc-900">
                      <svg
                        class="size-6"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
                      </svg>
                    </div>
                    {/* 篇数徽章 */}
                    <div class="rounded-full border border-zinc-200 bg-zinc-100 px-3 py-1 transition-colors group-hover:border-blue-500 group-hover:bg-blue-600 group-hover:text-white dark:border-zinc-700 dark:bg-zinc-800">
                      <span class="font-mono text-[10px] font-black tracking-widest uppercase">
                        {group.posts.length}{" "}
                        {group.posts.length === 1 ? "PART" : "PARTS"}
                      </span>
                    </div>
                  </div>

                  <div>
                    <h3 class="text-xl font-bold tracking-tight text-zinc-900 uppercase italic transition-colors group-hover:text-blue-600 dark:text-zinc-50 dark:group-hover:text-blue-400">
                      {group.meta?.data.title ?? group.series}
                    </h3>
                    <p class="mt-3 line-clamp-2 text-sm leading-relaxed font-medium text-zinc-500 dark:text-zinc-400">
                      {group.meta?.data.description ??
                        "Access the full collection of technical logs and architectural documentation."}
                    </p>
                  </div>
                </div>

                {/* 卡片底部元数据 */}
                <div class="mt-10 flex items-center justify-between border-t border-zinc-50 pt-6 dark:border-zinc-800/60">
                  <div class="flex flex-col gap-0.5">
                    <span class="text-[9px] font-black tracking-tighter text-zinc-400 uppercase">
                      Archived Date
                    </span>
                    <time class="font-mono text-[11px] font-bold text-zinc-600 dark:text-zinc-400">
                      {group.latestDate
                        .toLocaleDateString("en-US", {
                          year: "numeric",
                          month: "short",
                          day: "numeric",
                        })
                        .toUpperCase()}
                    </time>
                  </div>
                  {/* 交互引导 */}
                  <div class="flex translate-x-2 items-center gap-1.5 text-[10px] font-black tracking-widest text-zinc-300 uppercase opacity-0 transition-all group-hover:translate-x-0 group-hover:text-zinc-900 group-hover:opacity-100 dark:group-hover:text-white">
                    Enter Archive
                  </div>
                </div>
              </a>
            </div>
          ))
        }
      </section>
    </div>
  </Container>
</Layout>

<style is:global>
  .stagger-item {
    opacity: 0;
    transform: translateY(16px);
    animation: slideInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0s);
  }

  @keyframes slideInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
