---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import PageHeader from "@components/PageHeader.astro";
import { SERIES } from "@consts";

const allSeries = (await getCollection("series")).filter((p) => !p.data.draft);

const indexEntries = new Map(
  allSeries
    .filter(
      (p) =>
        !p.id.includes("/") ||
        p.id.endsWith("/index.md") ||
        p.id.endsWith("/index.mdx"),
    )
    .map((p) => [p.id.split("/")[0].replace(/\.(md|mdx)$/, ""), p]),
);

const seriesPosts = allSeries.filter(
  (p) =>
    p.id.includes("/") &&
    !p.id.endsWith("/index.md") &&
    !p.id.endsWith("/index.mdx"),
);

const seriesMap = new Map();
seriesPosts.forEach((post) => {
  const name = post.id.split("/")[0];
  const existing = seriesMap.get(name) || [];
  existing.push(post);
  seriesMap.set(name, existing);
});

const seriesList = Array.from(seriesMap.entries())
  .map(([series, posts]) => ({
    series,
    posts,
    latestDate: posts.reduce(
      (latest, p) => (p.data.date > latest ? p.data.date : latest),
      posts[0].data.date,
    ),
    meta: indexEntries.get(series),
  }))
  .sort((a, b) => b.latestDate.valueOf() - a.latestDate.valueOf());
---

<Layout title={SERIES.TITLE} description={SERIES.DESCRIPTION}>
  <!-- 统一背景 -->
  <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] bg-[size:40px_40px]"
    >
    </div>
    <div
      class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-[0.02] contrast-125 dark:opacity-[0.03]"
    >
    </div>
  </div>

  <Container>
    <div class="space-y-12 pb-24">
      <PageHeader
        title="Series."
        subtitle="Curated collections of thoughts and technical deep-dives."
      />

      <section class="animate grid gap-6 sm:grid-cols-2">
        {
          seriesList.map((group, i) => (
            <div class="stagger-item group" style={`--delay: ${i * 0.1}s`}>
              <a
                href={`/series/${group.series}`}
                class="relative flex h-full flex-col justify-between overflow-hidden rounded-[2rem] border border-zinc-200 bg-white p-7 transition-all duration-500 hover:-translate-y-1 hover:border-zinc-300 hover:shadow-xl dark:border-zinc-800 dark:bg-zinc-900/40 dark:hover:border-zinc-700"
              >
                <div class="space-y-4">
                  <div class="flex items-start justify-between">
                    <div class="flex size-12 items-center justify-center rounded-2xl bg-zinc-50 transition-colors group-hover:bg-zinc-900 group-hover:text-white dark:bg-zinc-950 dark:group-hover:bg-white dark:group-hover:text-zinc-900">
                      <svg
                        class="size-6"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
                      </svg>
                    </div>
                    <span class="font-mono text-[10px] font-bold tracking-widest text-zinc-400 uppercase">
                      {group.posts.length}{" "}
                      {group.posts.length === 1 ? "PART" : "PARTS"}
                    </span>
                  </div>

                  <div>
                    <h3 class="text-xl font-bold tracking-tight text-zinc-900 transition-colors group-hover:text-blue-600 dark:text-zinc-50 dark:group-hover:text-blue-400">
                      {group.meta?.data.title ?? group.series}
                    </h3>
                    <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
                      {group.meta?.data.description ??
                        "Explore this collection of related articles and documentation."}
                    </p>
                  </div>
                </div>

                <div class="mt-8 flex items-center justify-between border-t border-zinc-50 pt-5 dark:border-zinc-800/50">
                  <div class="flex flex-col">
                    <span class="text-[9px] font-bold tracking-tighter text-zinc-400 uppercase">
                      Last updated
                    </span>
                    <time class="font-mono text-[10px] text-zinc-500 dark:text-zinc-400">
                      {group.latestDate.toLocaleDateString("zh-CN", {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                      })}
                    </time>
                  </div>
                  <div class="flex translate-x-2 items-center gap-1 text-[10px] font-black tracking-widest text-zinc-900 uppercase opacity-0 transition-all group-hover:translate-x-0 group-hover:opacity-100 dark:text-white">
                    Open Archive
                  </div>
                </div>
              </a>
            </div>
          ))
        }
      </section>
    </div>
  </Container>
</Layout>

<style>
  .stagger-item {
    opacity: 0;
    transform: translateY(20px);
    animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay);
  }
  @keyframes slideUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
