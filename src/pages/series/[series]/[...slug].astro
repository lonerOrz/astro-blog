---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { readingTime } from "@lib/utils";
import BackToPrevious from "@components/BackToPrevious.astro";
import TableOfContents from "@components/TableOfContents.astro";
import SeriesNavigation from "@components/SeriesNavigation.astro";
import MarkdownImage from "@components/MarkdownImage.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("series");
  const filteredPosts = allPosts.filter(
    (post) =>
      !post.data.draft &&
      post.id.includes("/") &&
      !post.id.endsWith("/index.md") &&
      !post.id.endsWith("/index.mdx"),
  );

  const seriesGroups = new Map<string, typeof filteredPosts>();
  for (const post of filteredPosts) {
    const series = post.id.split("/")[0];
    const group = seriesGroups.get(series) || [];
    group.push(post);
    seriesGroups.set(series, group);
  }

  return Array.from(seriesGroups.entries()).flatMap(([series, posts]) => {
    const sortedPosts = posts.sort((a, b) => {
      const aOrder = a.data.seriesOrder ?? Infinity;
      const bOrder = b.data.seriesOrder ?? Infinity;
      if (aOrder !== bOrder) return aOrder - bOrder;
      return b.data.date.valueOf() - a.data.date.valueOf();
    });

    return sortedPosts.map((post, index) => {
      const slug = post.id
        .split("/")
        .slice(1)
        .join("/")
        .replace(/\.(md|mdx)$/, "");
      return {
        params: { series, slug },
        props: {
          post,
          prevPost: index > 0 ? sortedPosts[index - 1] : null,
          nextPost:
            index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null,
        },
      };
    });
  });
}

type Props = {
  post: CollectionEntry<"series">;
  prevPost: CollectionEntry<"series"> | null;
  nextPost: CollectionEntry<"series"> | null;
};

const { post, prevPost, nextPost } = Astro.props;
const seriesName = post.id.split("/")[0];
const { Content, headings } = await render(post);
---

<Layout
  title={post.data.title}
  description={post.data.description ||
    `Reading ${post.data.title} in ${seriesName}`}
>
  <div
    id="read-progress"
    class="fixed top-0 left-0 z-[100] h-[2px] w-0 bg-zinc-900 transition-all duration-150 [transition-timing-function:cubic-bezier(0.23,1,0.32,1)] dark:bg-white"
  >
  </div>

  <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
    <div
      class="absolute inset-0 bg-zinc-50 transition-colors duration-500 dark:bg-zinc-950"
    >
    </div>
    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] bg-[size:40px_40px]"
    >
    </div>
  </div>

  <Container>
    <div class="animate mt-8">
      <BackToPrevious href={`/series/${seriesName}`}>
        Back to <span class="font-bold tracking-tight uppercase"
          >{seriesName}</span
        >
      </BackToPrevious>
    </div>

    <div class="animate mt-12 mb-10 space-y-4">
      <div
        class="flex items-center gap-2 text-sm font-medium text-zinc-500 dark:text-zinc-400"
      >
        <a
          href={`/series/${seriesName}`}
          class="transition-colors hover:text-zinc-900 dark:hover:text-zinc-100"
        >
          {seriesName}
        </a>
        <span class="text-zinc-300 dark:text-zinc-700">·</span>
        <FormattedDate date={post.data.date} />
        <span class="opacity-40">&bull;</span>
        {post.body && <span>{readingTime(post.body)}</span>}
      </div>

      <h1
        class="text-3xl leading-tight font-bold tracking-tight text-zinc-900 md:text-4xl dark:text-zinc-50"
      >
        {post.data.title}
      </h1>
    </div>

    {
      headings && headings.length > 0 && (
        <div class="animate mb-12">
          <TableOfContents headings={headings} />
        </div>
      )
    }

    <article class="animate min-w-0">
      <div
        class="prose prose-neutral prose-lg dark:prose-invert prose-p:leading-relaxed prose-p:text-zinc-700 dark:prose-p:text-zinc-300 prose-headings:text-zinc-900 dark:prose-headings:text-zinc-50 prose-a:text-blue-600 dark:prose-a:text-blue-400 max-w-none pb-24"
      >
        <Content components={{ img: MarkdownImage }} />
      </div>

      <footer class="mt-16 border-t border-zinc-100 pt-12 dark:border-zinc-800">
        {
          (prevPost || nextPost) && (
            <SeriesNavigation
              prevSeriesEntry={prevPost}
              nextSeriesEntry={nextPost}
            />
          )
        }
      </footer>
    </article>
  </Container>
</Layout>

<script is:inline>
  function initProgress() {
    const bar = document.getElementById("read-progress");
    if (!bar) return;

    const update = () => {
      const scrollY = window.scrollY;
      const height = document.documentElement.scrollHeight - window.innerHeight;
      if (height <= 0) return;
      bar.style.width = (scrollY / height) * 100 + "%";
    };

    window.addEventListener("scroll", update, { passive: true });
    update();

    document.addEventListener(
      "astro:before-swap",
      () => {
        window.removeEventListener("scroll", update);
      },
      { once: true },
    );
  }

  initProgress();
  document.addEventListener("astro:after-swap", initProgress);
</script>

<style is:global>
  .animate {
    opacity: 0;
    transform: translateY(10px);
    animation: fadeIn 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes fadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  :global(.dark) #read-progress {
    box-shadow: 0 0 10px rgba(255, 255, 255, 0.1);
  }
</style>
