---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import PageHeader from "@components/PageHeader.astro";
import BangumiCard from "@components/BangumiCard.astro";
import { getBilibiliBangumi } from "@lib/bilibili";

const vmid = "439989352";

const [watching, watched, want] = await Promise.all([
  getBilibiliBangumi(vmid, 2),
  getBilibiliBangumi(vmid, 3),
  getBilibiliBangumi(vmid, 1),
]);

const groups = [
  { label: "Watching", data: watching, id: "watching" },
  { label: "Completed", data: watched, id: "watched" },
  { label: "Plan to Watch", data: want, id: "want" },
];
---

<Layout
  title="Bangumi - Anime Collection"
  description="My personal anime collection from Bilibili."
>
  <Container>
    <div class="mx-auto max-w-5xl space-y-14">
      <div class="animate">
        <PageHeader
          title="Bangumi."
          subtitle="Life is short, but stories last forever."
        />
      </div>

      <div class="animate no-scrollbar flex gap-3 overflow-x-auto pb-4">
        {
          groups.map((group, i) => (
            <button
              data-target={group.id}
              class:list={[
                "bangumi-tab shrink-0 rounded-full border px-6 py-2 text-[10px] font-bold tracking-[0.2em] uppercase transition-all duration-300",
                i === 0
                  ? "active-tab border-zinc-900 bg-zinc-900 text-white shadow-lg shadow-zinc-200 dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-950 dark:shadow-none"
                  : "border-zinc-200 text-zinc-400 hover:border-zinc-900 hover:text-zinc-900 dark:border-zinc-800 dark:text-zinc-500 dark:hover:border-zinc-100 dark:hover:text-zinc-100",
              ]}
            >
              {group.label}{" "}
              <span class="ml-1 opacity-50">/ {group.data.length}</span>
            </button>
          ))
        }
      </div>

      <div class="animate relative min-h-[400px]">
        {
          groups.map((group, i) => (
            <div
              id={group.id}
              class:list={[
                "bangumi-content grid gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4",
                i !== 0 && "hidden",
              ]}
            >
              {group.data.length > 0 ? (
                group.data.map((item, index) => (
                  <BangumiCard item={item} index={index} />
                ))
              ) : (
                <p class="col-span-full py-20 text-center font-mono text-xs tracking-widest text-zinc-400 uppercase">
                  No records found.
                </p>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </Container>
</Layout>

<script>
  function initTabs() {
    const tabs = document.querySelectorAll(".bangumi-tab");
    const contents = document.querySelectorAll(".bangumi-content");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const targetId = tab.getAttribute("data-target");

        tabs.forEach((t) => {
          t.classList.remove(
            "active-tab",
            "border-zinc-900",
            "bg-zinc-900",
            "text-white",
            "shadow-lg",
            "shadow-zinc-200",
            "dark:border-zinc-100",
            "dark:bg-zinc-100",
            "dark:text-zinc-950",
            "dark:shadow-none",
          );
          t.classList.add(
            "border-zinc-200",
            "text-zinc-400",
            "dark:border-zinc-800",
            "dark:text-zinc-500",
          );
        });

        tab.classList.add(
          "active-tab",
          "border-zinc-900",
          "bg-zinc-900",
          "text-white",
          "shadow-lg",
          "shadow-zinc-200",
          "dark:border-zinc-100",
          "dark:bg-zinc-100",
          "dark:text-zinc-950",
          "dark:shadow-none",
        );
        tab.classList.remove(
          "border-zinc-200",
          "text-zinc-400",
          "dark:border-zinc-800",
          "dark:text-zinc-500",
        );

        contents.forEach((content) => {
          content.id === targetId
            ? content.classList.remove("hidden")
            : content.classList.add("hidden");
        });
      });
    });
  }

  initTabs();
  document.addEventListener("astro:after-swap", initTabs);
</script>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
