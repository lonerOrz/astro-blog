---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import PageHeader from "@components/PageHeader.astro";
import Link from "@components/Link.astro";
import { ABOUT, SITE, SOCIALS } from "@consts";

const facts = [
  { label: "Focus", value: "Web, tooling, and small useful systems." },
  { label: "Taste", value: "Quiet interfaces, fast pages, clear writing." },
  { label: "Stack", value: "Astro, TypeScript, Tailwind CSS, and Nix." },
];
---

<Layout title={ABOUT.TITLE} description={ABOUT.DESCRIPTION || "About lonerOrz"}>
  <Container>
    <div class="mx-auto max-w-5xl space-y-14">
      <div class="animate">
        <PageHeader title="About." subtitle="lonerOrz" />
      </div>

      <section class="grid gap-12 lg:grid-cols-[1fr_340px] lg:items-start">
        <div class="min-w-0 space-y-10">
          <div class="animate space-y-6">
            <p
              class="max-w-2xl text-3xl leading-tight font-semibold tracking-tight text-zinc-900 sm:text-4xl dark:text-zinc-50"
            >
              I build quiet things for the web — notes, tools, experiments, and
              small systems that feel considered.
            </p>
            <div
              class="max-w-2xl space-y-4 text-base leading-relaxed text-zinc-600 dark:text-zinc-400"
            >
              <p>
                Hello, I'm lonerOrz. I'm a developer who cares about simplicity,
                speed, and the details.
              </p>
            </div>
          </div>

          <div class="grid gap-4 sm:grid-cols-3">
            {
              facts.map((fact, i) => (
                <div
                  class="stagger-item rounded-2xl border border-zinc-200 bg-white/50 p-5 shadow-sm transition-all duration-300 hover:-translate-y-1 dark:border-zinc-800 dark:bg-zinc-900/40"
                  style={`--delay: ${150 + i * 80}ms`}
                >
                  <p class="font-mono text-[10px] font-bold tracking-[0.2em] text-zinc-400 uppercase">
                    {fact.label}
                  </p>
                  <p class="mt-2 text-sm text-zinc-700 dark:text-zinc-300">
                    {fact.value}
                  </p>
                </div>
              ))
            }
          </div>
        </div>

        <aside class="stagger-item" style="--delay: 300ms">
          <div class="flip-card-perspective group">
            <div id="about-card" class="flip-card-inner cursor-help">
              <figure
                class="flip-card-front relative overflow-hidden rounded-[2.5rem] border border-zinc-200 bg-white p-2.5 shadow-2xl dark:border-zinc-800 dark:bg-zinc-900"
              >
                <div class="relative overflow-hidden rounded-[1.8rem]">
                  <img
                    src="/site/cat.png"
                    alt="A lovely companion"
                    class="aspect-[4/5] w-full object-cover transition-transform duration-700 group-hover:scale-105"
                    loading="eager"
                  />
                </div>
                <figcaption
                  class="px-2 py-4 text-center font-mono text-[10px] font-bold tracking-[0.2em] text-zinc-400 uppercase"
                >
                  companion / cat.png
                </figcaption>
              </figure>

              <div
                class="flip-card-back absolute inset-0 flex flex-col justify-between rounded-[2.5rem] border border-zinc-200 bg-white p-8 shadow-2xl dark:border-zinc-800 dark:bg-zinc-900"
              >
                <div class="space-y-8">
                  <div
                    class="flex items-center justify-between border-b border-zinc-100 pb-4 dark:border-zinc-800"
                  >
                    <span
                      class="font-mono text-[9px] font-bold tracking-[0.2em] text-zinc-400 uppercase"
                      >Metadata</span
                    >
                    <div class="flex items-center gap-1.5">
                      <span
                        class="size-1.5 animate-pulse rounded-full bg-emerald-500"
                      ></span>
                      <span
                        class="font-mono text-[9px] font-bold text-emerald-600 uppercase"
                        >Live</span
                      >
                    </div>
                  </div>
                  <div class="space-y-6">
                    <div>
                      <p
                        class="mb-1 font-mono text-[10px] font-bold tracking-widest text-zinc-400 uppercase"
                      >
                        Status
                      </p>
                      <p
                        class="text-sm text-zinc-600 italic dark:text-zinc-400"
                      >
                        "Building things that last."
                      </p>
                    </div>
                  </div>
                </div>
                <div class="pt-4 text-center">
                  <span
                    class="animate-pulse font-mono text-[10px] tracking-[0.3em] text-zinc-300 uppercase"
                    >Hover to return</span
                  >
                </div>
              </div>
            </div>
          </div>
        </aside>
      </section>

      <section
        class="animate border-t border-zinc-100 pt-12 dark:border-zinc-800"
      >
        <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-end">
          <div class="space-y-3">
            <h2
              class="text-sm font-bold tracking-widest text-zinc-400 uppercase"
            >
              Connect
            </h2>
            <p
              class="max-w-xl text-[15px] leading-relaxed text-zinc-500 dark:text-zinc-400"
            >
              Find me through the links below.
            </p>
          </div>
          <div class="flex flex-wrap gap-4">
            {
              SOCIALS.map((social) => (
                <Link
                  href={social.HREF}
                  external
                  underline={false}
                  class="rounded-lg border border-zinc-200 bg-zinc-50 px-3 py-1.5 text-xs font-medium text-zinc-600 shadow-sm transition-all hover:bg-zinc-900 hover:text-white dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-400 dark:hover:bg-zinc-100 dark:hover:text-zinc-900"
                >
                  {social.NAME}
                </Link>
              ))
            }
            <Link
              href={`mailto:${SITE.EMAIL}`}
              underline={false}
              class="rounded-lg border border-zinc-200 bg-zinc-50 px-3 py-1.5 text-xs font-medium text-zinc-600 shadow-sm transition-all hover:bg-zinc-900 hover:text-white dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-400 dark:hover:bg-zinc-100 dark:hover:text-zinc-900"
            >
              Email
            </Link>
          </div>
        </div>
      </section>
    </div>
  </Container>
</Layout>

<script>
  const card = document.getElementById("about-card");
  card?.addEventListener("click", () => card.classList.toggle("is-flipped"));
</script>

<style>
  .flip-card-perspective {
    perspective: 2000px;
    -webkit-perspective: 2000px;
    width: 100%;
    position: relative;
  }

  .flip-card-inner {
    position: relative;
    width: 100%;
    transform-style: preserve-3d;
    -webkit-transform-style: preserve-3d;
    transition: transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: transform;
    transform: translateZ(0);
  }

  .group:hover .flip-card-inner,
  .flip-card-inner.is-flipped {
    transform: rotateY(180deg);
  }

  .flip-card-front,
  .flip-card-back {
    width: 100%;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .flip-card-front {
    transform: rotateY(0deg);
  }

  .flip-card-back {
    transform: rotateY(180deg) translateZ(1px);
    z-index: 1;
  }
</style>
