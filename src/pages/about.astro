---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { ABOUT } from "@consts";
---

<Layout title={ABOUT.TITLE} description={ABOUT.DESCRIPTION}>
  <Container>
    <div class="animate space-y-10">
      <div class="space-y-1.5">
        <h1 class="text-3xl font-semibold text-black dark:text-white">
          About.
        </h1>
        <p class="font-mono text-xs text-black/40 dark:text-white/40">
          lonerOrz
        </p>
      </div>
      <article class="prose dark:prose-invert max-w-none">
        <p>
          Hello! I'm lonerOrz, a developer passionate about creating beautiful
          and functional websites.
        </p>
        <p>
          This website is my personal blog and portfolio where I share my
          thoughts on technology, programming, and other interests.
        </p>
        <img
          src="/site/cat.png"
          alt="A picture of a cat"
          class="mx-auto rounded-lg shadow-lg"
        />
        <p class="text-center text-sm">This is my cat, a lovely companion.</p>
        <p>
          Feel free to explore my blog posts and projects. If you'd like to get
          in touch, you can find my social media links on the homepage.
        </p>
      </article>
    </div>
  </Container>
</Layout>
