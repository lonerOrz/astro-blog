---
import { getCollection, render } from "astro:content";
import type { Page } from "astro";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import PageHeader from "@components/PageHeader.astro";
import { NOTES } from "@consts";

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const allNotes = (await getCollection("notes"))
    .filter((note) => !note.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return paginate(allNotes, { pageSize: 5 });
}

interface Props {
  page: Page<any>;
}

const { page } = Astro.props;
const currentNotes = page.data;

const renderedNotes = await Promise.all(
  currentNotes.map(async (note: any) => {
    const { Content } = await render(note);
    return { ...note, Content };
  })
);

const totalNotesCount = page.total;
const startingIndex = totalNotesCount - (page.currentPage - 1) * page.size;

function formatMomentsDate(date: Date) {
  const now = new Date();
  const diffTime = Math.abs(now.valueOf() - date.valueOf());
  const diffMinutes = Math.floor(diffTime / (1000 * 60));
  const diffHours = Math.floor(diffTime / (1000 * 60 * 60));
  const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));

  if (diffMinutes < 1) return "JUST NOW";
  if (diffMinutes < 60) return `${diffMinutes}M AGO`;
  if (diffHours < 24) return `${diffHours}H AGO`;
  if (diffDays === 1) return "YESTERDAY";
  if (diffDays < 7) return `${diffDays}D AGO`;

  return date.toLocaleDateString("zh-CN", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<Layout title={NOTES.TITLE} description={NOTES.DESCRIPTION}>
  <!-- 动态氛围背景 -->
  <div class="fixed inset-0 pointer-events-none overflow-hidden z-[-1]">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#e9d5ff_1px,transparent_1px),linear-gradient(to_bottom,#e9d5ff_1px,transparent_1px)] bg-[size:2.5rem_2.5rem] opacity-[0.2] dark:opacity-[0.1] [mask-image:radial-gradient(ellipse_at_center,white,transparent_90%)]"></div>
    <div class="absolute top-[-5%] left-[-5%] w-[600px] h-[600px] bg-purple-400/10 dark:bg-indigo-600/10 blur-[130px] rounded-full animate-pulse"></div>
    <div class="absolute bottom-[10%] right-[-5%] w-[550px] h-[650px] bg-fuchsia-300/10 dark:bg-blue-700/5 blur-[140px] rounded-full"></div>
  </div>

  <Container>
    <aside data-pagefind-ignore>
      <div class="pb-24">
        <PageHeader title="Notes." subtitle={`Atomic thoughts & technical fragments (Page ${page.currentPage})`} />

        <div class="mt-16 flex flex-col lg:flex-row gap-12 items-start">

          <!-- 左边栏：仪表盘 -->
          <div class="w-full lg:w-[32%] lg:sticky lg:top-28 flex flex-col gap-6 p-7 rounded-[2.5rem] border border-purple-200/50 bg-white/70 backdrop-blur-xl dark:border-indigo-500/20 dark:bg-zinc-900/40 shadow-sm shrink-0">
            <div class="flex items-center gap-3 text-[10px] font-bold tracking-[0.25em] text-purple-600/70 dark:text-indigo-400 uppercase">
              <div class="size-1.5 rounded-full bg-purple-500 animate-pulse"></div>
              <span>Status: Synchronized</span>
            </div>

            <div class="flex items-baseline gap-3 mt-2">
              <span class="text-5xl font-light tracking-tighter text-purple-950 dark:text-indigo-50 font-mono">{totalNotesCount}</span>
              <span class="text-[10px] font-black text-zinc-400 uppercase tracking-widest">Logs Compiled</span>
            </div>

            <div class="h-px bg-gradient-to-r from-purple-100 to-transparent dark:from-indigo-900/50"></div>

            <!-- 当前页面索引 -->
            <div class="hidden lg:flex flex-col gap-4">
              <span class="text-[9px] font-black text-purple-400 dark:text-indigo-500 uppercase tracking-widest">Current View Index</span>
              <nav class="relative pl-4 flex flex-col gap-4">
                <!-- 动态进度条 -->
                <div class="absolute left-0 top-1 bottom-1 w-[1.5px] bg-zinc-100 dark:bg-zinc-800">
                  <div id="js-live-tree" class="w-full bg-gradient-to-b from-purple-500 to-indigo-500 shadow-[0_0_8px_#a855f7] h-0 transition-all duration-300 ease-out"></div>
                </div>

                {renderedNotes.map((note: any, index: number) => {
                  const absoluteId = startingIndex - index;
                  return (
                    <a
                      href={`#note-${absoluteId}`}
                      data-index-link={absoluteId}
                      class="group/nav flex items-center justify-between text-xs font-medium text-zinc-400 hover:text-purple-600 dark:hover:text-indigo-400 transition-all duration-300"
                    >
                      <span class="truncate pr-4 max-w-[160px] group-hover/nav:translate-x-1 transition-transform">
                        {note.data.title || "Observation unit"}
                      </span>
                      <span class="font-mono text-[9px] opacity-40">#{String(absoluteId).padStart(2, '0')}</span>
                    </a>
                  );
                })}
              </nav>
            </div>

            <div class="h-px bg-gradient-to-r from-purple-100 to-transparent dark:from-indigo-900/50"></div>

            <!-- 侧边栏分页器 -->
            <nav class="flex flex-col gap-3 font-mono text-xs select-none">
              <div class="grid grid-cols-2 gap-2">
                {page.url.prev ? (
                  <a href={page.url.prev} class="flex items-center justify-center gap-1.5 py-3 rounded-2xl border border-purple-100 bg-white hover:bg-purple-600 hover:text-white shadow-sm transition-all duration-300 dark:bg-zinc-900 dark:border-zinc-800">
                    <span class="tracking-widest font-bold">PREV</span>
                  </a>
                ) : (
                  <div class="flex items-center justify-center py-3 rounded-2xl border border-dashed border-zinc-100 text-zinc-200 dark:border-zinc-800 dark:text-zinc-700 pointer-events-none text-[10px] uppercase font-bold tracking-tighter">Genesis</div>
                )}

                {page.url.next ? (
                  <a href={page.url.next} class="flex items-center justify-center gap-1.5 py-3 rounded-2xl border border-purple-100 bg-white hover:bg-purple-600 hover:text-white shadow-sm transition-all duration-300 dark:bg-zinc-900 dark:border-zinc-800">
                    <span class="tracking-widest font-bold">NEXT</span>
                  </a>
                ) : (
                  <div class="flex items-center justify-center py-3 rounded-2xl border border-dashed border-zinc-100 text-zinc-200 dark:border-zinc-800 dark:text-zinc-700 pointer-events-none text-[10px] uppercase font-bold tracking-tighter">Latest</div>
                )}
              </div>
            </nav>
          </div>

          <!-- 右边栏：Note 卡片 -->
          <div class="w-full lg:w-[68%] flex flex-col gap-12">
            {renderedNotes.map((note: any, i: number) => {
              const absoluteId = startingIndex - i;
              return (
                <article
                  id={`note-${absoluteId}`}
                  class="note-card-container group relative"
                  style={`--order: ${i}; scroll-margin-top: 120px;`}
                  data-note-id={absoluteId}
                >
                  <!-- 活页孔 -->
                  <div class="absolute left-4 top-0 bottom-0 w-4 flex flex-col justify-center gap-6 z-20 pointer-events-none">
                    {[...Array(8)].map((_, hi) => (
                      <div
                        class="notebook-hole size-2.5 sm:size-3 rounded-full bg-zinc-100 border border-zinc-200 shadow-[inset_0_1.5px_3px_rgba(0,0,0,0.1)] dark:bg-black dark:border-zinc-800 dark:shadow-[inset_0_2px_4px_rgba(0,0,0,0.8)] transition-all duration-500"
                        style={`transition-delay: ${hi * 40}ms;`}
                      ></div>
                    ))}
                  </div>

                  <!-- 核心卡片 -->
                  <div class="relative ml-10 rounded-[2.5rem] bg-white border border-zinc-200/60 dark:bg-zinc-900/40 dark:border-indigo-500/10 shadow-sm transition-all duration-500 group-hover:border-purple-200 dark:group-hover:border-indigo-500/30 group-hover:shadow-xl group-hover:shadow-purple-500/5">
                    <!-- 笔记本装饰红线 -->
                    <div class="absolute left-10 top-0 bottom-0 w-px bg-red-100/60 dark:bg-red-900/20"></div>

                    <div class="p-8 sm:p-12 pl-12 sm:pl-16">
                      <div class="flex items-center justify-between gap-4 mb-8 pb-6 border-b border-zinc-50 dark:border-indigo-950/30">
                        <div class="flex items-center gap-4 min-w-0">
                          <div class="flex items-center justify-center shrink-0 size-7 rounded-xl bg-purple-50 text-purple-500 group-hover:bg-purple-600 group-hover:text-white transition-all duration-500">
                             <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15.5 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-8.5"/><path d="M15 18H9"/><path d="M15 14H9"/><path d="M15 10H9"/><path d="M19 2.5 21.5 4.5 19 6.5"/></svg>
                          </div>
                          <div class="flex flex-col min-w-0">
                            <h2 class="font-bold text-zinc-900 dark:text-zinc-100 text-lg tracking-tight group-hover:text-purple-600 dark:group-hover:text-indigo-400 transition-colors">
                              {note.data.title || "Untitled Fragment"}
                            </h2>
                            <span class="font-mono text-[10px] text-purple-400 dark:text-indigo-500 tracking-[0.1em] mt-0.5">
                              {formatMomentsDate(note.data.date)}
                            </span>
                          </div>
                        </div>
                        <div class="font-mono text-[11px] font-bold text-zinc-300 dark:text-zinc-700 tracking-tighter">
                          LOG.#{absoluteId}
                        </div>
                      </div>

                      <div class="pl-1 sm:pl-8">
                        <div class="prose prose-zinc prose-base max-w-none dark:prose-invert prose-p:leading-relaxed prose-p:text-zinc-600 dark:prose-p:text-zinc-400 prose-a:text-purple-600 dark:prose-a:text-indigo-400 prose-strong:text-purple-900 dark:prose-strong:text-indigo-100">
                          <note.Content />
                        </div>

                        <div class="mt-12 flex items-center justify-between opacity-30 group-hover:opacity-100 transition-opacity duration-500">
                          <div class="flex gap-2">
                             {[1, 2, 3].map(() => <div class="size-1 rounded-full bg-zinc-200 dark:bg-zinc-800"></div>)}
                          </div>
                          <div class="text-[9px] font-black uppercase tracking-[0.3em] text-zinc-400">End Translation</div>
                        </div>
                      </div>
                    </div>
                  </div>
                </article>
              );
            })}
          </div>

        </div>
      </div>
    </aside>
  </Container>
</Layout>

<style is:global>
  /* 入场动画 */
  .note-card-container {
    opacity: 0;
    transform: translateY(30px);
    animation: noteUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--order) * 0.12s);
  }

  @keyframes noteUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* 活页孔 Hover 律动 */
  .group:hover .notebook-hole {
    background-color: #a855f7 !important;
    border-color: #9333ea !important;
    transform: scale(1.2);
    box-shadow: 0 0 10px rgba(168, 85, 247, 0.4);
  }
</style>

<script>
  function initNoteSystem() {
    const liveTree = document.getElementById('js-live-tree');
    const noteCards = document.querySelectorAll('[data-note-id]');
    const navLinks = document.querySelectorAll('[data-index-link]');

    if (!liveTree) return;

    let ticking = false;
    const updateProgressBar = () => {
      const winScroll = window.scrollY;
      const height = document.documentElement.scrollHeight - window.innerHeight;
      const scrolled = (winScroll / height) * 100;
      liveTree.style.height = scrolled + "%";
      ticking = false;
    };

    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(updateProgressBar);
        ticking = true;
      }
    }, { passive: true });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const activeId = entry.target.getAttribute('data-note-id');
          navLinks.forEach(link => {
            const isMatch = link.getAttribute('data-index-link') === activeId;
            link.classList.toggle('text-purple-600', isMatch);
            link.classList.toggle('dark:text-indigo-400', isMatch);
            link.classList.toggle('pl-2', isMatch);
            link.classList.toggle('text-zinc-400', !isMatch);
          });
        }
      });
    }, { rootMargin: "-20% 0px -60% 0px", threshold: 0.1 });

    noteCards.forEach(card => observer.observe(card));

    // 清理机制
    document.addEventListener('astro:before-swap', () => {
      observer.disconnect();
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initNoteSystem);
</script>
