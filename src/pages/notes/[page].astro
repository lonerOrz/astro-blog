---
import { getCollection, render } from "astro:content";
import type { Page } from "astro";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import PageHeader from "@components/PageHeader.astro";
import { NOTES } from "@consts";
import MarkdownImage from "@components/MarkdownImage.astro";

export async function getStaticPaths({ paginate }: { paginate: any }) {
  const allNotes = (await getCollection("notes"))
    .filter((note) => !note.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return paginate(allNotes, { pageSize: 5 });
}

interface Props {
  page: Page<any>;
}

const { page } = Astro.props;
const currentNotes = page.data;

const renderedNotes = await Promise.all(
  currentNotes.map(async (note: any) => {
    const { Content } = await render(note);
    return { ...note, Content };
  }),
);

const totalNotesCount = page.total;
const startingIndex = totalNotesCount - (page.currentPage - 1) * page.size;

function formatMomentsDate(date: Date) {
  const now = new Date();
  const diffTime = Math.abs(now.valueOf() - date.valueOf());
  const diffMinutes = Math.floor(diffTime / (1000 * 60));
  const diffHours = Math.floor(diffTime / (1000 * 60 * 60));
  const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));

  if (diffMinutes < 1) return "JUST NOW";
  if (diffMinutes < 60) return `${diffMinutes}M AGO`;
  if (diffHours < 24) return `${diffHours}H AGO`;
  if (diffDays === 1) return "YESTERDAY";
  if (diffDays < 7) return `${diffDays}D AGO`;

  return date.toLocaleDateString("zh-CN", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<Layout title={NOTES.TITLE} description={NOTES.DESCRIPTION}>
  <!-- 动态氛围背景 -->
  <div class="pointer-events-none fixed inset-0 z-[-1] overflow-hidden">
    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,#e9d5ff_1px,transparent_1px),linear-gradient(to_bottom,#e9d5ff_1px,transparent_1px)] [mask-image:radial-gradient(ellipse_at_center,white,transparent_90%)] bg-[size:2.5rem_2.5rem] opacity-[0.2] dark:opacity-[0.1]"
    >
    </div>
    <div
      class="absolute top-[-5%] left-[-5%] h-[600px] w-[600px] animate-pulse rounded-full bg-purple-400/10 blur-[130px] dark:bg-indigo-600/10"
    >
    </div>
    <div
      class="absolute right-[-5%] bottom-[10%] h-[650px] w-[550px] rounded-full bg-fuchsia-300/10 blur-[140px] dark:bg-blue-700/5"
    >
    </div>
  </div>

  <Container>
    <aside data-pagefind-ignore>
      <div class="pb-24">
        <PageHeader
          title="Notes."
          subtitle={`Atomic thoughts & technical fragments (Page ${page.currentPage})`}
        />

        <div class="mt-16 flex flex-col items-start gap-12 lg:flex-row">
          <!-- 左边栏：仪表盘 -->
          <div
            class="flex w-full shrink-0 flex-col gap-6 rounded-[2.5rem] border border-purple-200/50 bg-white/70 p-7 shadow-sm backdrop-blur-xl lg:sticky lg:top-28 lg:w-[32%] dark:border-indigo-500/20 dark:bg-zinc-900/40"
          >
            <div
              class="flex items-center gap-3 text-[10px] font-bold tracking-[0.25em] text-purple-600/70 uppercase dark:text-indigo-400"
            >
              <div class="size-1.5 animate-pulse rounded-full bg-purple-500">
              </div>
              <span>Status: Synchronized</span>
            </div>

            <div class="mt-2 flex items-baseline gap-3">
              <span
                class="font-mono text-5xl font-light tracking-tighter text-purple-950 dark:text-indigo-50"
                >{totalNotesCount}</span
              >
              <span
                class="text-[10px] font-black tracking-widest text-zinc-400 uppercase"
                >Logs Compiled</span
              >
            </div>

            <div
              class="h-px bg-gradient-to-r from-purple-100 to-transparent dark:from-indigo-900/50"
            >
            </div>

            <!-- 当前页面索引 -->
            <div class="hidden flex-col gap-4 lg:flex">
              <span
                class="text-[9px] font-black tracking-widest text-purple-400 uppercase dark:text-indigo-500"
                >Current View Index</span
              >
              <nav class="relative flex flex-col gap-4 pl-4">
                <!-- 动态进度条 -->
                <div
                  class="absolute top-1 bottom-1 left-0 w-[1.5px] bg-zinc-100 dark:bg-zinc-800"
                >
                  <div
                    id="js-live-tree"
                    class="h-0 w-full bg-gradient-to-b from-purple-500 to-indigo-500 shadow-[0_0_8px_#a855f7] transition-all duration-300 ease-out"
                  >
                  </div>
                </div>

                {
                  renderedNotes.map((note: any, index: number) => {
                    const absoluteId = startingIndex - index;
                    return (
                      <a
                        href={`#note-${absoluteId}`}
                        data-index-link={absoluteId}
                        class="group/nav flex items-center justify-between text-xs font-medium text-zinc-400 transition-all duration-300 hover:text-purple-600 dark:hover:text-indigo-400"
                      >
                        <span class="max-w-[160px] truncate pr-4 transition-transform group-hover/nav:translate-x-1">
                          {note.data.title || "Observation unit"}
                        </span>
                        <span class="font-mono text-[9px] opacity-40">
                          #{String(absoluteId).padStart(2, "0")}
                        </span>
                      </a>
                    );
                  })
                }
              </nav>
            </div>

            <div
              class="h-px bg-gradient-to-r from-purple-100 to-transparent dark:from-indigo-900/50"
            >
            </div>

            <!-- 侧边栏分页器 -->
            <nav class="flex flex-col gap-3 font-mono text-xs select-none">
              <div class="grid grid-cols-2 gap-2">
                {
                  page.url.prev ? (
                    <a
                      href={page.url.prev}
                      class="flex items-center justify-center gap-1.5 rounded-2xl border border-purple-100 bg-white py-3 shadow-sm transition-all duration-300 hover:bg-purple-600 hover:text-white dark:border-zinc-800 dark:bg-zinc-900"
                    >
                      <span class="font-bold tracking-widest">PREV</span>
                    </a>
                  ) : (
                    <div class="pointer-events-none flex items-center justify-center rounded-2xl border border-dashed border-zinc-100 py-3 text-[10px] font-bold tracking-tighter text-zinc-200 uppercase dark:border-zinc-800 dark:text-zinc-700">
                      Genesis
                    </div>
                  )
                }

                {
                  page.url.next ? (
                    <a
                      href={page.url.next}
                      class="flex items-center justify-center gap-1.5 rounded-2xl border border-purple-100 bg-white py-3 shadow-sm transition-all duration-300 hover:bg-purple-600 hover:text-white dark:border-zinc-800 dark:bg-zinc-900"
                    >
                      <span class="font-bold tracking-widest">NEXT</span>
                    </a>
                  ) : (
                    <div class="pointer-events-none flex items-center justify-center rounded-2xl border border-dashed border-zinc-100 py-3 text-[10px] font-bold tracking-tighter text-zinc-200 uppercase dark:border-zinc-800 dark:text-zinc-700">
                      Latest
                    </div>
                  )
                }
              </div>
            </nav>
          </div>

          <!-- 右边栏：Note 卡片 -->
          <div class="flex w-full flex-col gap-12 lg:w-[68%]">
            {
              renderedNotes.map((note: any, i: number) => {
                const absoluteId = startingIndex - i;
                return (
                  <article
                    id={`note-${absoluteId}`}
                    class="note-card-container group relative"
                    style={`--order: ${i}; scroll-margin-top: 120px;`}
                    data-note-id={absoluteId}
                  >
                    {/* 活页孔 */}
                    <div class="pointer-events-none absolute top-0 bottom-0 left-4 z-20 flex w-4 flex-col justify-center gap-6">
                      {[...Array(8)].map((_, hi) => (
                        <div
                          class="notebook-hole size-2.5 rounded-full border border-zinc-200 bg-zinc-100 shadow-[inset_0_1.5px_3px_rgba(0,0,0,0.1)] transition-all duration-500 sm:size-3 dark:border-zinc-800 dark:bg-black dark:shadow-[inset_0_2px_4px_rgba(0,0,0,0.8)]"
                          style={`transition-delay: ${hi * 40}ms;`}
                        />
                      ))}
                    </div>

                    {/* 核心卡片 */}
                    <div class="relative ml-10 rounded-[2.5rem] border border-zinc-200/60 bg-white shadow-sm transition-all duration-500 group-hover:border-purple-200 group-hover:shadow-xl group-hover:shadow-purple-500/5 dark:border-indigo-500/10 dark:bg-zinc-900/40 dark:group-hover:border-indigo-500/30">
                      <div class="absolute top-0 bottom-0 left-10 w-px bg-red-100/60 dark:bg-red-900/20" />

                      <div class="p-8 pl-12 sm:p-12 sm:pl-16">
                        <div class="mb-8 flex items-center justify-between gap-4 border-b border-zinc-50 pb-6 dark:border-indigo-950/30">
                          <div class="flex min-w-0 items-center gap-4">
                            <div class="flex size-7 shrink-0 items-center justify-center rounded-xl bg-purple-50 text-purple-500 transition-all duration-500 group-hover:bg-purple-600 group-hover:text-white">
                              <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="14"
                                height="14"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              >
                                <>
                                  <path d="M15.5 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-8.5" />
                                  <path d="M15 18H9" />
                                  <path d="M15 14H9" />
                                  <path d="M15 10H9" />
                                  <path d="M19 2.5 21.5 4.5 19 6.5" />
                                </>
                              </svg>
                            </div>
                            <div class="flex min-w-0 flex-col">
                              <h2 class="text-lg font-bold tracking-tight text-zinc-900 transition-colors group-hover:text-purple-600 dark:text-zinc-100 dark:group-hover:text-indigo-400">
                                {note.data.title || "Untitled Fragment"}
                              </h2>
                              <span class="mt-0.5 font-mono text-[10px] tracking-[0.1em] text-purple-400 dark:text-indigo-500">
                                {formatMomentsDate(note.data.date)}
                              </span>
                            </div>
                          </div>

                          {/* LOG ID 和 带 Tooltip 的分享按钮 */}
                          <div class="flex items-center gap-3">
                            <div class="font-mono text-[11px] font-bold tracking-tighter text-zinc-300 dark:text-zinc-700">
                              LOG.#{absoluteId}
                            </div>
                            <button
                              class="share-note-btn tooltip-trigger relative flex size-7 items-center justify-center rounded-lg text-zinc-400 transition-all duration-300 hover:bg-purple-50 hover:text-purple-600 dark:text-zinc-600 dark:hover:bg-indigo-900/40 dark:hover:text-indigo-400"
                              data-note-id={`note-${absoluteId}`}
                              data-tooltip="Copy link"
                              aria-label="Share note"
                            >
                              <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="14"
                                height="14"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              >
                                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
                              </svg>
                            </button>
                          </div>
                        </div>

                        <div class="pl-1 sm:pl-8">
                          <div class="prose prose-zinc prose-base dark:prose-invert prose-p:leading-relaxed prose-p:text-zinc-600 dark:prose-p:text-zinc-400 prose-a:text-purple-600 dark:prose-a:text-indigo-400 prose-strong:text-purple-900 dark:prose-strong:text-indigo-100 max-w-none">
                            <note.Content components={{ img: MarkdownImage }} />
                          </div>

                          <div class="mt-12 flex items-center justify-between opacity-30 transition-opacity duration-500 group-hover:opacity-100">
                            <div class="flex gap-2">
                              {[1, 2, 3].map(() => (
                                <div class="size-1 rounded-full bg-zinc-200 dark:bg-zinc-800" />
                              ))}
                            </div>
                            <div class="text-[9px] font-black tracking-[0.3em] text-zinc-400 uppercase">
                              End Translation
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </article>
                );
              })
            }
          </div>
        </div>
      </div>
    </aside>
  </Container>
</Layout>

<style is:global>
  /* 入场动画 */
  .note-card-container {
    opacity: 0;
    transform: translateY(30px);
    animation: noteUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--order) * 0.12s);
  }

  @keyframes noteUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* 活页孔 Hover 律动 */
  .group:hover .notebook-hole {
    background-color: #a855f7 !important;
    border-color: #9333ea !important;
    transform: scale(1.2);
    box-shadow: 0 0 10px rgba(168, 85, 247, 0.4);
  }

  /* --- Tooltip 样式 --- */
  .tooltip-trigger::before {
    content: attr(data-tooltip);
    position: absolute;
    bottom: 125%;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    padding: 6px 10px;
    background-color: #18181b; /* zinc-900 */
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
    border-radius: 8px;
    opacity: 0;
    pointer-events: none;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 50;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  }

  .tooltip-trigger::after {
    content: "";
    position: absolute;
    bottom: 110%;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    border-width: 5px;
    border-style: solid;
    border-color: #18181b transparent transparent transparent;
    opacity: 0;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 50;
  }

  .tooltip-trigger:hover::before,
  .tooltip-trigger:hover::after {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* Tooltip 暗色模式适配 */
  .dark .tooltip-trigger::before {
    background-color: #312e81; /* indigo-900 */
    border: 1px solid rgba(129, 140, 248, 0.2);
    color: #e0e7ff;
  }
  .dark .tooltip-trigger::after {
    border-color: #312e81 transparent transparent transparent;
  }
</style>

<script>
  function initNoteSystem() {
    // 1. 如果通过分享链接进入，平滑滚动到目标锚点
    if (window.location.hash) {
      const targetElement = document.querySelector(window.location.hash);
      if (targetElement) {
        setTimeout(() => {
          targetElement.scrollIntoView({ behavior: "smooth", block: "start" });
        }, 200);
      }
    }

    const liveTree = document.getElementById("js-live-tree");
    const noteCards = document.querySelectorAll("[data-note-id]");
    const navLinks = document.querySelectorAll("[data-index-link]");

    // 2. 绑定复制链接功能
    const shareButtons = document.querySelectorAll(".share-note-btn");
    shareButtons.forEach((btn) => {
      btn.addEventListener("click", async () => {
        const noteId = btn.getAttribute("data-note-id");
        const url = new URL(window.location.href);
        url.hash = noteId || "";
        const shareUrl = url.toString();

        try {
          await navigator.clipboard.writeText(shareUrl);

          // 反馈：变更 Tooltip 文字和图标
          btn.setAttribute("data-tooltip", "Copied!");
          const originalInner = btn.innerHTML;
          btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-green-500 dark:text-green-400"><polyline points="20 6 9 17 4 12"></polyline></svg>`;

          setTimeout(() => {
            btn.innerHTML = originalInner;
            btn.setAttribute("data-tooltip", "Copy link");
          }, 2000);
        } catch (err) {
          console.error("Failed to copy text: ", err);
        }
      });
    });

    if (!liveTree) return;

    let ticking = false;
    const updateProgressBar = () => {
      const winScroll = window.scrollY;
      const height = document.documentElement.scrollHeight - window.innerHeight;
      const scrolled = (winScroll / height) * 100;
      liveTree.style.height = scrolled + "%";
      ticking = false;
    };

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          window.requestAnimationFrame(updateProgressBar);
          ticking = true;
        }
      },
      { passive: true },
    );

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const activeId = entry.target.getAttribute("data-note-id");
            navLinks.forEach((link) => {
              const isMatch = link.getAttribute("data-index-link") === activeId;
              link.classList.toggle("text-purple-600", isMatch);
              link.classList.toggle("dark:text-indigo-400", isMatch);
              link.classList.toggle("pl-2", isMatch);
              link.classList.toggle("text-zinc-400", !isMatch);
            });
          }
        });
      },
      { rootMargin: "-20% 0px -60% 0px", threshold: 0.1 },
    );

    noteCards.forEach((card) => observer.observe(card));

    document.addEventListener(
      "astro:before-swap",
      () => {
        observer.disconnect();
      },
      { once: true },
    );
  }

  document.addEventListener("astro:page-load", initNoteSystem);
</script>
