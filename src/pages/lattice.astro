---
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";
---

<Layout
  title="Torus Knot / Topology"
  description="High-fidelity mathematical topology visualization."
>
  <Container>
    <div class="mx-auto max-w-6xl space-y-8 py-12" id="knot-container">
      <header
        class="animate-slide-up flex flex-col gap-6 border-b border-zinc-200 pb-8 md:flex-row md:items-end md:justify-between dark:border-zinc-800"
      >
        <div class="space-y-4">
          <div
            class="inline-flex items-center gap-2 rounded-full border border-zinc-300 bg-zinc-100 px-3 py-1 dark:border-zinc-800 dark:bg-zinc-900"
          >
            <span class="relative flex h-2 w-2">
              <span
                class="absolute inline-flex h-full w-full animate-ping rounded-full bg-blue-400 opacity-75"
              ></span>
              <span
                class="relative inline-flex h-2 w-2 rounded-full bg-blue-500"
              ></span>
            </span>
            <span
              class="font-mono text-[10px] font-bold tracking-[0.2em] text-zinc-500 uppercase"
              >Math Engine v2.0</span
            >
          </div>
          <h1
            class="text-4xl leading-none font-black tracking-tighter text-zinc-900 uppercase dark:text-white"
          >
            Torus <span class="text-zinc-400 dark:text-zinc-600">//</span> Knot
          </h1>
          <p
            class="max-w-md text-[11px] leading-relaxed font-bold tracking-[0.2em] text-zinc-500 uppercase"
          >
            Parametric curves generated via <span
              class="text-zinc-900 dark:text-zinc-300"
              >Toroidal Harmonic Motion</span
            >. Projected in isometric 3D space.
          </p>
        </div>

        <div class="grid grid-cols-2 gap-10 font-mono">
          <div class="space-y-1">
            <div
              class="text-[9px] font-bold tracking-widest text-zinc-400 uppercase"
            >
              Calculation
            </div>
            <div class="text-xs text-zinc-800 uppercase dark:text-zinc-200">
              Matrix Projection
            </div>
          </div>
          <div class="space-y-1">
            <div
              class="text-[9px] font-bold tracking-widest text-zinc-400 uppercase"
            >
              Complexity
            </div>
            <div class="text-xs text-zinc-800 uppercase dark:text-zinc-200">
              Non-Euclidean
            </div>
          </div>
        </div>
      </header>

      <!-- Main Display -->
      <main
        class="animate-slide-up relative aspect-video w-full overflow-hidden rounded-[2.5rem] border border-zinc-200 bg-white shadow-2xl dark:border-zinc-800 dark:bg-black"
        style="--delay: 0.1s"
      >
        <div class="pointer-events-none absolute top-8 left-8 z-20 space-y-4">
          <div
            class="rounded-2xl border border-zinc-200/50 bg-white/40 p-5 shadow-sm backdrop-blur-xl dark:border-zinc-800/50 dark:bg-black/40"
          >
            <div
              class="mb-2 text-[8px] font-black tracking-[0.3em] text-zinc-400 uppercase"
            >
              Mathematical Formula
            </div>
            <div
              id="formula-readout"
              class="font-mono text-[10px] font-bold text-zinc-800 dark:text-zinc-200"
            >
              x = (R + r cos qθ)cos pθ
            </div>
          </div>
        </div>

        <!-- 装饰背景层 -->
        <div
          class="absolute inset-0 z-0 bg-[radial-gradient(circle_at_center,rgba(59,130,246,0.04),transparent_70%)]"
        >
        </div>
        <div
          class="absolute inset-0 z-0 opacity-20 dark:opacity-40"
          style="background-image: radial-gradient(circle, #80808022 1px, transparent 1px); background-size: 40px 40px;"
        >
        </div>

        <!-- 渲染画布 -->
        <canvas id="math-canvas" class="relative z-10 h-full w-full cursor-move"
        ></canvas>

        <!-- 遮罩渐变 -->
        <div
          class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-white via-white/20 to-transparent dark:from-black dark:via-black/20"
        >
        </div>
      </main>

      <!-- Control Interface -->
      <footer
        class="animate-slide-up grid gap-8 rounded-[2rem] border border-zinc-200 bg-zinc-50/50 p-10 md:grid-cols-3 dark:border-zinc-800 dark:bg-zinc-950/50"
        style="--delay: 0.2s"
      >
        {
          [
            {
              id: "p",
              label: "Rotational (p)",
              min: 1,
              max: 15,
              step: 1,
              val: 3,
            },
            {
              id: "q",
              label: "Harmonic (q)",
              min: 1,
              max: 20,
              step: 1,
              val: 7,
            },
            {
              id: "r",
              label: "Radius Amplitude",
              min: 0.1,
              max: 1.5,
              step: 0.01,
              val: 0.45,
            },
          ].map((item) => (
            <div class="space-y-5">
              <div class="flex items-center justify-between px-1">
                <label
                  for={`input-${item.id}`}
                  class="text-[10px] font-black tracking-[0.25em] text-zinc-400 uppercase"
                >
                  {item.label}
                </label>
                <span
                  id={`${item.id}-readout`}
                  class="font-mono text-xs font-bold text-blue-600 dark:text-blue-400"
                >
                  {item.val}
                </span>
              </div>
              <input
                id={`input-${item.id}`}
                type="range"
                min={item.min}
                max={item.max}
                step={item.step}
                value={item.val}
                class="custom-slider"
              />
            </div>
          ))
        }
      </footer>
    </div>
  </Container>
</Layout>

<style is:global>
  .custom-slider {
    -webkit-appearance: none;
    width: 100%;
    height: 2px;
    background: #e2e8f0;
    outline: none;
    border-radius: 2px;
  }
  .dark .custom-slider {
    background: #27272a;
  }

  .custom-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #000;
    border: 3px solid #fff;
    box-shadow:
      0 0 0 1px #e2e8f0,
      0 4px 6px -1px rgba(0, 0, 0, 0.1);
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .dark .custom-slider::-webkit-slider-thumb {
    background: #fff;
    border-color: #000;
    box-shadow: 0 0 0 1px #27272a;
  }
  .custom-slider::-webkit-slider-thumb:hover {
    transform: scale(1.25);
    background: #2563eb;
  }

  /* 入场动画 */
  .animate-slide-up {
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0s);
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script is:inline data-astro-rerun>
  class TorusVisualizer {
    constructor() {
      this.canvas = document.getElementById("math-canvas");
      if (!this.canvas) return;
      this.ctx = this.canvas.getContext("2d", { alpha: false });

      this.inputs = {
        p: document.getElementById("input-p"),
        q: document.getElementById("input-q"),
        r: document.getElementById("input-r"),
      };

      this.readouts = {
        p: document.getElementById("p-readout"),
        q: document.getElementById("q-readout"),
        r: document.getElementById("r-readout"),
        formula: document.getElementById("formula-readout"),
      };

      this.t = 0;
      this.lastTime = 0;
      this.isDestroyed = false;
      this._resizeHandler = () => this.resize();
      this._visibilityHandler = () => this._onVisibility();
      this._swapHandler = () => this.destroy();
      this.init();
    }

    init() {
      this.resize();
      if (this.width === 0 || this.height === 0) {
        // 延迟重试：等待 layout 稳定
        this._retryTimer = setTimeout(() => this.init(), 50);
        return;
      }
      clearTimeout(this._retryTimer);
      window.addEventListener("resize", this._resizeHandler);
      document.addEventListener("visibilitychange", this._visibilityHandler);
      document.addEventListener("astro:before-swap", this._swapHandler);
      this.animate();
    }

    _onVisibility() {
      if (document.hidden) {
        cancelAnimationFrame(this.frameReq);
      } else {
        this.lastTime = performance.now();
        this.animate(this.lastTime);
      }
    }

    resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      this.width = this.canvas.offsetWidth;
      this.height = this.canvas.offsetHeight;
      if (this.width === 0 || this.height === 0) return;
      this.canvas.width = this.width * dpr;
      this.canvas.height = this.height * dpr;
      this.ctx.setTransform(1, 0, 0, 1, 0, 0);
      this.ctx.scale(dpr, dpr);
      this.scale = Math.min(this.width, this.height) * 0.18;
    }

    // 3D 空间到 2D 投影
    project(x, y, z, rotX, rotY) {
      // 旋转矩阵
      let y1 = y * Math.cos(rotX) - z * Math.sin(rotX);
      let z1 = y * Math.sin(rotX) + z * Math.cos(rotX);
      let x2 = x * Math.cos(rotY) - z1 * Math.sin(rotY);
      let z2 = x * Math.sin(rotY) + z1 * Math.cos(rotY);

      // 透视计算
      const perspective = 1 / (1 + z2 * 0.12);
      return {
        x: this.width / 2 + x2 * this.scale * perspective,
        y: this.height / 2 + y1 * this.scale * perspective,
        z: z2, // 用于深度深度着色
      };
    }

    animate(now = 0) {
      if (this.isDestroyed) return;

      const deltaTime = now - this.lastTime;
      this.lastTime = now;
      this.t += 0.004 * (deltaTime / 16.6);

      const p = parseFloat(this.inputs.p.value);
      const q = parseFloat(this.inputs.q.value);
      const r = parseFloat(this.inputs.r.value);

      // 同步 UI 读数
      this.readouts.p.textContent = p;
      this.readouts.q.textContent = q;
      this.readouts.r.textContent = r.toFixed(2);
      this.readouts.formula.textContent = `φ(θ) = [ (2 + ${r.toFixed(2)} cos ${q}θ)cos ${p}θ, ... ]`;

      this.draw(p, q, r);
      this.frameReq = requestAnimationFrame((t) => this.animate(t));
    }

    draw(p, q, r) {
      const { ctx, width, height, t } = this;
      const isDark = document.documentElement.classList.contains("dark");

      // 清空背景
      ctx.fillStyle = isDark ? "#000" : "#fff";
      ctx.fillRect(0, 0, width, height);

      const rotY = t * 0.25;
      const rotX = Math.PI / 4 + Math.sin(t * 0.12) * 0.15;

      // 1. 绘制底层环面 (Subtle Scaffolding)
      ctx.lineWidth = 0.5;
      ctx.strokeStyle = isDark ? "rgba(255,255,255,0.02)" : "rgba(0,0,0,0.04)";
      for (let u = 0; u < Math.PI * 2; u += Math.PI / 10) {
        ctx.beginPath();
        for (let v = 0; v < Math.PI * 2; v += 0.15) {
          const x = (2.2 + r * Math.cos(v)) * Math.cos(u);
          const y = (2.2 + r * Math.cos(v)) * Math.sin(u);
          const z = r * Math.sin(v);
          const pt = this.project(x, y, z, rotX, rotY);
          if (v === 0) ctx.moveTo(pt.x, pt.y);
          else ctx.lineTo(pt.x, pt.y);
        }
        ctx.stroke();
      }

      // 2. 绘制 5 重细丝纽结 (Multistrand Knot)
      const strands = 5;
      for (let s = 0; s < strands; s++) {
        const strandOffset = s * 0.015;
        ctx.beginPath();

        // 纽结路径：根据 p,q 决定 θ 的终点（为了闭合，通常取 2π）
        const resolution = 0.01;
        for (let theta = 0; theta <= Math.PI * 2; theta += resolution) {
          const R = 2.2;
          const tr = r + strandOffset;

          // Torus Knot 参数方程
          const x = (R + tr * Math.cos(q * theta)) * Math.cos(p * theta);
          const y = (R + tr * Math.cos(q * theta)) * Math.sin(p * theta);
          const z = tr * Math.sin(q * theta);

          const pt = this.project(x, y, z, rotX, rotY);

          // 基于深度的样式优化
          const depthAlpha = Math.max(0.05, (pt.z + 2.5) / 5);
          const hue = ((theta / (Math.PI * 2)) * 60 + 210) % 360; // 极光蓝调

          if (theta === 0) {
            ctx.moveTo(pt.x, pt.y);
          } else {
            ctx.strokeStyle = isDark
              ? `hsla(${hue}, 80%, 75%, ${depthAlpha * 0.5})`
              : `hsla(${hue}, 70%, 45%, ${depthAlpha * 0.7})`;
            ctx.lineWidth = depthAlpha * 1.8;
            ctx.lineTo(pt.x, pt.y);
          }

          // 周期性描绘离散数学结点
          if (s === 2 && Math.floor(theta * 100) % 50 === 0) {
            ctx.save();
            ctx.fillStyle = ctx.strokeStyle;
            ctx.globalAlpha = depthAlpha;
            ctx.beginPath();
            ctx.arc(pt.x, pt.y, 2 * depthAlpha, 0, Math.PI * 2);
            ctx.fill();
            ctx.restore();
            ctx.beginPath();
            ctx.moveTo(pt.x, pt.y);
          }
        }
        ctx.stroke();
      }
    }

    destroy() {
      this.isDestroyed = true;
      clearTimeout(this._retryTimer);
      cancelAnimationFrame(this.frameReq);
      window.removeEventListener("resize", this._resizeHandler);
      document.removeEventListener("visibilitychange", this._visibilityHandler);
      document.removeEventListener("astro:before-swap", this._swapHandler);
    }
  }

  let visualizer = new TorusVisualizer();
</script>
