---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import PlaylistSelector from "@components/PlaylistSelector.astro";
import { MUSIC } from "@consts";

const PLAYLISTS = [
  { id: "2842079283", label: "Default playlist" },
  { id: "8991745471", label: "Chill (placeholder)" },
  { id: "13054354660", label: "Top hits (placeholder)" },
];

const DEFAULT_PLAYLIST = PLAYLISTS[0].id;
---

<Layout title={MUSIC.TITLE} description={MUSIC.DESCRIPTION} hideFooter>
  <link rel="preload" href="/js/aplayer/APlayer.min.js" as="script" />
  <link rel="preload" href="/js/aplayer/Meting2.min.js" as="script" />
  <link rel="stylesheet" href="/css/aplayer/APlayer.min.css" />

  <Container>
    <main id="anMusic-page">
      <div id="an_music_bg" aria-hidden="true"></div>
      <div id="an_music_overlay" aria-hidden="true"></div>

      <PlaylistSelector
        playlists={PLAYLISTS}
        defaultPlaylist={DEFAULT_PLAYLIST}
        variant="v2"
      />

      <div class="h-2 md:h-3" aria-hidden="true"></div>

      <div id="an_music_player_mount">
        <div id="an_music_loading" class="music-loading-shell">
          <div class="music-loading-cover">
            <div class="loading-wave"></div>
            <div class="loading-wave"></div>
            <svg
              class="music-loading-svg"
              viewBox="0 0 100 100"
              aria-hidden="true"
            >
              <g class="record-base">
                <circle
                  cx="50"
                  cy="50"
                  r="46"
                  fill="url(#vinyl-plate)"
                  stroke="#1c1c1f"
                  stroke-width="0.3"></circle>

                <g id="record-grooves" opacity="0.35">
                  {
                    Array.from({ length: 9 }, (_, i) => 38 - i * 4).map((r) => (
                      <circle
                        cx="50"
                        cy="50"
                        r={r}
                        fill="none"
                        stroke="#ffffff"
                        stroke-width="0.08"
                      />
                    ))
                  }
                </g>

                <circle
                  cx="50"
                  cy="50"
                  r="14"
                  fill="#141416"
                  stroke="#2c2c30"
                  stroke-width="0.4"></circle>
                <circle
                  cx="50"
                  cy="50"
                  r="12"
                  fill="none"
                  stroke="rgba(255,255,255,0.05)"
                  stroke-width="0.15"></circle>

                <circle cx="50" cy="50" r="3.2" fill="url(#center-gold)"
                ></circle>
                <circle cx="50" cy="50" r="1.3" fill="#030303"></circle>
              </g>

              <g class="light-effect">
                <path
                  id="light-path"
                  d="M 80,50 A 30,30 0 0,1 20,50 A 30,30 0 0,1 80,50"
                  fill="none"></path>
                <path
                  d="M 80,50 A 30,30 0 0,1 20,50 A 30,30 0 0,1 80,50"
                  fill="none"
                  stroke="rgba(255,213,79,0.06)"
                  stroke-width="0.4"></path>
                <circle
                  class="light-point"
                  cx="0"
                  cy="0"
                  r="4.5"
                  fill="url(#light-gradient)"
                  filter="url(#glow)"
                >
                  <animateMotion dur="3s" repeatCount="indefinite">
                    <mpath href="#light-path"></mpath>
                  </animateMotion>
                </circle>
              </g>

              <defs>
                <radialGradient id="vinyl-plate" cx="50%" cy="50%" r="50%">
                  <stop offset="0%" stop-color="#0c0c0e"></stop>
                  <stop offset="70%" stop-color="#141417"></stop>
                  <stop offset="92%" stop-color="#1e1e22"></stop>
                  <stop offset="100%" stop-color="#08080a"></stop>
                </radialGradient>

                <radialGradient id="center-gold" cx="50%" cy="50%" r="50%">
                  <stop offset="0%" stop-color="#ffe082"></stop>
                  <stop offset="60%" stop-color="#ffb300"></stop>
                  <stop offset="100%" stop-color="#b78103"></stop>
                </radialGradient>

                <radialGradient id="light-gradient" cx="50%" cy="50%" r="50%">
                  <stop offset="0%" stop-color="#ffffff" stop-opacity="1"
                  ></stop>
                  <stop offset="25%" stop-color="#ffca28" stop-opacity="0.9"
                  ></stop>
                  <stop offset="60%" stop-color="#ff8f00" stop-opacity="0.35"
                  ></stop>
                  <stop offset="100%" stop-color="#ff6f00" stop-opacity="0"
                  ></stop>
                </radialGradient>

                <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
                  <feGaussianBlur stdDeviation="1.5" result="blur"
                  ></feGaussianBlur>
                  <feMerge>
                    <feMergeNode in="blur"></feMergeNode>
                    <feMergeNode in="SourceGraphic"></feMergeNode>
                  </feMerge>
                </filter>
              </defs>
            </svg>
          </div>
          <div class="music-loading-copy">
            <p>Loading playlist</p>
            <span>Music will start as soon as the playlist is ready.</span>
          </div>
        </div>
      </div>
    </main>
  </Container>
</Layout>

<script is:inline data-astro-rerun>
  (() => {
    const root = document.documentElement;
    const page = document.getElementById("anMusic-page");
    const bg = document.getElementById("an_music_bg");
    const mount = document.getElementById("an_music_player_mount");

    if (!page || !bg || !mount) return;

    root.classList.add("music-page-active");

    const fallbackLoadingTemplate =
      document.getElementById("an_music_loading")?.innerHTML || "";

    let currentPlaylist = null;
    let picObserver = null;
    let syncFrame = null;
    let loadScriptPromise = null;

    const loadScript = (src) =>
      new Promise((resolve, reject) => {
        const script = document.createElement("script");
        script.src = src;
        script.async = true;
        script.onload = resolve;
        script.onerror = reject;
        document.head.appendChild(script);
      });

    async function loadAPlayerScripts() {
      if (window.APlayer && window.MetingJSElement) return;
      if (!loadScriptPromise) {
        loadScriptPromise = (async () => {
          await loadScript("/js/aplayer/APlayer.min.js");
          await loadScript("/js/aplayer/Meting2.min.js");
        })();
      }
      return loadScriptPromise;
    }

    function createMetingElement(playlistId) {
      const player = document.createElement("meting-js");
      const attrs = {
        id: playlistId,
        server: "netease",
        type: "playlist",
        order: "list",
        fixed: "false",
        "list-folded": "false",
        autoplay: "false",
        mutex: "true",
        theme: "#fff",
        volume: "0.5",
      };
      Object.entries(attrs).forEach(([k, v]) => player.setAttribute(k, v));
      return player;
    }

    function destroyCurrentPlayer() {
      mount.classList.remove("is-ready");
      document.querySelectorAll("meting-js").forEach((el) => {
        if (el.aplayer) el.aplayer.destroy();
        el.remove();
      });
      document.querySelectorAll(".aplayer").forEach((el) => el.remove());
    }

    function syncCover() {
      if (syncFrame) cancelAnimationFrame(syncFrame);
      syncFrame = requestAnimationFrame(() => {
        const pic = mount.querySelector(".aplayer-pic");
        if (!pic) return;
        const cover =
          pic.style.backgroundImage ||
          window.getComputedStyle(pic).backgroundImage;

        if (
          cover &&
          cover !== "none" &&
          cover !== 'url("")' &&
          bg.dataset.currentCover !== cover
        ) {
          bg.dataset.currentCover = cover;
          bg.style.setProperty("--music-cover", cover);
          bg.classList.add("is-cover-ready");
        }
      });
    }

    function getInitialPlaylist(selector) {
      try {
        const saved = localStorage.getItem("an_music_last_playlist");
        const available = selector?.dataset.playlists
          ? JSON.parse(selector.dataset.playlists)
          : [];
        if (saved && available.some((p) => p.id === saved)) return saved;
      } catch (e) {}
      return selector?.dataset.default;
    }

    function setPlaylist(playlistId) {
      if (!playlistId || playlistId === currentPlaylist) return;
      currentPlaylist = playlistId;

      try {
        localStorage.setItem("an_music_last_playlist", playlistId);
      } catch (e) {}

      document
        .querySelectorAll("#playlist-selector [data-playlist]")
        .forEach((b) => {
          const active = b.dataset.playlist === playlistId;
          b.classList.toggle("playlist-active", active);
          b.classList.toggle("playlist-inactive", !active);
          b.setAttribute("aria-selected", String(active));
          b.tabIndex = active ? 0 : -1;
        });

      let shell = mount.querySelector("#an_music_loading");
      if (!shell) {
        shell = document.createElement("div");
        shell.id = "an_music_loading";
        shell.className = "music-loading-shell";
        shell.innerHTML = fallbackLoadingTemplate;
        mount.appendChild(shell);
      }
      shell.classList.remove("is-hidden");

      destroyCurrentPlayer();

      loadAPlayerScripts()
        .then(() => {
          mount.appendChild(createMetingElement(playlistId));
          let isReadyFired = false;

          const fireReady = (aplayer) => {
            if (isReadyFired) return;
            isReadyFired = true;

            shell.classList.add("is-hidden");
            window.setTimeout(() => {
              shell.remove();
              mount.classList.add("is-ready");
            }, 100);

            if (aplayer) {
              const pic = aplayer.querySelector(".aplayer-pic");
              if (pic) {
                picObserver?.disconnect();
                picObserver = new MutationObserver(syncCover);
                picObserver.observe(pic, {
                  attributes: true,
                  attributeFilter: ["style"],
                });
                syncCover();
              }

              const volumeWrap = aplayer.querySelector(".aplayer-volume-wrap");
              const metingJS = mount.querySelector("meting-js");
              if (volumeWrap && metingJS?.aplayer) {
                volumeWrap.addEventListener(
                  "wheel",
                  (e) => {
                    e.preventDefault();
                    const ap = metingJS.aplayer;
                    const nextVol = ap.volume() + (e.deltaY < 0 ? 0.05 : -0.05);
                    ap.volume(Math.max(0, Math.min(1, nextVol)), false);
                  },
                  { passive: false },
                );
              }
            }
          };

          const safeTimer = setTimeout(() => {
            fireReady(mount.querySelector(".aplayer"));
          }, 4000);

          const observer = new MutationObserver((_, obs) => {
            const aplayer = mount.querySelector(".aplayer");
            const listItems = mount.querySelectorAll(".aplayer-list ol li");

            if (aplayer && listItems.length > 0) {
              obs.disconnect();
              clearTimeout(safeTimer);
              setTimeout(() => fireReady(aplayer), 50);
            }
          });
          observer.observe(mount, { childList: true, subtree: true });
        })
        .catch((err) => {
          console.error("APlayer load failed", err);
        });
    }

    window.requestAnimationFrame(() => {
      const selector = document.getElementById("playlist-selector");
      const initial = getInitialPlaylist(selector);
      if (initial) setPlaylist(initial);
    });

    const selector = document.getElementById("playlist-selector");
    selector?.addEventListener("click", (e) => {
      const btn = e.target.closest("[data-playlist]");
      if (btn) setPlaylist(btn.dataset.playlist);
    });
    selector?.addEventListener("change", (e) => {
      if (e.target.matches("select")) setPlaylist(e.target.value);
    });

    document.addEventListener(
      "astro:before-swap",
      () => {
        picObserver?.disconnect();
        if (syncFrame) cancelAnimationFrame(syncFrame);
        destroyCurrentPlayer();
        root.classList.remove("music-page-active");
      },
      { once: true },
    );
  })();
</script>

<style is:global>
  html.music-page-active {
    background: #050505;
  }
  html.music-page-active body {
    background:
      radial-gradient(
        circle at 50% 0%,
        rgba(255, 255, 255, 0.12),
        transparent 38%
      ),
      #050505 !important;
    color: #fff;
  }
  html.music-page-active body > main {
    padding-block: 0 !important;
  }
  html.music-page-active #anMusic-page {
    padding-top: 72px !important;
  }
  @media (max-width: 640px) {
    html.music-page-active #anMusic-page {
      padding-top: 48px !important;
    }
  }

  html.music-page-active header {
    opacity: 0.82;
    background: rgba(5, 5, 5, 0.18) !important;
    border-bottom-color: rgba(255, 255, 255, 0.08) !important;
    backdrop-filter: blur(18px) saturate(1.25);
    -webkit-backdrop-filter: blur(18px) saturate(1.25);
    transition:
      opacity 250ms cubic-bezier(0.23, 1, 0.32, 1),
      background-color 250ms cubic-bezier(0.23, 1, 0.32, 1);
  }
  html.music-page-active header:hover {
    opacity: 1;
    background: rgba(5, 5, 5, 0.28) !important;
  }
  html.music-page-active header a,
  html.music-page-active header .nav-item {
    color: rgba(255, 255, 255, 0.72) !important;
  }
  html.music-page-active header .nav-item:hover,
  html.music-page-active header .nav-active {
    background: rgba(255, 255, 255, 0.1) !important;
    color: #fff !important;
  }
  html.music-page-active header span {
    color: rgba(255, 255, 255, 0.28) !important;
  }
  html.music-page-active #magnifying-glass {
    border-color: rgba(255, 255, 255, 0.16) !important;
    background: rgba(255, 255, 255, 0.08) !important;
    color: rgba(255, 255, 255, 0.74) !important;
    box-shadow: none !important;
  }
  html.music-page-active #magnifying-glass:hover,
  html.music-page-active #magnifying-glass:focus-visible {
    border-color: rgba(255, 255, 255, 0.24) !important;
    background: rgba(255, 255, 255, 0.14) !important;
    color: #fff !important;
  }
  html.music-page-active #magnifying-glass kbd {
    border-color: rgba(255, 255, 255, 0.14) !important;
    background: rgba(255, 255, 255, 0.1) !important;
    color: rgba(255, 255, 255, 0.5) !important;
  }
  #an_music_bg,
  #an_music_overlay {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  #an_music_bg {
    inset: -5vh;
    width: 110vw;
    height: 110vh;
    background-image: var(
      --music-cover,
      radial-gradient(
        circle at 35% 28%,
        rgba(99, 102, 241, 0.55),
        transparent 34%
      ),
      radial-gradient(
        circle at 68% 38%,
        rgba(236, 72, 153, 0.42),
        transparent 30%
      ),
      radial-gradient(
        circle at 50% 72%,
        rgba(20, 184, 166, 0.34),
        transparent 38%
      )
    );
    background-position: center;
    background-size: cover;
    filter: blur(28px) saturate(1.62) brightness(1.16);
    opacity: 1;
    scale: 1.015;
    transform-origin: center;
    transition:
      opacity 1.5s ease-in-out,
      filter 1.5s ease-in-out !important;
  }
  #an_music_bg.is-cover-ready {
    animation: none !important;
    opacity: 1 !important;
  }
  #an_music_overlay {
    background:
      radial-gradient(
        circle at 50% 22%,
        rgba(255, 255, 255, 0.24),
        transparent 30%
      ),
      radial-gradient(
        circle at 50% 50%,
        rgba(0, 0, 0, 0),
        rgba(0, 0, 0, 0.28) 66%,
        rgba(0, 0, 0, 0.58) 100%
      ),
      linear-gradient(180deg, rgba(0, 0, 0, 0.08), rgba(0, 0, 0, 0.42));
  }
  #anMusic-page {
    position: relative;
    z-index: 1;
    min-height: calc(100vh - 144px);
  }
  .music-loading-shell {
    position: relative;
    z-index: 1;
    display: grid;
    min-height: 52vh;
    place-items: center;
    gap: 24px;
    text-align: center;
    opacity: 1;
    transition:
      opacity 300ms cubic-bezier(0.23, 1, 0.32, 1),
      scale 300ms cubic-bezier(0.23, 1, 0.32, 1);
  }
  .music-loading-shell.is-hidden {
    opacity: 0;
    scale: 0.985;
  }
  .music-loading-cover {
    position: relative;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.04);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      0 24px 80px rgba(0, 0, 0, 0.35);
  }
  .loading-wave {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(255, 193, 7, 0.25);
    pointer-events: none;
    z-index: 1;
    animation: loading-ripple-effect 3s cubic-bezier(0.215, 0.61, 0.355, 1)
      infinite;
  }
  .loading-wave:nth-child(2) {
    animation-delay: 1.5s;
  }
  @keyframes loading-ripple-effect {
    0% {
      transform: scale(1);
      opacity: 0.8;
    }
    100% {
      transform: scale(1.6);
      opacity: 0;
    }
  }
  .music-loading-svg {
    width: 100%;
    height: 100%;
    position: relative;
    z-index: 2;
    animation: music-loading-spin 8s linear infinite;
    filter: drop-shadow(0 0 4px rgba(255, 255, 255, 0.3));
  }
  @keyframes music-loading-spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .music-loading-svg {
      animation: none;
    }
  }
  .music-loading-copy p {
    margin: 0;
    color: #fff;
    font-size: 1.25rem;
    font-weight: 700;
  }
  .music-loading-copy span {
    display: block;
    margin-top: 6px;
    color: rgba(255, 255, 255, 0.58);
    font-size: 0.875rem;
  }
  #anMusic-page .aplayer {
    position: relative !important;
    z-index: 1 !important;
    display: flex !important;
    flex-direction: row-reverse !important;
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    height: 75vh !important;
    margin: 0 !important;
  }
  #anMusic-page .aplayer * {
    border: none !important;
  }
  #anMusic-page .aplayer-list {
    width: 35% !important;
    display: block !important;
    height: 100% !important;
    max-height: none !important;
    padding-right: 5px !important;
    transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1) !important;
    overflow: hidden !important;
    opacity: 1 !important;
  }
  #anMusic-page .aplayer-list.aplayer-list-hide {
    width: 0 !important;
    opacity: 0 !important;
    padding-right: 0 !important;
  }
  #anMusic-page .aplayer-body {
    width: 65% !important;
    height: 100% !important;
    flex-direction: column !important;
    display: flex !important;
    padding-left: 30px !important;
    box-sizing: border-box !important;
    transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1) !important;
  }
  #anMusic-page .aplayer-list.aplayer-list-hide + .aplayer-body {
    width: 100% !important;
    padding-left: 0 !important;
  }
  #anMusic-page .aplayer:has(.aplayer-list-hide) .aplayer-body {
    width: 100% !important;
    padding-left: 0 !important;
  }
  #anMusic-page .aplayer-list ol {
    max-height: 100% !important;
    padding-right: 15px !important;
  }
  #anMusic-page .aplayer-list ol::-webkit-scrollbar {
    width: 6px !important;
  }
  #anMusic-page .aplayer-list ol::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05) !important;
    border-radius: 3px !important;
  }
  #anMusic-page .aplayer-list ol::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.3) !important;
    border-radius: 3px !important;
  }
  #anMusic-page .aplayer-list ol::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.5) !important;
  }
  #anMusic-page .aplayer-list ol li {
    background: rgba(255, 255, 255, 0.05) !important;
    border: none !important;
    border-radius: 8px !important;
    margin-bottom: 8px !important;
    color: #fff !important;
    transition: background 0.3s !important;
    padding-left: 15px !important;
  }
  #anMusic-page .aplayer-list ol li:hover {
    background: rgba(255, 255, 255, 0.15) !important;
  }
  #anMusic-page .aplayer-list ol li.aplayer-list-light {
    background: rgba(255, 255, 255, 0.2) !important;
  }
  #anMusic-page .aplayer-list ol li .aplayer-list-cur {
    left: 5px !important;
    top: 8px !important;
    height: 16px !important;
  }
  #anMusic-page .aplayer-info {
    margin: 0 !important;
    padding: 10px 20px !important;
    height: auto !important;
    text-align: center !important;
    width: 100% !important;
    flex-shrink: 0 !important;
  }
  #anMusic-page .aplayer-info .aplayer-music {
    margin-bottom: 15px !important;
    height: auto !important;
    white-space: normal !important;
    overflow: visible !important;
    line-height: 1.4 !important;
  }
  #anMusic-page .aplayer-info .aplayer-music .aplayer-title {
    font-size: 1.8rem !important;
    font-weight: 800 !important;
    color: #fff !important;
    display: block !important;
    width: 100% !important;
    word-wrap: break-word !important;
  }
  #anMusic-page .aplayer-info .aplayer-music .aplayer-author {
    color: rgba(255, 255, 255, 0.6) !important;
    margin-top: 5px !important;
  }
  #anMusic-page .aplayer-pic {
    float: none !important;
    width: 250px !important;
    height: 250px !important;
    border-radius: 20px !important;
    margin: 0 auto 30px auto !important;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4) !important;
  }
  #anMusic-page .aplayer-lrc {
    height: 300px !important;
    --lrc-line-height: 40px;
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    ) !important;
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    ) !important;
    overflow: hidden !important;
    margin-top: 10px !important;
  }
  #anMusic-page .aplayer-lrc-contents {
    padding-top: 100px !important;
  }
  #anMusic-page .aplayer-lrc:before,
  #anMusic-page .aplayer-lrc:after {
    display: none !important;
  }
  #anMusic-page .aplayer-lrc p {
    font-size: 1.1rem !important;
    color: rgba(255, 255, 255, 0.5) !important;
    font-weight: 500 !important;
    line-height: var(--lrc-line-height) !important;
    height: var(--lrc-line-height) !important;
    margin: 0 !important;
    padding: 0 !important;
    transition:
      color 0.5s ease-out,
      font-size 0.5s ease-out,
      font-weight 0.5s ease-out,
      height 0.5s ease-out !important;
  }
  #anMusic-page .aplayer-lrc p.aplayer-lrc-current {
    color: #fff !important;
    font-size: 1.4rem !important;
    font-weight: 700 !important;
    height: auto !important;
    min-height: 16px !important;
  }
  #anMusic-page .aplayer-info .aplayer-controller {
    position: fixed !important;
    bottom: 40px !important;
    left: 20px !important;
    right: 20px !important;
    width: auto !important;
    max-width: 760px !important;
    margin: 0 auto !important;
