---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import PlaylistSelector from "@components/PlaylistSelector.astro";
import { MUSIC } from "@consts";

// Playlists available for selection. Replace with actual playlist IDs.
const PLAYLISTS = [
  { id: "2842079283", label: "Default playlist" },
  { id: "8991745471", label: "Chill (placeholder)" },
  { id: "13054354660", label: "Top hits (placeholder)" },
];

const DEFAULT_PLAYLIST = PLAYLISTS[0].id;
---

<Layout title={MUSIC.TITLE} description={MUSIC.DESCRIPTION} hideFooter>
  <Container>
    <main id="anMusic-page">
      <!-- 动态封面氛围背景 -->
      <div id="an_music_bg" aria-hidden="true"></div>
      <div id="an_music_overlay" aria-hidden="true"></div>

      <PlaylistSelector
        playlists={PLAYLISTS}
        defaultPlaylist={DEFAULT_PLAYLIST}
        variant="v2"
      />

      <!-- spacer to create visual separation between selector and player (tightened) -->
      <div class="h-2 md:h-3" aria-hidden="true"></div>

      <div id="an_music_player_mount">
        <div id="an_music_loading" class="music-loading-shell">
          <div class="music-loading-cover"></div>
          <div class="music-loading-copy">
            <p>Loading playlist</p>
            <span>Music will start as soon as the playlist is ready.</span>
          </div>
        </div>
      </div>
    </main>
  </Container>
</Layout>

<!-- APlayer CSS — non-blocking load -->
<link rel="stylesheet" href="/css/aplayer/APlayer.min.css" />

<script is:inline data-astro-rerun>
  (() => {
    const root = document.documentElement;
    const page = document.getElementById("anMusic-page");
    const bg = document.getElementById("an_music_bg");
    const mount = document.getElementById("an_music_player_mount");

    if (!page || !bg || !mount) return;

    root.classList.add("music-page-active");

    let currentPlaylist = null;
    let aplayerReady = false;

    /** Dynamically load APlayer + MetingJS scripts (non-blocking). */
    function loadAPlayerScripts() {
      if (aplayerReady) return Promise.resolve();
      if (window.APlayer) { aplayerReady = true; return Promise.resolve(); }

      return new Promise((resolve, reject) => {
        const js = document.createElement("script");
        js.src = "/js/aplayer/APlayer.min.js";
        js.onload = () => {
          aplayerReady = true;
          const meting = document.createElement("script");
          meting.src = "/js/aplayer/Meting2.min.js";
          meting.onload = resolve;
          meting.onerror = reject;
          document.head.appendChild(meting);
        };
        js.onerror = reject;
        document.head.appendChild(js);
      });
    }

    function createLoadingShell() {
      const shell = document.createElement("div");
      shell.id = "an_music_loading";
      shell.className = "music-loading-shell";
      shell.innerHTML =
        '<div class="music-loading-cover"></div><div class="music-loading-copy"><p>Loading playlist</p><span>Music will start as soon as the playlist is ready.</span></div>';
      return shell;
    }

    function createMetingElement(playlistId) {
      const player = document.createElement("meting-js");
      const attrs = {
        id: playlistId,
        server: "netease",
        type: "playlist",
        order: "list",
        fixed: "false",
        "list-folded": "false",
        autoplay: "false",
        mutex: "true",
        theme: "#fff",
        volume: "0.5",
      };
      Object.entries(attrs).forEach(([key, value]) => {
        player.setAttribute(key, value);
      });
      return player;
    }

    function removeExistingPlayer() {
      const existing = mount.querySelector("meting-js");
      if (existing) existing.remove();
      document.querySelectorAll(".aplayer").forEach((n) => n.remove());
    }

    function showShell() {
      let shell = mount.querySelector("#an_music_loading");
      if (!shell) {
        shell = createLoadingShell();
        mount.appendChild(shell);
      } else {
        shell.classList.remove("is-hidden");
      }
      return shell;
    }

    function hideShell(shell) {
      shell.classList.add("is-hidden");
      window.setTimeout(() => shell.remove(), 300);
    }

    function showError() {
      const err = document.createElement("div");
      err.className = "music-loading-shell";
      err.innerHTML = '<div class="music-loading-copy"><p>无法加载歌单</p><span>请检查歌单 ID 是否有效或稍后重试。</span></div>';
      mount.appendChild(err);
      window.setTimeout(() => err.remove(), 3500);
    }

    function disablePlaylistButton(playlistId) {
      const btn = document.querySelector(`#playlist-selector [data-playlist="${playlistId}"]`);
      const select = document.querySelector('#playlist-selector select');
      if (btn) {
        btn.setAttribute("aria-disabled", "true");
        btn.disabled = true;
        btn.classList.add("playlist-disabled");
      }
      if (select && select.value === playlistId) {
        select.setAttribute('aria-disabled', 'true');
        select.disabled = true;
        select.classList.add('playlist-disabled');
      }
    }

    /** Wait for APlayer DOM to appear using MutationObserver instead of polling. */
    async function waitForAplayer(shell) {
      await new Promise((resolve) => {
        const observer = new MutationObserver((_mutations, obs) => {
          if (mount.querySelector(".aplayer")) {
            obs.disconnect();
            resolve();
          }
        });
        observer.observe(mount, { childList: true, subtree: true });
        // Safety timeout — if APlayer doesn't appear in 8s, give up
        window.setTimeout(() => { observer.disconnect(); resolve(); }, 8000);
      });
      hideShell(shell);
    }

    /** Wait for cover image to appear. */
    function waitForCover() {
      return new Promise((resolve) => {
        const observer = new MutationObserver((_mutations, obs) => {
          const pic = getPic();
          if (pic) {
            obs.disconnect();
            resolve(pic);
          }
        });
        observer.observe(mount, { childList: true, subtree: true, attributes: true });
        window.setTimeout(() => { observer.disconnect(); resolve(null); }, 8000);
      });
    }

    function setPlaylist(playlistId) {
      if (!playlistId) return;
      currentPlaylist = playlistId;

      try {
        localStorage.setItem("an_music_last_playlist", playlistId);
      } catch (e) { /* ignore */ }

      // Update selector UI
      const buttons = document.querySelectorAll("#playlist-selector [data-playlist]");
      buttons.forEach((b) => {
        const pressed = b.dataset.playlist === playlistId;
        if (pressed) {
          b.classList.add("playlist-active");
          b.classList.remove("playlist-inactive");
          b.setAttribute("tabindex", "0");
        } else {
          b.classList.remove("playlist-active");
          b.classList.add("playlist-inactive");
          b.setAttribute("tabindex", "-1");
        }
        b.setAttribute("aria-selected", pressed ? "true" : "false");
        b.setAttribute("aria-pressed", pressed ? "true" : "false");
      });

      const shell = showShell();
      removeExistingPlayer();

      // Load APlayer scripts if not yet loaded, then create player
      loadAPlayerScripts().then(() => {
        const player = createMetingElement(playlistId);
        mount.appendChild(player);
        return waitForAplayer(shell);
      }).then(() => waitForCover()).then((pic) => {
        if (pic) {
          attachCoverObserver(pic);
          scheduleSync(pic);
        }
        // If no .aplayer appeared after 8s, the playlist likely failed
        if (!mount.querySelector(".aplayer")) {
          disablePlaylistButton(playlistId);
          showError();
        }
      }).catch(() => {
        hideShell(shell);
        showError();
      });
    }

    // Initial mount: defer after paint
    window.requestAnimationFrame(() => {
      window.setTimeout(() => {
        const selector = document.getElementById("playlist-selector");
        let initial = null;
        try {
          const saved = localStorage.getItem("an_music_last_playlist");
          const available = selector?.dataset.playlists
            ? JSON.parse(selector.dataset.playlists)
            : null;
          const defaultFromDOM = selector?.dataset?.default;
          if (saved && available && available.some((p) => p.id === saved)) {
            initial = saved;
          } else if (defaultFromDOM) {
            initial = defaultFromDOM;
          } else if (available && available.length) {
            initial = available[0].id;
          }
        } catch (e) { /* ignore */ }
        if (initial) setPlaylist(initial);
      }, 0);
    });

    // Wire playlist selector clicks
    const selector = document.getElementById("playlist-selector");
    if (selector) {
      selector.addEventListener("click", (e) => {
        let node = e.target;
        if (!(node instanceof Element)) node = node?.parentElement;
        const btn = node && node.closest ? node.closest("[data-playlist]") : null;
        if (btn) {
          const id = btn.dataset.playlist;
          if (id && id !== currentPlaylist) setPlaylist(id);
        }
      });

      selector.addEventListener("keydown", (e) => {
        const buttons = Array.from(selector.querySelectorAll("[data-playlist]"));
        if (!buttons.length) return;
        const idx = buttons.indexOf(document.activeElement);
        if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
          e.preventDefault();
          const next = idx > 0 ? idx - 1 : buttons.length - 1;
          buttons[next].focus();
        } else if (e.key === "ArrowRight" || e.key === "ArrowDown") {
          e.preventDefault();
          const next = idx < buttons.length - 1 ? idx + 1 : 0;
          buttons[next].focus();
        } else if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          const btn = document.activeElement?.closest?.("[data-playlist]") || null;
          if (btn) {
            const id = btn.dataset.playlist;
            if (id && id !== currentPlaylist) setPlaylist(id);
          }
        }
      });

      selector.addEventListener('change', (e) => {
        const target = e.target;
        if (target && target.matches && target.matches('select')) {
          const id = target.value;
          if (id && id !== currentPlaylist) setPlaylist(id);
        }
      });
    }

    function normalizeCover(background) {
      if (!background || background === "none") return null;
      return background;
    }

    function getPic() {
      return document.querySelector("#anMusic-page .aplayer-pic");
    }

    function getCurrentCover(pic = getPic()) {
      if (!pic) return null;
      const inlineBackground = normalizeCover(pic.style.backgroundImage);
      if (inlineBackground) return inlineBackground;
      const computedBackground = normalizeCover(window.getComputedStyle(pic).backgroundImage);
      if (computedBackground) return computedBackground;
      const img = pic.querySelector("img");
      if (img?.currentSrc || img?.src) return `url("${img.currentSrc || img.src}")`;
      return null;
    }

    function syncMusicCoverBackground(pic = getPic()) {
      const cover = getCurrentCover(pic);
      if (!cover || bg.dataset.currentCover === cover) return false;
      bg.dataset.currentCover = cover;
      bg.style.setProperty("--music-cover", cover);
      bg.classList.add("is-cover-ready");
      return true;
    }

    let frame = 0;
    function scheduleSync(pic) {
      window.cancelAnimationFrame(frame);
      frame = window.requestAnimationFrame(() => syncMusicCoverBackground(pic));
    }

    let picObserver = null;
    function attachCoverObserver(pic) {
      if (!pic || pic.dataset.coverObserved === "true") return;
      pic.dataset.coverObserved = "true";
      picObserver = new MutationObserver(() => scheduleSync(pic));
      picObserver.observe(pic, {
        attributes: true,
        attributeFilter: ["style", "class", "src"],
        childList: true,
        subtree: true,
      });
      scheduleSync(pic);
    }

    // Clicking a track updates cover — probe a few times
    page.addEventListener("click", () => {
      const pic = getPic();
      if (pic) attachCoverObserver(pic);
      scheduleSync(pic);
      window.setTimeout(() => scheduleSync(getPic()), 120);
      window.setTimeout(() => scheduleSync(getPic()), 360);
    });

    document.addEventListener("astro:before-swap", () => {
      picObserver?.disconnect();
      window.cancelAnimationFrame(frame);
      root.classList.remove("music-page-active");
    }, { once: true });
  })();
</script>

<style is:global>
  /*
    Immersive music mode.
    All global overrides are scoped behind html.music-page-active so the normal
    blog theme is restored automatically when navigating away.
  */
  html.music-page-active {
    background: #050505;
  }

  html.music-page-active body {
    background:
      radial-gradient(
        circle at 50% 0%,
        rgba(255, 255, 255, 0.12),
        transparent 38%
      ),
      #050505 !important;
    color: #fff;
  }

  html.music-page-active body > main {
    padding-block: 0 !important;
  }

  html.music-page-active #anMusic-page {
    padding-top: 72px !important;
  }

  @media (max-width: 640px) {
    html.music-page-active #anMusic-page {
      padding-top: 48px !important;
    }
  }

  html.music-page-active header {
    opacity: 0.82;
    background: rgba(5, 5, 5, 0.18) !important;
    border-bottom-color: rgba(255, 255, 255, 0.08) !important;
    backdrop-filter: blur(18px) saturate(1.25);
    -webkit-backdrop-filter: blur(18px) saturate(1.25);
    transition:
      opacity 250ms cubic-bezier(0.23, 1, 0.32, 1),
      background-color 250ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  html.music-page-active header:hover {
    opacity: 1;
    background: rgba(5, 5, 5, 0.28) !important;
  }

  html.music-page-active header a,
  html.music-page-active header .nav-item {
    color: rgba(255, 255, 255, 0.72) !important;
  }

  html.music-page-active header .nav-item:hover,
  html.music-page-active header .nav-active {
    background: rgba(255, 255, 255, 0.1) !important;
    color: #fff !important;
  }

  html.music-page-active header span {
    color: rgba(255, 255, 255, 0.28) !important;
  }

  html.music-page-active #magnifying-glass {
    border-color: rgba(255, 255, 255, 0.16) !important;
    background: rgba(255, 255, 255, 0.08) !important;
    color: rgba(255, 255, 255, 0.74) !important;
    box-shadow: none !important;
  }

  html.music-page-active #magnifying-glass:hover,
  html.music-page-active #magnifying-glass:focus-visible {
    border-color: rgba(255, 255, 255, 0.24) !important;
    background: rgba(255, 255, 255, 0.14) !important;
    color: #fff !important;
  }

  html.music-page-active #magnifying-glass kbd {
    border-color: rgba(255, 255, 255, 0.14) !important;
    background: rgba(255, 255, 255, 0.1) !important;
    color: rgba(255, 255, 255, 0.5) !important;
  }

  /* 音乐页面背景 */
  #an_music_bg_wrapper {
    display: none !important;
  }

  #an_music_bg,
  #an_music_overlay {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  /* Cover-driven atmosphere layer. Updated by JS from the current song cover. */
  #an_music_bg {
    inset: -5vh;
    width: 110vw;
    height: 110vh;
    background-image: var(
      --music-cover,
      radial-gradient(
        circle at 35% 28%,
        rgba(99, 102, 241, 0.55),
        transparent 34%
      ),
      radial-gradient(
        circle at 68% 38%,
        rgba(236, 72, 153, 0.42),
        transparent 30%
      ),
      radial-gradient(
        circle at 50% 72%,
        rgba(20, 184, 166, 0.34),
        transparent 38%
      )
    );
    background-position: center;
    background-size: cover;
    filter: blur(28px) saturate(1.62) brightness(1.16);
    opacity: 1;
    scale: 1.015;
    transform-origin: center;
    transition:
      opacity 500ms cubic-bezier(0.23, 1, 0.32, 1),
      filter 500ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  #an_music_bg.is-cover-ready {
    animation: music-cover-in 500ms cubic-bezier(0.23, 1, 0.32, 1) both;
  }

  @keyframes music-cover-in {
    from {
      filter: blur(36px) saturate(1.35) brightness(0.96);
    }
  }

  /* Stable readability layer — keeps text legible regardless of cover color. */
  #an_music_overlay {
    background:
      radial-gradient(
        circle at 50% 22%,
        rgba(255, 255, 255, 0.24),
        transparent 30%
      ),
      radial-gradient(
        circle at 50% 50%,
        rgba(0, 0, 0, 0),
        rgba(0, 0, 0, 0.28) 66%,
        rgba(0, 0, 0, 0.58) 100%
      ),
      linear-gradient(180deg, rgba(0, 0, 0, 0.08), rgba(0, 0, 0, 0.42));
  }

  #anMusic-page {
    position: relative;
    z-index: 1;
    min-height: calc(100vh - 144px);
  }

  .music-loading-shell {
    position: relative;
    z-index: 1;
    display: grid;
    min-height: 52vh;
    place-items: center;
    gap: 20px;
    text-align: center;
    opacity: 1;
    transition:
      opacity 300ms cubic-bezier(0.23, 1, 0.32, 1),
      scale 300ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .music-loading-shell.is-hidden {
    opacity: 0;
    scale: 0.985;
  }

  .music-loading-cover {
    width: 180px;
    height: 180px;
    border-radius: 28px;
    background:
      linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.18),
        rgba(255, 255, 255, 0.04)
      ),
      rgba(255, 255, 255, 0.08);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      0 24px 80px rgba(0, 0, 0, 0.35);
    animation: music-shell-pulse 1.8s ease-in-out infinite;
  }

  .music-loading-copy p {
    margin: 0;
    color: #fff;
    font-size: 1.25rem;
    font-weight: 700;
  }

  .music-loading-copy span {
    display: block;
    margin-top: 6px;
    color: rgba(255, 255, 255, 0.58);
    font-size: 0.875rem;
  }

  @keyframes music-shell-pulse {
    0%,
    100% {
      opacity: 0.72;
      scale: 1;
    }
    50% {
      opacity: 1;
      scale: 1.015;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .music-loading-cover {
      animation: none;
    }
  }

  /* APlayer 结构重组 (安知鱼风格) */

  #anMusic-page .aplayer {
    position: relative !important;
    z-index: 1 !important;
    display: flex !important;
    flex-direction: row-reverse !important;
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    height: 75vh !important;
    margin: 0 !important;
  }

  /* 彻底消除所有内部边框和横线 */
  #anMusic-page .aplayer * {
    border-top: none !important;
    border-bottom: none !important;
    border-left: none !important;
    border-right: none !important;
  }

  /* 歌单区 (左侧 35% - 调窄) */
  #anMusic-page .aplayer-list {
    width: 35% !important;
    display: block !important;
    height: 100% !important;
    max-height: none !important;
    padding-right: 5px !important;
  }

  #anMusic-page .aplayer-list ol {
    max-height: 100% !important;
    padding-right: 15px !important; /* 给滚动条留空间 */
  }

  /* 自定义滚动条样式 */
  #anMusic-page .aplayer-list ol::-webkit-scrollbar {
    width: 6px !important;
  }

  #anMusic-page .aplayer-list ol::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05) !important;
    border-radius: 3px !important;
  }

  #anMusic-page .aplayer-list ol::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.3) !important;
    border-radius: 3px !important;
  }

  #anMusic-page .aplayer-list ol::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.5) !important;
  }

  #anMusic-page .aplayer-list ol li {
    background: rgba(255, 255, 255, 0.05) !important;
    border: none !important;
    border-radius: 8px !important;
    margin-bottom: 8px !important;
    color: #fff !important;
    transition: background 0.3s !important;
    padding-left: 15px !important; /* 给指示条留空间 */
    position: relative !important;
  }

  #anMusic-page .aplayer-list ol li:hover {
    background: rgba(255, 255, 255, 0.15) !important;
  }

  #anMusic-page .aplayer-list ol li.aplayer-list-light {
    background: rgba(255, 255, 255, 0.2) !important;
  }

  /* 当前歌曲指示条 */
  #anMusic-page .aplayer-list ol li .aplayer-list-cur {
    left: 5px !important;
    top: 8px !important;
    height: 16px !important;
  }

  /* 封面歌词区 (右侧 65% - 调宽) */
  #anMusic-page .aplayer-body {
    width: 65% !important; /* 修复宽度冲突 */
    height: 100% !important;
    flex-direction: column !important;
    display: flex !important;
    padding-left: 30px !important;
    box-sizing: border-box !important;
  }

  /* 修复歌曲名称只显示一半的问题 */
  #anMusic-page .aplayer-info {
    margin: 0 !important;
    padding: 10px 20px !important;
    height: auto !important;
    text-align: center !important;
    width: 100% !important;
    flex-shrink: 0 !important;
  }

  #anMusic-page .aplayer-info .aplayer-music {
    margin-bottom: 15px !important;
    height: auto !important;
    white-space: normal !important;
    overflow: visible !important;
    line-height: 1.4 !important;
  }

  #anMusic-page .aplayer-info .aplayer-music .aplayer-title {
    font-size: 1.8rem !important;
    font-weight: 800 !important;
    color: #fff !important;
    display: block !important;
    width: 100% !important;
    word-wrap: break-word !important;
    white-space: normal !important;
  }

  #anMusic-page .aplayer-info .aplayer-music .aplayer-author {
    color: rgba(255, 255, 255, 0.6) !important;
    margin-top: 5px !important;
  }

  #anMusic-page .aplayer-pic {
    float: none !important;
    width: 250px !important;
    height: 250px !important;
    border-radius: 20px !important;
    margin: 0 auto 30px auto !important;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4) !important;
  }

  #anMusic-page .aplayer-info {
    margin: 0 !important;
    padding: 0 !important;
    height: auto !important;
    text-align: center !important;
  }

  #anMusic-page .aplayer-info .aplayer-music {
    margin-bottom: 20px !important;
  }

  #anMusic-page .aplayer-info .aplayer-music .aplayer-title {
    font-size: 2rem !important;
    font-weight: 800 !important;
    color: #fff !important;
  }

  /* 歌词区域优化 */
  #anMusic-page .aplayer-lrc {
    height: 300px !important;
    --lrc-line-height: 40px; /* 歌词行距，可调整 */
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    ) !important;
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    ) !important;
    overflow: hidden !important;
    margin-top: 10px !important;
  }

  #anMusic-page .aplayer-lrc-contents {
    padding-top: 100px !important;
  }

  #anMusic-page .aplayer-lrc:before,
  #anMusic-page .aplayer-lrc:after {
    display: none !important;
  }

  #anMusic-page .aplayer-lrc p {
    font-size: 1.1rem !important;
    color: rgba(255, 255, 255, 0.5) !important;
    font-weight: 500 !important;
    line-height: var(--lrc-line-height) !important;
    height: var(--lrc-line-height) !important;
    margin: 0 !important;
    padding: 0 !important;
