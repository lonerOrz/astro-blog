---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { MUSIC, SITE } from "@consts";
---

<Layout title={MUSIC.TITLE} description={MUSIC.DESCRIPTION}>
  <!-- 动态虚化背景 -->
  <div id="an_music_bg"></div>

  <Container>
    <main id="anMusic-page">
      <meting-js
        id="2842079283"
        server="netease"
        type="playlist"
        order="list"
        fixed="false"
        list-folded="false"
        autoplay="false"
        mutex="true"
        theme="#fff"
        volume="0.5"></meting-js>
    </main>
  </Container>
</Layout>

<script is:inline>
  // 忽略 APlayer 内部错误
  window.addEventListener("error", (e) => {
    if (e.message?.includes("classList") && e.filename?.includes("APlayer")) {
      e.preventDefault();
    }
  });

  function syncPlayerUI() {
    const bg = document.getElementById("an_music_bg");
    if (!bg) return;

    document.body.style.backgroundColor = "transparent";

    const check = setInterval(() => {
      const pic = document.querySelector(".aplayer-pic");
      if (pic) {
        const imgUrl = window.getComputedStyle(pic).backgroundImage;
        if (imgUrl && imgUrl !== "none") {
          bg.style.backgroundImage = imgUrl;
          clearInterval(check);
        }
      }
    }, 200);

    setTimeout(() => clearInterval(check), 10000);

    // 持续监听背景变化（切歌时）
    setInterval(() => {
      const pic = document.querySelector(".aplayer-pic");
      if (pic) {
        const imgUrl = window.getComputedStyle(pic).backgroundImage;
        if (
          imgUrl &&
          imgUrl !== "none" &&
          bg.style.backgroundImage !== imgUrl
        ) {
          bg.style.backgroundImage = imgUrl;
        }
      }
    }, 1000);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", syncPlayerUI);
  } else {
    syncPlayerUI();
  }
</script>

<style is:global>
  /* 沉浸式页面基础配置 */
  main {
    margin: 0 !important;
  }

  /* 隐藏原有的博客干扰元素 */
  header,
  footer,
  #back-to-top {
    opacity: 0.3;
    transition: opacity 0.3s;
  }
  header:hover {
    opacity: 1;
  }

  #an_music_bg {
    display: block;
    filter: blur(80px);
    opacity: 0.4;
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    background-position: center;
    background-size: cover;
    transition: background-image 1s ease-in-out;
    pointer-events: none;
  }

  #anMusic-page {
    position: relative;
    z-index: 1;
    margin-top: 0rem;
    padding-top: 0 !important;
  }

  /* APlayer 结构重组 (安知鱼风格) */

  #anMusic-page .aplayer {
    display: flex !important;
    flex-direction: row-reverse !important;
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    height: 75vh !important;
    margin: 0 !important;
  }

  /* 彻底消除所有内部边框和横线 */
  #anMusic-page .aplayer * {
    border-top: none !important;
    border-bottom: none !important;
    border-left: none !important;
    border-right: none !important;
  }

  /* 歌单区 (左侧 35% - 调窄) */
  #anMusic-page .aplayer-list {
    width: 35% !important;
    display: block !important;
    height: 100% !important;
    max-height: none !important;
    padding-right: 5px !important;
  }

  #anMusic-page .aplayer-list ol {
    max-height: 100% !important;
    padding-right: 15px !important; /* 给滚动条留空间 */
  }

  /* 自定义滚动条样式 */
  #anMusic-page .aplayer-list ol::-webkit-scrollbar {
    width: 6px !important;
  }

  #anMusic-page .aplayer-list ol::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05) !important;
    border-radius: 3px !important;
  }

  #anMusic-page .aplayer-list ol::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.3) !important;
    border-radius: 3px !important;
  }

  #anMusic-page .aplayer-list ol::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.5) !important;
  }

  #anMusic-page .aplayer-list ol li {
    background: rgba(255, 255, 255, 0.05) !important;
    border: none !important;
    border-radius: 8px !important;
    margin-bottom: 8px !important;
    color: #fff !important;
    transition: all 0.3s !important;
    padding-left: 15px !important; /* 给指示条留空间 */
    position: relative !important;
  }

  #anMusic-page .aplayer-list ol li:hover {
    background: rgba(255, 255, 255, 0.15) !important;
  }

  #anMusic-page .aplayer-list ol li.aplayer-list-light {
    background: rgba(255, 255, 255, 0.2) !important;
  }

  /* 当前歌曲指示条 */
  #anMusic-page .aplayer-list ol li .aplayer-list-cur {
    left: 5px !important;
    top: 8px !important;
    height: 16px !important;
  }

  /* 封面歌词区 (右侧 65% - 调宽) */
  #anMusic-page .aplayer-body {
    width: 65% !important; /* 修复宽度冲突 */
    height: 100% !important;
    flex-direction: column !important;
    display: flex !important;
    padding-left: 30px !important;
    box-sizing: border-box !important;
  }

  /* 修复歌曲名称只显示一半的问题 */
  #anMusic-page .aplayer-info {
    margin: 0 !important;
    padding: 10px 20px !important;
    height: auto !important;
    text-align: center !important;
    width: 100% !important;
    flex-shrink: 0 !important;
  }

  #anMusic-page .aplayer-info .aplayer-music {
    margin-bottom: 15px !important;
    height: auto !important;
    white-space: normal !important;
    overflow: visible !important;
    line-height: 1.4 !important;
  }

  #anMusic-page .aplayer-info .aplayer-music .aplayer-title {
    font-size: 1.8rem !important;
    font-weight: 800 !important;
    color: #fff !important;
    display: block !important;
    width: 100% !important;
    word-wrap: break-word !important;
    white-space: normal !important;
  }

  #anMusic-page .aplayer-info .aplayer-music .aplayer-author {
    color: rgba(255, 255, 255, 0.6) !important;
    margin-top: 5px !important;
  }

  #anMusic-page .aplayer-pic {
    float: none !important;
    width: 250px !important;
    height: 250px !important;
    border-radius: 20px !important;
    margin: 0 auto 30px auto !important;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4) !important;
  }

  #anMusic-page .aplayer-info {
    margin: 0 !important;
    padding: 0 !important;
    height: auto !important;
    text-align: center !important;
  }

  #anMusic-page .aplayer-info .aplayer-music {
    margin-bottom: 20px !important;
  }

  #anMusic-page .aplayer-info .aplayer-music .aplayer-title {
    font-size: 2rem !important;
    font-weight: 800 !important;
    color: #fff !important;
  }

  /* 歌词区域优化 */
  #anMusic-page .aplayer-lrc {
    height: 300px !important;
    --lrc-line-height: 40px; /* 歌词行距，可调整 */
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    ) !important;
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    ) !important;
    overflow: hidden !important;
    margin-top: 10px !important;
  }

  #anMusic-page .aplayer-lrc-contents {
    padding-top: 100px !important;
  }

  #anMusic-page .aplayer-lrc:before,
  #anMusic-page .aplayer-lrc:after {
    display: none !important;
  }

  #anMusic-page .aplayer-lrc p {
    font-size: 1.1rem !important;
    color: rgba(255, 255, 255, 0.5) !important;
    font-weight: 500 !important;
    line-height: var(--lrc-line-height) !important;
    height: var(--lrc-line-height) !important;
    margin: 0 !important;
    padding: 0 !important;
    transition: all 0.5s ease-out !important;
  }

  #anMusic-page .aplayer-lrc p.aplayer-lrc-current {
    color: #fff !important;
    font-size: 1.4rem !important;
    font-weight: 700 !important;
    height: auto !important;
    min-height: 16px !important;
  }

  /* 控制器固定到底部 */
  #anMusic-page .aplayer-info .aplayer-controller {
    position: fixed !important;
    bottom: 40px !important;
    left: 20px !important;
    right: 20px !important;
    width: auto !important;
    max-width: 760px !important;
    margin: 0 auto !important;
    background: rgba(255, 255, 255, 0.1) !important;
    backdrop-filter: blur(20px) !important;
    padding: 10px 20px !important;
    border-radius: 50px !important;
    display: flex !important;
    align-items: center !important;
    z-index: 100 !important;
  }

  /* 进度条区域 - 居中显示 */
  #anMusic-page .aplayer-info .aplayer-controller .aplayer-bar-wrap {
    flex: 1 1 auto !important;
    margin: 0 20px !important;
    min-width: 120px !important;
  }

  /* 时间显示 */
  #anMusic-page .aplayer-info .aplayer-controller .aplayer-time {
    color: #fff !important;
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
    position: static !important;
    height: auto !important;
    padding: 0 !important;
  }

  /* 强制显示所有控制按钮 */
  #anMusic-page .aplayer-info .aplayer-controller .aplayer-time .aplayer-icon {
    display: inline-block !important;
    width: 24px !important;
    height: 24px !important;
    position: static !important;
    margin: 0 !important;
  }

  /* 按钮颜色 */
  #anMusic-page .aplayer-played {
    background: #fff !important;
  }
  #anMusic-page .aplayer-thumb {
    background: #fff !important;
  }
  #anMusic-page .aplayer-icon path {
    fill: #fff !important;
    opacity: 0.8;
  }
</style>
