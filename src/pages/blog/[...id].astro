---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import TagPill from "@components/TagPill.astro";
import { readingTime } from "@lib/utils";
import BackToPrevious from "@components/BackToPrevious.astro";
import PostNavigation from "@components/PostNavigation.astro";
import TableOfContents from "@components/TableOfContents.astro";
import Giscus from "@components/Giscus.astro";
import MarkdownImage from "@components/MarkdownImage.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter((p) => !p.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return posts.map((post, index) => ({
    params: { id: post.id.replace(/\.(md|mdx)$/, "") },
    props: {
      post,
      prevPost: posts[index - 1] ?? null,
      nextPost: posts[index + 1] ?? null,
      allPosts: posts,
    },
  }));
}

type Props = {
  post: CollectionEntry<"blog">;
  prevPost: CollectionEntry<"blog"> | null;
  nextPost: CollectionEntry<"blog"> | null;
  allPosts: CollectionEntry<"blog">[];
};

const { post, prevPost, nextPost, allPosts } = Astro.props;
const { Content, headings } = await render(post);
---

<Layout
  title={post.data.title}
  description={post.data.description || "Article by lonerOrz"}
>
  <div
    id="read-progress-bar"
    class="fixed top-0 left-0 z-[100] h-[2px] w-0 bg-zinc-900 transition-all duration-150 ease-out dark:bg-zinc-100"
  >
  </div>

  <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] bg-[size:40px_40px]"
    >
    </div>
  </div>

  <Container>
    <div hidden data-posts-index={JSON.stringify(
      allPosts.map((p) => ({
        id: p.id.replace(/\.(md|mdx)$/, ""),
        title: p.data.title,
        tags: p.data.tags || [],
      })),
    )}></div>
    <div class="animate mt-8">
      <BackToPrevious href="/blog">Back to articles</BackToPrevious>
    </div>

    <div class="mt-16 mb-12 space-y-6">
      <div class="animate-item flex items-center gap-3" style="--delay: 0.1s">
        <div
          class="flex items-center gap-2 rounded-full border border-zinc-200 bg-zinc-100/50 px-3 py-1 dark:border-zinc-800 dark:bg-zinc-900/50"
        >
          <div
            class="size-1.5 rounded-full bg-emerald-500 shadow-[0_0_5px_#10b981]"
          >
          </div>
          <span
            class="font-mono text-[9px] font-bold tracking-widest text-zinc-500 uppercase dark:text-zinc-400"
            >Published Document</span
          >
        </div>
        <div class="h-px w-8 bg-zinc-100 dark:bg-zinc-800"></div>
        <div
          class="font-mono text-[10px] tracking-tighter text-zinc-400 uppercase dark:text-zinc-500"
        >
          <FormattedDate date={post.data.date} />
        </div>
      </div>

      <div class="space-y-4">
        <h1
          class="animate-item text-4xl leading-[1.1] font-black tracking-tighter text-balance text-zinc-900 md:text-5xl dark:text-zinc-50"
          style="--delay: 0.2s"
        >
          {post.data.title}
        </h1>

        <div
          class="animate-item flex items-center gap-4 text-xs font-medium text-zinc-400 dark:text-zinc-500"
          style="--delay: 0.3s"
        >
          <div class="flex items-center gap-1.5">
            <svg
              class="size-3.5 opacity-60"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
            ><circle cx="12" cy="12" r="10"></circle><polyline
                points="12 6 12 12 16 14"></polyline></svg
            >
            {post.body && <span>{readingTime(post.body)}</span>}
          </div>
          {
            post.data.tags && post.data.tags.length > 0 && (
              <>
                <span class="opacity-30">/</span>
                <div class="flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <TagPill tag={tag} />
                  ))}
                </div>
              </>
            )
          }
        </div>
      </div>
    </div>

    {
      headings.length > 0 && (
        <div class="animate-item mb-16" style="--delay: 0.4s">
          <div class="rounded-3xl border border-zinc-100 bg-zinc-50/30 p-1 dark:border-zinc-800/50 dark:bg-zinc-900/20">
            <TableOfContents headings={headings} />
          </div>
        </div>
      )
    }

    <article class="animate-item" style="--delay: 0.5s">
      <div
        class="prose prose-neutral prose-lg dark:prose-invert prose-p:leading-relaxed prose-p:text-zinc-700 dark:prose-p:text-zinc-300 prose-headings:font-bold prose-headings:tracking-tight prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-a:font-semibold prose-a:no-underline hover:prose-a:underline max-w-none pb-24"
      >
        <Content components={{ img: MarkdownImage }} />
      </div>

      <div
        class="animate-item mt-20 flex flex-col items-center gap-6 border-t border-zinc-100 py-12 select-none dark:border-zinc-800/50"
        style="--delay: 0.2s"
      >
        <div class="flex items-center gap-4">
          <div class="h-px w-10 bg-zinc-200 dark:bg-zinc-800"></div>
          <span
            class="font-mono text-[9px] font-black tracking-[0.4em] text-zinc-400 uppercase dark:text-zinc-500"
            >End of document</span
          >
          <div class="h-px w-10 bg-zinc-200 dark:bg-zinc-800"></div>
        </div>
        <div class="flex gap-2">
          {
            [1, 2, 3].map((i) => (
              <div
                class="size-1 rounded-full bg-zinc-200 dark:bg-zinc-800"
                style={`opacity: ${1 - i * 0.25}`}
              />
            ))
          }
        </div>
      </div>

      <div class="space-y-24">
        <PostNavigation
          prevPost={prevPost}
          nextPost={nextPost}
        />
        <div class="rounded-[2.5rem] bg-zinc-50/50 p-1 dark:bg-zinc-900/30">
          <Giscus />
        </div>
      </div>
    </article>
  </Container>
</Layout>

<script is:inline>
  const postsIndex = JSON.parse(
    document.querySelector("[data-posts-index]").getAttribute("data-posts-index"),
  );

  function initTagNav() {
    const params = new URLSearchParams(location.search);
    const tag = params.get("tag");
    if (!tag) return;

    const backLink = document.querySelector("[data-back-link]");
    if (backLink) {
      backLink.setAttribute("href", `/blog?tag=${encodeURIComponent(tag)}`);
    }

    const slug = location.pathname.replace(/^\/blog\//, "");
    const sameTag = postsIndex.filter((p) => p.tags.includes(tag));
    const idx = sameTag.findIndex((p) => p.id === slug);
    if (idx === -1) return;

    const prevLink = document.querySelector('[data-nav-link="prev"]');
    const nextLink = document.querySelector('[data-nav-link="next"]');

    if (idx > 0) {
      const prev = sameTag[idx - 1];
      if (prevLink) {
        prevLink.setAttribute(
          "href",
          `/blog/${prev.id}?tag=${encodeURIComponent(tag)}`,
        );
        const titleEl = prevLink.querySelector("[data-nav-title]");
        if (titleEl) titleEl.textContent = prev.title;
      }
    } else {
      const col = prevLink?.closest("[data-nav-col]");
      if (col) col.innerHTML = '<div class="invisible"></div>';
    }

    if (idx < sameTag.length - 1) {
      const next = sameTag[idx + 1];
      if (nextLink) {
        nextLink.setAttribute(
          "href",
          `/blog/${next.id}?tag=${encodeURIComponent(tag)}`,
        );
        const titleEl = nextLink.querySelector("[data-nav-title]");
        if (titleEl) titleEl.textContent = next.title;
      }
    } else {
      const col = nextLink?.closest("[data-nav-col]");
      if (col) col.innerHTML = '<div class="invisible"></div>';
    }
  }

  initTagNav();
  document.addEventListener("astro:after-swap", initTagNav);

  function setupProgressBar() {
    const bar = document.getElementById("read-progress-bar");
    if (!bar) return;
    let ticking = false;
    const update = () => {
      const scrollY = window.scrollY;
      const height = document.documentElement.scrollHeight - window.innerHeight;
      bar.style.width = (scrollY / height) * 100 + "%";
      ticking = false;
    };
    const onScroll = () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    update();
    document.addEventListener(
      "astro:before-swap",
      () => window.removeEventListener("scroll", onScroll),
      { once: true },
    );
  }
  setupProgressBar();
  document.addEventListener("astro:after-swap", setupProgressBar);
</script>

<style is:global>
  .text-balance {
    text-wrap: balance;
  }

  .animate-item {
    opacity: 0;
    transform: translateY(15px);
    animation: slideInFade 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    animation-delay: var(--delay, 0s);
  }

  @keyframes slideInFade {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  :global(.dark) #read-progress-bar {
    box-shadow: 0 0 12px rgba(255, 255, 255, 0.2);
  }

  .prose :not(pre) > code {
    color: #27272a;
    background-color: #f4f4f5;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    border: none !important;
  }

  :global(.dark) .prose :not(pre) > code {
    color: #e4e4e7;
    background-color: rgba(39, 39, 42, 0.5);
  }
</style>
