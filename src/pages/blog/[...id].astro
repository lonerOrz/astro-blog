---
import { type CollectionEntry, render } from "astro:content";
import BlogPost from "@components/BlogPost.astro";
import MarkdownImage from "@components/MarkdownImage.astro";
import { getSortedPosts } from "@utils/nav";

export async function getStaticPaths() {
  const posts = await getSortedPosts();

  return posts.map((post, index) => ({
    params: { id: post.id.replace(/\.(md|mdx)$/, "") },
    props: {
      post,
      prevPost: posts[index - 1] ?? null,
      nextPost: posts[index + 1] ?? null,
    },
  }));
}

type Props = {
  post: CollectionEntry<"blog">;
  prevPost: CollectionEntry<"blog"> | null;
  nextPost: CollectionEntry<"blog"> | null;
};

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);
---

<BlogPost
  post={post}
  backHref="/blog"
  backLabel="Back to articles"
  prevPost={prevPost}
  nextPost={nextPost}
  linkPrefix="/blog"
  headings={headings}
>
  <Content components={{ img: MarkdownImage }} />
</BlogPost>
