---
import Layout from "../layouts/Layout.astro";
import Container from "@components/Container.astro";
import PageHeader from "@components/PageHeader.astro";
import Link from "@components/Link.astro";
import ArrowIcon from "@components/ArrowIcon.astro";

const GITHUB_USERNAME = "lonerOrz";
const ghToken = process.env.GITHUB_TOKEN;
const authHeader: Record<string, string> = ghToken
  ? { Authorization: `Bearer ${ghToken}` }
  : {};
const [ghUser, ghRepos] = await Promise.all([
  fetch(`https://api.github.com/users/${GITHUB_USERNAME}`, {
    headers: authHeader,
  }).then((r) => r.json()),
  fetch(
    `https://api.github.com/users/${GITHUB_USERNAME}/repos?sort=updated&per_page=100`,
    { headers: authHeader },
  ).then((r) => r.json()),
]);
---

<Layout
  title="GitHub Engineering Dashboard"
  description="Explore the open-source projects and technical contributions of lonerOrz."
>
  <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] bg-[size:40px_40px] dark:opacity-20"
    >
    </div>
    <div
      class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-[0.02] contrast-125 dark:opacity-[0.03]"
    >
    </div>
  </div>

  <Container>
    <div
      class="mx-auto max-w-6xl space-y-12 pb-24"
      data-github-user={GITHUB_USERNAME}
      data-gh-user={JSON.stringify(ghUser)}
      data-gh-repos={JSON.stringify(ghRepos)}
    >
      <!-- Header -->
      <div
        class="animate-slide-up flex flex-col justify-between gap-6 md:flex-row md:items-end"
        style="--delay: 0.1s"
      >
        <PageHeader title="Engineering." subtitle={`System status: Online`} />
        <!-- Verified Badge SVG -->
        <div
          class="group pointer-events-none relative hidden select-none md:block"
        >
          <svg class="size-24" viewBox="0 0 100 100">
            <path
              id="curve"
              fill="none"
              d="M 10,50 A 40,40 0 1,1 90,50 A 40,40 0 1,1 10,50"></path>
            <text
              class="fill-zinc-300 text-[10px] font-bold tracking-[0.22em] uppercase dark:fill-zinc-600"
            >
              <textPath href="#curve">
                • Github Verified Contributor • Creative Coder
              </textPath>
            </text>
            <circle
              cx="50"
              cy="50"
              r="30"
              class="fill-blue-500/5 stroke-blue-500/10 stroke-1 dark:fill-blue-500/10"
            ></circle>
            <path
              d="M42 50 L48 56 L58 44"
              class="fill-none stroke-blue-500 stroke-[3]"
              style="stroke-dasharray: 30; stroke-dashoffset: 30; animation: draw 1.2s ease forwards 0.8s;"
            ></path>
          </svg>
        </div>
      </div>

      <section
        class="animate-slide-up grid gap-6 lg:grid-cols-12"
        style="--delay: 0.2s"
      >
        <!-- Profile Box -->
        <div
          class="relative col-span-full rounded-[2.5rem] border border-zinc-200 bg-zinc-50 p-8 lg:col-span-8 dark:border-zinc-800 dark:bg-zinc-900"
        >
          <div class="absolute top-0 right-0 p-8">
            <div
              class="flex items-center gap-2 rounded-full border border-emerald-500/10 bg-emerald-500/5 px-3 py-1 text-[10px] font-black tracking-tighter text-emerald-600 uppercase dark:text-emerald-400"
            >
              <span class="size-1.5 animate-pulse rounded-full bg-emerald-500"
              ></span>
              Active
            </div>
          </div>

          <div class="relative z-10 space-y-8" id="profile-area">
            <div class="flex items-center gap-6">
              <div class="relative size-24 shrink-0">
                <div
                  class="absolute inset-0 animate-pulse rounded-[2rem] bg-zinc-200/50 dark:bg-zinc-800"
                  id="avatar-skeleton"
                >
                </div>
                <img
                  id="gh-avatar"
                  src={`https://github.com/${GITHUB_USERNAME}.png?size=200`}
                  class="relative size-full rounded-[2rem] border border-white opacity-0 shadow-lg transition-opacity duration-500 dark:border-zinc-800"
                  onload="this.classList.remove('opacity-0'); document.getElementById('avatar-skeleton').remove();"
                />
              </div>
              <div class="space-y-3">
                <h2
                  id="gh-name"
                  class="min-h-[1em] text-4xl leading-none font-black tracking-tighter text-zinc-900 uppercase italic dark:text-zinc-50"
                >
                  <div
                    class="h-9 w-48 animate-pulse rounded-lg bg-zinc-200/50 dark:bg-zinc-800"
                  >
                  </div>
                </h2>
                <div class="flex items-center gap-3">
                  <span
                    class="font-mono text-sm font-bold text-blue-600 dark:text-blue-400"
                    >@{GITHUB_USERNAME}</span
                  >
                  <div
                    id="gh-location"
                    class="text-[10px] font-black tracking-widest text-zinc-400 uppercase italic"
                  >
                  </div>
                </div>
              </div>
            </div>

            <p
              id="gh-bio"
              class="min-h-[3em] max-w-xl text-lg leading-relaxed font-medium text-zinc-600 dark:text-zinc-300"
            >
              <div class="animate-pulse space-y-2">
                <div
                  class="h-4 w-full rounded bg-zinc-200/30 dark:bg-zinc-800/50"
                >
                </div>
                <div
                  class="h-4 w-2/3 rounded bg-zinc-200/30 dark:bg-zinc-800/50"
                >
                </div>
              </div>
            </p>

            <div
              class="grid grid-cols-2 gap-4 border-t border-zinc-200 pt-4 font-mono sm:grid-cols-4 dark:border-zinc-800"
            >
              {
                ["Repos", "Followers", "Following", "Stars"].map((label) => (
                  <div class="space-y-0.5">
                    <span class="block text-[9px] font-black tracking-[0.2em] text-zinc-400 uppercase">
                      {label}
                    </span>
                    <span
                      id={`stat-${label.toLowerCase()}`}
                      class="text-3xl font-black tracking-tighter text-zinc-900 dark:text-zinc-50"
                    >
                      00
                    </span>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <!-- Tech Stack Card -->
        <div
          class="col-span-full flex flex-col justify-between rounded-[2.5rem] border border-zinc-200 bg-white p-8 transition-all lg:col-span-4 dark:border-zinc-800 dark:bg-zinc-900"
        >
          <div class="space-y-2">
            <h3
              class="text-sm font-black tracking-[0.3em] text-zinc-400 uppercase dark:text-zinc-500"
            >
              Core Stack
            </h3>
            <p class="text-xl font-bold text-zinc-900 italic dark:text-zinc-50">
              Analysis
            </p>
          </div>

          <div id="lang-container" class="my-8 space-y-6">
            <!-- Loading Skeletons -->
            {
              [1, 2, 3].map(() => (
                <div class="h-1.5 w-full animate-pulse rounded-full bg-zinc-100 dark:bg-zinc-800" />
              ))
            }
          </div>

          <Link
            href={`https://github.com/${GITHUB_USERNAME}`}
            external
            underline={false}
            class="group flex items-center justify-between rounded-2xl bg-zinc-900 px-6 py-4 text-[10px] font-black tracking-widest text-white uppercase transition-all hover:bg-blue-600 active:scale-95 dark:bg-white/10 dark:hover:bg-white dark:hover:text-zinc-900"
          >
            Visit Hub
            <ArrowIcon
              direction="right"
              class="size-3 transition-transform group-hover:translate-x-1"
            />
          </Link>
        </div>
      </section>

      <!-- 全宽热力图 -->
      <section
        class="animate-slide-up rounded-[2.5rem] border border-zinc-200 bg-white p-8 dark:border-zinc-800 dark:bg-zinc-900/40"
        style="--delay: 0.3s"
      >
        <div
          class="mb-10 flex flex-col justify-between gap-4 md:flex-row md:items-center"
        >
          <div class="space-y-1">
            <h3
              class="text-2xl leading-none font-black tracking-tighter text-zinc-900 uppercase dark:text-zinc-50"
            >
              Matrix.
            </h3>
            <p
              class="text-xs font-bold tracking-widest text-zinc-400 uppercase italic"
            >
              Annual Activity Logs
            </p>
          </div>
          <div
            class="flex items-center gap-4 font-mono text-[10px] text-zinc-400"
          >
            <span class="flex items-center gap-1.5"
              ><span
                class="size-2.5 rounded-sm border bg-zinc-100 dark:border-zinc-700 dark:bg-zinc-800"
              ></span> Empty</span
            >
            <div class="flex gap-1.5">
              {
                [1, 2, 3, 4].map((i) => (
                  <div
                    class="size-2.5 rounded-sm bg-blue-500"
                    style={`opacity: ${0.2 * i}`}
                  />
                ))
              }
            </div>
            <span class="flex items-center gap-1.5"
              >Full <span class="size-2.5 rounded-sm bg-blue-600 shadow-sm"
              ></span></span
            >
          </div>
        </div>

        <div class="group scrollbar-hide relative overflow-x-auto pb-4">
          <div
            class="min-w-[800px] origin-left transition-all duration-800 group-hover:scale-[1.005]"
          >
            <img
              id="heatmap-img"
              src={`https://ghchart.rshah.org/3b82f6/${GITHUB_USERNAME}`}
              alt="Heatmap"
              class="gh-chart w-full opacity-0 transition-opacity duration-900"
              onload="this.classList.add('opacity-100')"
            />
          </div>
        </div>
      </section>

      <!-- 精选 仓库 -->
      <section class="animate-slide-up space-y-10" style="--delay: 0.4s">
        <div class="flex items-center gap-6 px-4">
          <h3
            class="shrink-0 font-mono text-sm font-black tracking-[0.4em] text-zinc-400 uppercase"
          >
            Repositories
          </h3>
          <div
            class="h-px flex-1 bg-gradient-to-r from-zinc-100 via-zinc-200 to-zinc-100 opacity-50 dark:from-zinc-900 dark:via-zinc-800 dark:to-zinc-900"
          >
          </div>
        </div>

        <div
          id="repos-container"
          class="grid gap-6 md:grid-cols-2 lg:grid-cols-3"
        >
          {
            [1, 2, 3, 4, 5, 6].map(() => (
              <div class="h-64 animate-pulse rounded-[2.5rem] border border-zinc-200 bg-zinc-50/50 dark:border-zinc-800 dark:bg-zinc-900/20" />
            ))
          }
        </div>
      </section>
    </div>
  </Container>
</Layout>

<script is:inline>
  function initGitHub() {
    const root = document.querySelector("[data-github-user]");
    const username = root?.getAttribute("data-github-user");
    if (!username) return;

    try {
      const user = JSON.parse(root.getAttribute("data-gh-user") || "{}");
      const repos = JSON.parse(root.getAttribute("data-gh-repos") || "[]");
      if (!user.login) return;

      document.getElementById("gh-name").textContent = user.name || username;
      document.getElementById("gh-bio").textContent =
        user.bio || "Crafting digital experiences through elegant code.";
      document.getElementById("gh-location").textContent = user.location
        ? `// ${user.location.toUpperCase()}`
        : "LOCATION: ENCRYPTED";

      // 2. Rolling Counter
      const animateValue = (id, end) => {
        const obj = document.getElementById(id);
        let startTimestamp = null;
        const duration = 1200;
        const step = (timestamp) => {
          if (!startTimestamp) startTimestamp = timestamp;
          const progress = Math.min((timestamp - startTimestamp) / duration, 1);
          obj.innerText = Math.floor(progress * end);
          if (progress < 1) window.requestAnimationFrame(step);
          else obj.innerText = end;
        };
        window.requestAnimationFrame(step);
      };

      const topRepos = repos
        .filter((r) => !r.fork)
        .sort((a, b) => b.stargazers_count - a.stargazers_count)
        .slice(0, 6);
      const totalStars = repos.reduce(
        (acc, curr) => acc + curr.stargazers_count,
        0,
      );

      animateValue("stat-repos", user.public_repos);
      animateValue("stat-followers", user.followers);
      animateValue("stat-following", user.following);
      animateValue("stat-stars", totalStars);

      // 3. Languages
      const langs = {};
      repos.slice(0, 15).forEach((r) => {
        if (r.language) langs[r.language] = (langs[r.language] || 0) + 1;
      });
      const sortedLangs = Object.entries(langs)
        .sort((a, b) => b[1] - a[1])
        .slice(0, 4);

      document.getElementById("lang-container").innerHTML = sortedLangs
        .map(
          ([name, count]) => `
        <div class="group/lang">
          <div class="flex justify-between text-[10px] font-black uppercase text-zinc-400 dark:text-zinc-500 mb-1.5 transition-colors group-hover/lang:text-blue-600 dark:group-hover/lang:text-blue-400">
            <span>${name}</span>
            <span>${Math.round((count / 15) * 100)}%</span>
          </div>
          <div class="h-1 w-full bg-zinc-100 dark:bg-white/5 rounded-full overflow-hidden">
            <div class="h-full bg-zinc-900 dark:bg-blue-500 transition-all duration-900 [transition-timing-function:cubic-bezier(0.23,1,0.32,1)]" style="width: ${(count / 15) * 100}%"></div>
          </div>
        </div>
      `,
        )
        .join("");

      document.getElementById("repos-container").innerHTML = topRepos
        .map(
          (repo) => `
        <a href="${repo.html_url}" target="_blank"
           class="group relative flex flex-col justify-between rounded-[2.5rem] border border-zinc-200 bg-white p-8 transition-all duration-500 hover:-translate-y-1.5 hover:border-blue-500/40 hover:shadow-[0_20px_40px_-12px_rgba(0,0,0,0.06)] dark:border-zinc-800 dark:bg-zinc-900/50 dark:hover:border-blue-500/30 dark:hover:shadow-none translate-gpu">
          <div class="space-y-6">
            <div class="flex items-center justify-between">
              <!-- 精致 Repo 图标：响应式 Hover 背景 -->
              <div class="size-11 rounded-2xl bg-zinc-50 dark:bg-zinc-950 flex items-center justify-center transition-all duration-500 group-hover:bg-blue-600 dark:group-hover:bg-blue-500 group-hover:scale-105">
                <svg class="size-5 text-zinc-400 dark:text-zinc-500 group-hover:text-white transition-colors" viewBox="0 0 16 16" fill="currentColor">
                  <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 1 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25a.25.25 0 0 1-.4.2l-1.45-1.087a.249.249 0 0 0-.3 0L5.4 15.7a.25.25 0 0 1-.4-.2Z"></path>
                </svg>
              </div>
              <div class="flex items-center gap-1.5 font-mono text-[10px] font-black text-amber-600 dark:text-amber-500">
                <svg class="size-3 fill-current" viewBox="0 0 24 24"><path d="M12 .587l3.668 7.431L24 9.748l-6 5.854 1.416 8.262L12 18.896 4.584 23.864 6 15.602 0 9.748l8.332-1.73L12 .587z"/></svg>
                ${repo.stargazers_count}
              </div>
            </div>
            <div class="space-y-3">
              <h4 class="text-xl font-black tracking-tighter text-zinc-900 dark:text-zinc-50 group-hover:text-blue-600 dark:group-hover:text-blue-500 transition-colors uppercase leading-none">${repo.name}</h4>
              <p class="line-clamp-3 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400 font-medium">${repo.description || "System module documentation is currently being synchronized."}</p>
            </div>
          </div>
          <div class="mt-8 flex items-center justify-between pt-6 border-t border-zinc-100 dark:border-zinc-800/80">
            <span class="font-mono text-[9px] font-black uppercase tracking-widest text-zinc-400">${repo.language || "Module"}</span>
            <span class="text-[10px] font-black uppercase tracking-widest text-zinc-900 dark:text-white flex items-center gap-1 group-hover:gap-2 transition-all">
              Inspect <ArrowIcon direction="right" class="size-3" />
            </span>
          </div>
        </a>
      `,
        )
        .join("");
    } catch (e) {
      console.error(e);
    }
  }

  initGitHub();
  document.addEventListener("astro:after-swap", initGitHub);
</script>

<style>
  @keyframes draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  :global(.dark) .gh-chart {
    filter: invert(0.9) hue-rotate(180deg) brightness(1.2);
  }

  .animate-slide-up {
    opacity: 0;
    transform: translateY(24px);
    animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0s);
  }

  @keyframes slideUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .translate-gpu {
    transform: translateZ(0);
    will-change: transform, border-color;
    backface-visibility: hidden;
  }
</style>
