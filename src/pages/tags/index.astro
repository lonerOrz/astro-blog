---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import PageHeader from "@components/PageHeader.astro";
import ArrowCard from "@components/ArrowCard.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const tagMap = new Map<string, number>();
posts.forEach((post) => {
  post.data.tags?.forEach((tag) => {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  });
});

const sortedTags = [...tagMap.keys()].sort((a, b) => a.localeCompare(b));
const title = "Topics & Tags";
const description = "Browse all categories and filter articles instantly.";
---

<Layout title={title} description={description}>
  <Container>
    <div class="space-y-10">
      <div class="animate">
        <PageHeader
          title="Browse Topics"
          subtitle={`Explore articles across ${tagMap.size} different categories.`}
        />
      </div>

      <div class="animate space-y-4">
        <span
          class="block pl-1 text-[0.65rem] font-black tracking-[0.15em] text-stone-400 uppercase dark:text-stone-500"
        >
          Category Filter
        </span>
        <div class="filter-dock">
          <div class="flex flex-wrap items-center gap-2.5">
            <button
              type="button"
              class="tag-filter-btn active"
              data-tag="all"
              aria-selected="true"
            >
              <span class="btn-label">All Topics</span>
              <span class="count-badge">{posts.length}</span>
            </button>

            {
              sortedTags.map((tag) => (
                <button
                  type="button"
                  class="tag-filter-btn"
                  data-tag={tag}
                  aria-selected="false"
                >
                  <span class="btn-label">#{tag}</span>
                  <span class="count-badge">{tagMap.get(tag)}</span>
                </button>
              ))
            }
          </div>
        </div>
        <div
          class="h-[1px] w-full bg-gradient-to-r from-stone-200 to-transparent dark:from-stone-800"
        >
        </div>
      </div>

      <div class="animate space-y-6">
        <header class="flex items-center justify-between">
          <div class="flex items-center gap-2.5">
            <span class="status-dot"></span>
            <h2
              class="result-title-text text-lg font-bold tracking-tight text-stone-900 dark:text-stone-100"
            >
              All Topics
            </h2>
          </div>
          <span
            class="result-count-text rounded-lg border border-stone-200/50 bg-stone-100 px-2.5 py-1.5 text-[0.65rem] font-black tracking-widest text-stone-600 uppercase dark:border-stone-700/50 dark:bg-stone-800/80 dark:text-stone-300"
          >
            Showing {posts.length} articles
          </span>
        </header>

        <section>
          <ul class="relative flex flex-col gap-4">
            {
              posts.map((post) => (
                <li
                  class="post-item"
                  data-tags={JSON.stringify(post.data.tags || [])}
                >
                  <ArrowCard entry={post} />
                </li>
              ))
            }
          </ul>

          <div class="no-results-placeholder hidden py-12 text-center">
            <p class="text-sm font-bold text-stone-500 dark:text-stone-400">
              No articles match this topic.
            </p>
          </div>
        </section>
      </div>
    </div>
  </Container>
</Layout>

<script>
  function initFilters() {
    const container = document.querySelector(".space-y-10");
    if (!container) return;

    const urlParams = new URLSearchParams(window.location.search);
    let activeTag = urlParams.get("tag") || "all";

    const tagButtons = container.querySelectorAll(".tag-filter-btn");
    const postItems = container.querySelectorAll(
      ".post-item",
    ) as NodeListOf<HTMLElement>;
    const noResults = container.querySelector(
      ".no-results-placeholder",
    ) as HTMLElement;
    const resultCountText = container.querySelector(
      ".result-count-text",
    ) as HTMLElement;
    const resultTitleText = container.querySelector(
      ".result-title-text",
    ) as HTMLElement;

    const updatePostLinks = (tag: string) => {
      postItems.forEach((item) => {
        const link = item.querySelector("a");
        if (!link) return;
        if (!link.dataset.originalHref) {
          link.dataset.originalHref = link.getAttribute("href") || "";
        }
        const original = link.dataset.originalHref;
        const slug = original.replace(/^\/blog\//, "");
        if (tag === "all") {
          link.setAttribute("href", `/tags/all/${slug}`);
        } else {
          link.setAttribute(
            "href",
            `/tags/${encodeURIComponent(tag)}/${slug}`,
          );
        }
      });
    };

    const filterPosts = (tag: string, updateUrl = true) => {
      activeTag = tag;

      if (updateUrl) {
        const newUrl =
          tag === "all"
            ? window.location.pathname
            : `?tag=${encodeURIComponent(tag)}`;
        window.history.pushState({}, "", newUrl);
      }

      tagButtons.forEach((btn) => {
        const btnTag = btn.getAttribute("data-tag");
        const isActive = btnTag === tag;
        btn.classList.toggle("active", isActive);
        btn.setAttribute("aria-selected", String(isActive));
      });

      let matchCount = 0;
      postItems.forEach((item) => {
        const tags = JSON.parse(
          item.getAttribute("data-tags") || "[]",
        ) as string[];
        const isMatch = tag === "all" || tags.includes(tag);

        if (isMatch) {
          item.style.display = "block";
          item.style.animation = "none";
          void item.offsetWidth;
          item.style.animation =
            "slideIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards";
          matchCount++;
        } else {
          item.style.display = "none";
        }
      });

      updatePostLinks(tag);

      if (noResults) {
        noResults.classList.toggle("hidden", matchCount > 0);
      }

      if (resultCountText && resultTitleText) {
        resultTitleText.textContent = tag === "all" ? "All Topics" : `#${tag}`;
        resultCountText.textContent = `Showing ${matchCount} ${matchCount === 1 ? "article" : "articles"}`;
      }
    };

    tagButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const tag = btn.getAttribute("data-tag");
        if (tag) filterPosts(tag);
      });
    });

    filterPosts(activeTag, false);
  }

  initFilters();
  document.addEventListener("astro:after-swap", initFilters);
</script>

<style>
  :root {
    --bg-panel: rgba(255, 255, 255, 0.82);

    --border-soft: rgba(15, 23, 42, 0.08);
    --border-hover: rgba(99, 102, 241, 0.18);

    --text-main: #0f172a;
    --text-muted: #64748b;

    --accent: #4f46e5;
    --accent-hover: #4338ca;

    --badge-bg: #f1f5f9;
    --badge-text: #64748b;

    --shadow-soft:
      0 1px 2px rgba(15, 23, 42, 0.02), 0 8px 30px rgba(15, 23, 42, 0.05);

    --shadow-active:
      0 6px 20px rgba(79, 70, 229, 0.16), 0 16px 40px rgba(79, 70, 229, 0.1);
  }

  .animate {
    opacity: 0;
    transform: translateY(12px);
    animation: slideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .filter-dock {
    position: relative;

    background: var(--bg-panel);

    border: 1px solid var(--border-soft);

    border-radius: 1.15rem;

    padding: 1rem;

    backdrop-filter: blur(14px);

    box-shadow: var(--shadow-soft);
  }

  .tag-filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;

    padding: 0.38rem 0.82rem;

    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: -0.01em;

    color: var(--text-main);

    background: rgba(255, 255, 255, 0.72);

    border: 1px solid rgba(15, 23, 42, 0.08);

    border-radius: 9999px;

    cursor: pointer;

    transition:
      transform 0.24s ease,
      background-color 0.24s ease,
      border-color 0.24s ease,
      color 0.24s ease,
      box-shadow 0.24s ease;
  }

  .tag-filter-btn:hover {
    color: var(--accent);

    background: rgba(248, 250, 252, 0.96);

    border-color: var(--border-hover);

    transform: translateY(-1px);

    box-shadow:
      0 4px 12px rgba(15, 23, 42, 0.04),
      0 10px 24px rgba(79, 70, 229, 0.06);
  }

  .tag-filter-btn:active {
    transform: scale(0.97);
  }

  .tag-filter-btn.active {
    color: #ffffff;

    background: linear-gradient(180deg, #6366f1, #4f46e5);

    border-color: #4f46e5;

    box-shadow: var(--shadow-active);
  }

  .tag-filter-btn.active:hover {
    background: linear-gradient(180deg, #7275f5, #5a52ea);

    border-color: #5a52ea;

    color: #ffffff;
  }

  .count-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;

    min-width: 1.15rem;

    padding: 0.1rem 0.42rem;

    font-size: 0.64rem;
    font-weight: 800;

    border-radius: 9999px;

    background: var(--badge-bg);

    color: var(--badge-text);

    transition:
      background-color 0.24s ease,
      color 0.24s ease;
  }

  .tag-filter-btn:hover .count-badge {
    background: rgba(99, 102, 241, 0.1);

    color: var(--accent);
  }

  .tag-filter-btn.active .count-badge {
    background: rgba(255, 255, 255, 0.14);

    color: #ffffff;
  }

  .status-dot {
    width: 6px;
    height: 6px;

    border-radius: 9999px;

    background: #6366f1;

    box-shadow:
      0 0 0 4px rgba(99, 102, 241, 0.12),
      0 0 12px rgba(99, 102, 241, 0.35);
  }

  .post-item {
    opacity: 0;
    transform: translateY(14px);
  }

  @keyframes slideIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  :global(html.dark) {
    --bg-panel: rgba(10, 15, 28, 0.78);

    --border-soft: rgba(255, 255, 255, 0.08);
    --border-hover: rgba(129, 140, 248, 0.24);

    --text-main: #f8fafc;
    --text-muted: #94a3b8;

    --accent: #818cf8;
    --accent-hover: #a5b4fc;

    --badge-bg: rgba(255, 255, 255, 0.06);
    --badge-text: #94a3b8;

    --shadow-soft:
      0 1px 2px rgba(0, 0, 0, 0.3), 0 12px 36px rgba(0, 0, 0, 0.32);

    --shadow-active:
      0 8px 24px rgba(129, 140, 248, 0.2), 0 18px 40px rgba(129, 140, 248, 0.12);
  }

  :global(html.dark) .filter-dock {
    background: linear-gradient(
      180deg,
      rgba(15, 23, 42, 0.92),
      rgba(2, 6, 23, 0.92)
    );

    border-color: var(--border-soft);
  }

  :global(html.dark) .tag-filter-btn {
    color: var(--text-main);

    background: rgba(15, 23, 42, 0.72);

    border-color: rgba(255, 255, 255, 0.08);
  }

  :global(html.dark) .tag-filter-btn:hover {
    color: var(--accent-hover);

    background: rgba(30, 41, 59, 0.88);

    border-color: var(--border-hover);

    box-shadow:
      0 6px 18px rgba(0, 0, 0, 0.22),
      0 10px 28px rgba(99, 102, 241, 0.08);
  }

  :global(html.dark) .tag-filter-btn.active {
    color: #ffffff;

    background: linear-gradient(180deg, #818cf8, #6366f1);

    border-color: #6366f1;
  }

  :global(html.dark) .tag-filter-btn.active:hover {
    background: linear-gradient(180deg, #929cff, #7275f5);

    border-color: #7275f5;
  }

  :global(html.dark) .count-badge {
    background: rgba(255, 255, 255, 0.06);

    color: #94a3b8;
  }

  :global(html.dark) .tag-filter-btn:hover .count-badge {
    background: rgba(129, 140, 248, 0.12);

    color: #c7d2fe;
  }

  :global(html.dark) .tag-filter-btn.active .count-badge {
    background: rgba(255, 255, 255, 0.14);

    color: #ffffff;
  }

  :global(html.dark) .status-dot {
    background: #818cf8;

    box-shadow:
      0 0 0 4px rgba(129, 140, 248, 0.12),
      0 0 14px rgba(129, 140, 248, 0.4);
  }
</style>
