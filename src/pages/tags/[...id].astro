---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import ArrowCard from "@components/ArrowCard.astro";
import BackToPrevious from "@components/BackToPrevious.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((post) => post.data.tags || []))];
  return tags.map((tag) => ({
    params: { id: tag },
    props: {
      posts: posts.filter((post) => post.data.tags?.includes(tag)),
    },
  }));
}

const { id } = Astro.params;
const { posts } = Astro.props;

const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
---

<Layout title={`Tag: ${id}`} description={`Posts with the tag: ${id}`}>
  <Container>
    <div class="space-y-10" data-pagefind-ignore>
      <div class="animate">
        <BackToPrevious href="/tags">All tags</BackToPrevious>
      </div>
      <div class="animate space-y-1.5">
        <h1 class="text-3xl font-semibold text-zinc-900 dark:text-zinc-50">
          #{id}
        </h1>
        <p class="font-mono text-xs text-zinc-400 dark:text-zinc-500">
          {sortedPosts.length}
          {sortedPosts.length === 1 ? "article" : "articles"}
        </p>
      </div>
      <div class="animate border-t border-zinc-200 dark:border-zinc-800">
        <ul class="not-prose">
          {
            sortedPosts.map((post) => (
              <li>
                <ArrowCard entry={post} />
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </Container>
</Layout>
