---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { SITE, HOME, SOCIALS } from "@consts";
import Link from "@components/Link.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const allBlog = (await getCollection("blog")).filter(
  (post) => !post.data.draft,
);
const blog = allBlog
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const allProjects: CollectionEntry<"projects">[] = (
  await getCollection("projects")
).filter((project) => !project.data.draft);
const projects = allProjects
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);

const totalArticles = allBlog.length;
const totalProjects = allProjects.length;
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <div class="pointer-events-none fixed top-0 left-0 z-50 h-0.5 w-full overflow-hidden" aria-hidden="true">
    <svg class="loading-line h-full w-full" preserveAspectRatio="none" viewBox="0 0 100 1">
      <line x1="0" y1="0" x2="100" y2="0" class="stroke-gradient" stroke-width="2" />
    </svg>
  </div>

  <div class="pointer-events-none fixed inset-0 -z-20 bg-[linear-gradient(to_right,#8080800a_1px,transparent_1px),linear-gradient(to_bottom,#8080800a_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]" aria-hidden="true" />

  <Container>
    <aside data-pagefind-ignore class="mx-auto max-w-3xl">
      <section class="relative py-16 sm:py-24">

        <div class="grid grid-cols-1 gap-10 md:grid-cols-3 md:items-start">
          <div class="relative space-y-6 md:col-span-2">
            <div class="pointer-events-none absolute -left-6 top-1.5 hidden h-40 w-4 md:block" aria-hidden="true">
              <svg width="100%" height="100%" viewBox="0 0 16 160" fill="none" preserveAspectRatio="none" class="stroke-anim-path">
                <path d="M8 0V120L1 127H15L8 134V160" stroke="currentColor" class="text-zinc-200 dark:text-zinc-800" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="8" cy="120" r="2.5" class="fill-emerald-500" />
              </svg>
            </div>

            <div class="reveal-item inline-flex items-center gap-2 rounded-md border border-zinc-200/60 bg-zinc-50/50 px-2.5 py-1 backdrop-blur-sm dark:border-zinc-800/60 dark:bg-zinc-900/30" style="--order: 1;">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse" />
              <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-zinc-400 dark:text-zinc-500">
                Digital garden
              </span>
            </div>

            <h1 class="reveal-text text-4xl font-extrabold leading-[1.1] tracking-tight text-zinc-900 sm:text-5xl dark:text-zinc-50" style="--order: 2;">
              Hi, I'm lonerOrz.<br />
              <span class="bg-gradient-to-r from-emerald-500 via-cyan-500 to-indigo-500 bg-clip-text text-transparent dark:from-emerald-400 dark:to-cyan-400">
                Trying to make sense of things.
              </span>
            </h1>

            <p class="reveal-item max-w-md text-base leading-relaxed text-zinc-500 dark:text-zinc-400" style="--order: 3;">
              A developer who values simplicity and meaningful code. This space documents learning, shares insights, and captures fleeting ideas.
            </p>

            <div class="reveal-item border-l-2 border-zinc-200 pl-4 py-0.5 dark:border-zinc-800" style="--order: 4;">
              <p class="font-mono text-xs italic tracking-wide text-zinc-400 dark:text-zinc-500">
                今こそ、救いの时だ。
              </p>
            </div>

            <div class="reveal-item pt-2" style="--order: 5;">
              <a
                href="/blog"
                class="group inline-flex items-center gap-1.5 rounded-xl border border-zinc-200 bg-white px-4 py-2.5 text-sm font-medium text-zinc-700 shadow-sm transition-all duration-300 active:scale-[0.97] hover:border-zinc-300 hover:text-zinc-900 hover:shadow-[0_4px_12px_rgba(0,0,0,0.03)] dark:border-zinc-800 dark:bg-zinc-950 dark:text-zinc-300 dark:hover:border-zinc-700 dark:hover:text-zinc-50"
              >
                <span>Explore the garden</span>
                <svg
                  aria-hidden="true"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-zinc-400 transition-transform duration-300 group-hover:translate-x-1 dark:text-zinc-500"
                >
                  <path d="M5 12h14" />
                  <path d="m12 5 7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>

        </div>
      </section>

      <hr class="reveal-item border-zinc-200/60 dark:border-zinc-800/60" style="--order: 5;" />

      <section class="space-y-5 py-14">
        <div class="reveal-item flex items-center justify-between" style="--order: 5;">
          <h2 class="text-xs font-bold uppercase tracking-wider text-zinc-400 dark:text-zinc-500">
            Recent Writing
          </h2>
          <Link
            href="/blog"
            underline={false}
            class="text-xs text-zinc-400 transition-colors hover:text-zinc-900 dark:text-zinc-500 dark:hover:text-zinc-50"
          >
            All articles →
          </Link>
        </div>

        <ul class="space-y-1">
          {blog.map((post, i) => (
            <li
              class="stagger-row"
              style={`--delay: ${400 + i * 40}ms`}
            >
              <a
                href={`/blog/${post.id}`}
                class="group flex items-center gap-4 rounded-xl px-3 py-3.5 transition-all duration-200 active:scale-[0.99] hover:bg-zinc-50 dark:hover:bg-zinc-900/40"
              >
                <span class="relative flex h-4 w-4 items-center justify-center font-mono text-xs text-zinc-300 dark:text-zinc-700">
                  <span class="transition-all duration-300 group-hover:scale-0 group-hover:opacity-0">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="absolute h-3.5 w-3.5 scale-0 opacity-0 text-emerald-500 transition-all duration-300 group-hover:scale-100 group-hover:opacity-100 dark:text-emerald-400">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </span>

                <span class="flex-1 truncate text-sm font-medium text-zinc-800 transition-colors group-hover:text-zinc-900 dark:text-zinc-300 dark:group-hover:text-zinc-50">
                  {post.data.title}
                </span>

                <time class="shrink-0 font-mono text-[11px] text-zinc-400 transition-transform duration-300 group-hover:-translate-x-1 dark:text-zinc-500">
                  {post.data.date.toLocaleDateString("en-US", {
                    month: "short",
                    year: "numeric",
                  })}
                </time>
              </a>
            </li>
          ))}
        </ul>
      </section>

      {projects.length > 0 && (
        <Fragment>
          <hr class="reveal-item border-zinc-200/60 dark:border-zinc-800/60" style="--order: 6;" />
          <section class="space-y-5 py-14">
            <div class="reveal-item flex items-center justify-between" style="--order: 6;">
              <h2 class="text-xs font-bold uppercase tracking-wider text-zinc-400 dark:text-zinc-500">
                Projects
              </h2>
              <Link
                href="/projects"
                underline={false}
                class="text-xs text-zinc-400 transition-colors hover:text-zinc-900 dark:text-zinc-500 dark:hover:text-zinc-50"
              >
                All projects →
              </Link>
            </div>
            <ul class="space-y-1">
              {projects.map((project, i) => (
                <li
                  class="stagger-row"
                  style={`--delay: ${550 + i * 40}ms`}
                >
                  <a
                    href={`/projects/${project.id}`}
                    class="group flex items-center gap-4 rounded-xl px-3 py-3.5 transition-all duration-200 active:scale-[0.99] hover:bg-zinc-50 dark:hover:bg-zinc-900/40"
                  >
                    <span class="relative flex h-4 w-4 items-center justify-center font-mono text-xs text-zinc-300 dark:text-zinc-700">
                      <span class="transition-all duration-300 group-hover:scale-0 group-hover:opacity-0">
                        {String(i + 1).padStart(2, '0')}
                      </span>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="absolute h-3.5 w-3.5 scale-0 opacity-0 text-cyan-500 transition-all duration-300 group-hover:scale-100 group-hover:opacity-100 dark:text-cyan-400">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                      </svg>
                    </span>

                    <span class="flex-1 truncate text-sm font-medium text-zinc-800 transition-colors group-hover:text-zinc-900 dark:text-zinc-300 dark:group-hover:text-zinc-50">
                      {project.data.title}
                    </span>

                    <span class="hidden shrink-0 max-w-[180px] truncate text-right font-mono text-[11px] text-zinc-400 transition-transform duration-300 group-hover:-translate-x-1 dark:text-zinc-500 sm:block">
                      {project.data.description}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        </Fragment>
      )}

      <hr class="reveal-item border-zinc-200/60 dark:border-zinc-800/60" style="--order: 7;" />

      <section class="reveal-item space-y-5 py-14" style="--order: 7;">
        <h2 class="text-xs font-bold uppercase tracking-wider text-zinc-400 dark:text-zinc-500">
          Connect
        </h2>
        <ul class="flex flex-wrap gap-x-6 gap-y-3">
          {SOCIALS.map((SOCIAL) => (
            <li>
              <Link
                href={SOCIAL.HREF}
                external
                underline={false}
                class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-50"
              >
                {SOCIAL.NAME}
              </Link>
            </li>
          ))}
          <li>
            <Link
              href={`mailto:${SITE.EMAIL}`}
              underline={false}
              class="text-sm text-zinc-500 transition-colors hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-50"
            >
              {SITE.EMAIL}
            </Link>
          </li>
        </ul>
      </section>
    </aside>
  </Container>
</Layout>

<style is:global>
  @keyframes lineLoading {
    0% { transform: scaleX(0); transform-origin: left; opacity: 1; }
    45% { transform: scaleX(1); transform-origin: left; opacity: 1; }
    50% { transform: scaleX(1); transform-origin: right; opacity: 1; }
    100% { transform: scaleX(0); transform-origin: right; opacity: 0; }
  }

  .loading-line {
    animation: lineLoading 1.1s cubic-bezier(0.65, 0, 0.35, 1) forwards;
  }

  .stroke-gradient {
    stroke: #10b981;
  }
  :global(.dark) .stroke-gradient {
    stroke: #34d399;
  }

  @keyframes textReveal {
    0% { clip-path: inset(0 0 100% 0); transform: translateY(24px); }
    100% { clip-path: inset(0 0 0% 0); transform: translateY(0); }
  }

  .reveal-text {
    animation: textReveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(var(--order) * 70ms + 150ms);
  }

  @keyframes elementReveal {
    0% { opacity: 0; transform: translateY(10px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .reveal-item {
    opacity: 0;
    animation: elementReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(var(--order) * 70ms + 100ms);
  }

  .stagger-row {
    opacity: 0;
    animation: elementReveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: var(--delay);
  }

  @keyframes softGlow {
    0%, 100% { transform: scale(1) translate(0px, 0px); opacity: 0.9; }
    50% { transform: scale(1.05) translate(4px, -6px); opacity: 1; }
  }
  .animate-glow {
    animation: softGlow 8s ease-in-out infinite;
  }

  @keyframes drawStroke {
    0% { stroke-dashoffset: 400; }
    100% { stroke-dashoffset: 0; }
  }

  .stroke-box-path rect {
    stroke-dasharray: 400;
    stroke-dashoffset: 400;
    animation: drawStroke 1.2s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 450ms;
  }

  @keyframes drawVerticalLine {
    0% { stroke-dasharray: 200; stroke-dashoffset: 200; opacity: 0; }
    30% { opacity: 1; }
    100% { stroke-dasharray: 200; stroke-dashoffset: 0; opacity: 1; }
  }

  .stroke-anim-path path {
    animation: drawVerticalLine 1.5s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 300ms;
  }

  .stroke-anim-path circle {
    opacity: 0;
    animation: elementReveal 0.4s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 1.1s;
  }
</style>
