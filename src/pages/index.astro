---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { SITE, HOME, SOCIALS } from "@consts";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
// terminal



const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const projects: CollectionEntry<"projects">[] = (
  await getCollection("projects")
)
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);


---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <!-- 新加一个 欢迎文本 和 网站大logo -->
    <div class="flex items-center justify-center gap-16 py-20">
      <div class="max-w-xl space-y-6">
        <h1 class="text-8xl font-extrabold leading-tight">
          <span
            class="bg-gradient-to-r from-blue-500 to-purple-500 bg-clip-text text-transparent"
          >
            Welcome to lonerOrz's website!
          </span>
        </h1>
        <div class="tagline text-lg text-gray-600 dark:text-gray-400">System online.</div>
        今こそ、救いの時だ。
      </div>
      <img
        src="/site/hero.png"
        alt="Website Logo"
        class="h-[400px] w-[400px] object-contain"
      />
    </div>

    <!-- 保持距离的div -->
    <div class="h-24"></div>

    <aside data-pagefind-ignore>
      <h1 class="font-semibold text-black dark:text-white">About this space</h1>
      <div class="space-y-16">
        <section>
          <article class="space-y-4">
            <span>
              <p>
                Welcome to my digital garden. I'm a developer who values
                simplicity and meaningful code. This blog is built to be fast,
                minimal, and focused on content—no unnecessary noise, just
                thoughts and tech.
              </p>
              <p>
                I use this space to document my learning journey, share
                technical insights, and capture fleeting ideas that would
                otherwise be lost in the noise of the internet.
              </p>
            </span>
            <span class="animate">
              <p>
                The world of software is vast and often overwhelming. Here, I
                try to slow down and build things with intent. Whether it's a
                deep dive into a new framework or a simple reflection on daily
                life, everything here is a piece of my digital footprint.
              </p>
            </span>
          </article>
        </section>



        <section class="animate space-y-4">
          <h2 class="font-semibold text-black dark:text-white">
            Let's Connect
          </h2>
          <article>
            <p>
              If you want to get in touch with me about something or just to say
              hi, reach out on social media or send me an email.
            </p>
          </article>
          <ul class="not-prose flex flex-wrap gap-4 items-center">
            {
              SOCIALS.map((SOCIAL) => (
                <li class="flex gap-x-2 text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-white">
                  <Link
                    href={SOCIAL.HREF}
                    external
                    aria-label={`${SITE.TITLE} on ${SOCIAL.NAME}`}
                  >
                    {SOCIAL.NAME}
                  </Link>
                  {"/"}
                </li>
              ))
            }
            <li class="line-clamp-1">
              <Link
                href={`mailto:${SITE.EMAIL}`}
                aria-label={`Email ${SITE.TITLE}`}
              >
                {SITE.EMAIL}
              </Link>
            </li>
          </ul>
        </section>
      </div>
    </aside>
  </Container>
</Layout>
