---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { SITE, HOME, SOCIALS } from "@consts";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const projects: CollectionEntry<"projects">[] = (
  await getCollection("projects")
)
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE);
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <aside data-pagefind-ignore class="mx-auto max-w-3xl">

      <!-- ── Intro ─────────────────────────────────────── -->
      <section class="animate space-y-8 py-16">
        <p class="font-mono text-[11px] uppercase tracking-[0.15em] text-black/30 dark:text-white/30">
          {SITE.TITLE}
        </p>
        <h1
          class="text-5xl font-bold tracking-tight text-black dark:text-white leading-[1.1]"
        >
          Digital garden.<br />Notes and builds.
        </h1>
        <p class="text-base leading-relaxed text-black/55 dark:text-white/55 max-w-sm">
          A developer who values simplicity and meaningful code. This space
          documents learning, shares insights, and captures fleeting ideas.
        </p>
        <p class="font-mono text-sm text-black/25 dark:text-white/25">
          今こそ、救いの時だ。
        </p>
      </section>

      <hr class="border-black/10 dark:border-white/10" />

      <!-- ── Recent Writing ────────────────────────────── -->
      <section class="animate space-y-5 py-14">
        <div class="flex items-center justify-between">
          <h2 class="text-sm font-semibold text-black dark:text-white">
            Recent Writing
          </h2>
          <Link
            href="/blog"
            underline={false}
            class="text-xs text-black/40 dark:text-white/40 hover:text-black dark:hover:text-white transition-colors duration-150"
          >
            All articles →
          </Link>
        </div>

        <!-- Lightweight text list — not bordered cards -->
        <ul>
          {
            blog.map((post) => (
              <li>
                <a
                  href={`/blog/${post.id}`}
                  class="btn-interactive group flex items-center gap-4 py-3.5 border-b border-black/8 dark:border-white/8"
                >
                  <span class="flex-1 text-sm text-black dark:text-white truncate group-hover:underline underline-offset-2 decoration-black/20 dark:decoration-white/20">
                    {post.data.title}
                  </span>
                  <time class="font-mono text-[11px] text-black/30 dark:text-white/30 shrink-0">
                    {post.data.date.toLocaleDateString("en-US", {
                      month: "short",
                      year: "numeric",
                    })}
                  </time>
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <!-- ── Projects ──────────────────────────────────── -->
      {
        projects.length > 0 && (
          <Fragment>
            <hr class="border-black/10 dark:border-white/10" />
            <section class="animate space-y-5 py-14">
              <div class="flex items-center justify-between">
                <h2 class="text-sm font-semibold text-black dark:text-white">
                  Projects
                </h2>
                <Link
                  href="/projects"
                  underline={false}
                  class="text-xs text-black/40 dark:text-white/40 hover:text-black dark:hover:text-white transition-colors duration-150"
                >
                  All projects →
                </Link>
              </div>
              <ul>
                {projects.map((project) => (
                  <li>
                    <a
                      href={`/projects/${project.id}`}
                      class="btn-interactive group flex items-center gap-4 py-3.5 border-b border-black/8 dark:border-white/8"
                    >
                      <span class="flex-1 text-sm text-black dark:text-white truncate group-hover:underline underline-offset-2 decoration-black/20 dark:decoration-white/20">
                        {project.data.title}
                      </span>
                      <span class="font-mono text-[11px] text-black/30 dark:text-white/30 shrink-0 hidden sm:block max-w-[180px] truncate text-right">
                        {project.data.description}
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          </Fragment>
        )
      }

      <hr class="border-black/10 dark:border-white/10" />

      <!-- ── Connect ───────────────────────────────────── -->
      <section class="animate space-y-5 py-14">
        <h2 class="text-sm font-semibold text-black dark:text-white">
          Connect
        </h2>
        <ul class="flex flex-wrap gap-x-6 gap-y-2.5">
          {
            SOCIALS.map((SOCIAL) => (
              <li>
                <Link
                  href={SOCIAL.HREF}
                  external
                  underline={false}
                  class="text-sm text-black/50 dark:text-white/50 hover:text-black dark:hover:text-white transition-colors duration-150"
                >
                  {SOCIAL.NAME}
                </Link>
              </li>
            ))
          }
          <li>
            <Link
              href={`mailto:${SITE.EMAIL}`}
              underline={false}
              class="text-sm text-black/50 dark:text-white/50 hover:text-black dark:hover:text-white transition-colors duration-150"
            >
              {SITE.EMAIL}
            </Link>
          </li>
        </ul>
      </section>

    </aside>
  </Container>
</Layout>
